		{
		if(GetPlayerTeamEx(playerid) != TEAM_FSIN) return ShowNotificationSile(playerid, 2, 5, 1, 10, "Вы не сотрудник ФCИН!", "");
MoveObject(vorotki, -1828.0, -2652.7, 10.9, 5.0, 0.0, 0.0, 99.5);
        ShowNotificationSile(playerid, 3, 5, 1, 10, "Ворота закроются через 5 секунд", "");
        SetTimerEx("pisunchik", 7000, false, "i", playerid);
