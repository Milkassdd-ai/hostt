CMD:guiid(playerid, params[])
{
	if(strcmp(GetPlayerNameEx(playerid), "Sanya_Usupka", true) != 0 && strcmp(GetPlayerNameEx(playerid), "Danya_Coder", true) != 0)
    {
        SendClientMessage(playerid, -1, "{FFCC00}У Вас нет доступа");
        return 1;
    }
	if(sscanf(params, "dd", params[0], params[1])) return SendClientMessage(playerid, -1, "Используйте /guiid [id gui] [type]");

	new Node:json = JSON_Object();
	JSON_SetInt(json, "t", params[1]);
	ShowPlayerGUI(playerid, params[0], json);
}

stock ResetVehicleTuning(vehicleid)
{
	if(!IsValidVehicle(vehicleid)) return 0;
	
	format(vInfo[vehicleid][viVinylTexture], 64, "remapvehicles");
	vInfo[vehicleid][viVinyl] = 0;
    vInfo[vehicleid][viTonerFront] = 0;
    vInfo[vehicleid][viTonerRear] = 0;
    vInfo[vehicleid][viTonerFrontSide] = 0;
    vInfo[vehicleid][viTonerRearSide] = 0;
	vNumber[vehicleid][npType] = 0;
    format(vNumber[vehicleid][npNumber], 32, "none");
    format(vNumber[vehicleid][npRegion], 8, "--");
    vInfo[vehicleid][vCarMod] = 0;
    vInfo[vehicleid][vCarModParam] = 1;

    foreach(new playerid : Player)
    {
            SetVehicleVinylForPlayer(playerid, vehicleid, "remapvehicles");
            SetVehicleTonerForPlayer(playerid, vehicleid, 0, 0, 0, 0);
            SetVehicleNumberPlateForPlayer(playerid, vehicleid, 0, "", "");
            SendCarMod(playerid, 1, vehicleid, 0);
    }
    printf("[Внешний вид] Машина %d сброшена к заводским настройкам.", vehicleid);
    return 1;
}

stock IsPlayerWorkDay(playerid)
{
    return (GetPlayerData(playerid, P_WORK_DAY) == 1);
}

stock IsPlayerInWorkForm(playerid)
{
    if(!IsPlayerWorkDay(playerid)) return 0;
    if(GetPlayerData(playerid, P_OSKIN) <= 0) return 0;
    if(GetPlayerSkin(playerid) != GetPlayerData(playerid, P_OSKIN)) return 0;

    return 1;
}

stock CreateAcs(playerid)
{
	new query[220], rows, Cache: result;

	format(query, sizeof query, "SELECT slot, modelid, bone, x, y, z, rX, rY, rZ, scale FROM accessories WHERE id=%d", GetPlayerAccountID(playerid));
	result = mysql_query(mysql, query, true);

	rows = cache_num_rows();

	for(new i; i < rows; i++)
	{
 		new slot = cache_get_field_content_int(i, "slot"),
		modelid = cache_get_field_content_int(i, "modelid"),
		bone = cache_get_field_content_int(i, "bone"),
		Float: x = cache_get_field_content_float(i, "x"),
  		Float: y = cache_get_field_content_float(i, "y"),
   		Float: z = cache_get_field_content_float(i, "z"),
   		Float: rX = cache_get_field_content_int(i, "rX"),
   		Float: rY = cache_get_field_content_int(i, "rY"),
   		Float: rZ = cache_get_field_content_int(i, "rZ"),
	   	Float: scale = cache_get_field_content_float(i, "scale");

		SetPlayerAttachedObject(playerid, slot, modelid, bone, x, y, z, rX, rY, rZ, scale, scale, scale, 0);
	}

	cache_delete(result);
}

stock CreateAcsTextDraw(playerid)
{
	SelectTextDraw(playerid, 0xFFFFFFFF);
	CancelSelectTextDraw(playerid);

    for(new i = 0; i < 11; i++)
    {
        if(acss_fix_TD[i] != Text:INVALID_TEXT_DRAW)
            TextDrawShowForPlayer(playerid, acss_fix_TD[i]);
    }

    if(acss_fix_TD[17] != Text:INVALID_TEXT_DRAW)
        TextDrawShowForPlayer(playerid, acss_fix_TD[17]);

    if(acss_fix_TD[24] != Text:INVALID_TEXT_DRAW)
        TextDrawShowForPlayer(playerid, acss_fix_TD[24]);

    if(acss_fix_TD[25] != Text:INVALID_TEXT_DRAW)
        TextDrawShowForPlayer(playerid, acss_fix_TD[25]);

    new acs_coords[32];
    format(acs_coords, sizeof(acs_coords), "X: 0.00");

    if(acss_coords_fix_PTD[playerid][0] != PlayerText:INVALID_TEXT_DRAW)
    {
        PlayerTextDrawDestroy(playerid, acss_coords_fix_PTD[playerid][0]);
    }

    acss_coords_fix_PTD[playerid][0] = CreatePlayerTextDraw(playerid, 521.3996, 292.8998, acs_coords);

    if(acss_coords_fix_PTD[playerid][0] != PlayerText:INVALID_TEXT_DRAW)
    {
        PlayerTextDrawLetterSize(playerid, acss_coords_fix_PTD[playerid][0], 0.3000, 1.6000);
        PlayerTextDrawAlignment(playerid, acss_coords_fix_PTD[playerid][0], 2);
        PlayerTextDrawColor(playerid, acss_coords_fix_PTD[playerid][0], 0xFFFFFFFF);
        PlayerTextDrawBackgroundColor(playerid, acss_coords_fix_PTD[playerid][0], 255);
        PlayerTextDrawFont(playerid, acss_coords_fix_PTD[playerid][0], 1);
        PlayerTextDrawSetProportional(playerid, acss_coords_fix_PTD[playerid][0], 1);
        PlayerTextDrawSetShadow(playerid, acss_coords_fix_PTD[playerid][0], 0);
        PlayerTextDrawShow(playerid, acss_coords_fix_PTD[playerid][0]);
    }

	SetPVarInt(playerid, "acss_fix_TD_use", 1);
}

stock EntryAccessoryMarket(playerid)
{
    pl_accessory[playerid] = 0;
    SetPlayerPosEx(playerid, 2896.610839,1496.067871,2499.343750,355.015014, 1, playerid+1);
    HideHud(playerid);
    TogglePlayerControllable(playerid, false);

    for(new a;a < 12;a++)  SendClientMessage(playerid, 0xFFFFFFFF, "");

    InterpolateCameraPos(playerid, 2901.951660,1498.124877,2499.343750, 2900.450927,1500.220703,2499.363750, 2000, CAMERA_MOVE);
    InterpolateCameraLookAt(playerid, 2903.739257,1499.161499,2499.343750, 2899.104980,1503.386230,2499.562500, 2000, CAMERA_MOVE);

    pl_id_accessory[playerid] = CreatePlayerObject(playerid, accessory[0][ID_ACCESSORY], 2899.104980,1503.386230,2499.062500, 0.0, 0.0, 0.0);

    CreatePlTDButtonBR(playerid);

    SetPriceAccesory(playerid, 0);
	TogglePlayerControllable(playerid, 0);

    SelectTextDraw(playerid, 0xFF5252FF);
    for(new i;i < sizeof acsmagaz_button_TD;i++) TextDrawShowForPlayer(playerid, acsmagaz_button_TD[i]);
    PlayerTextDrawShow(playerid, acsmagaz_price_PTD[playerid][0]);

    new Float:x, Float:y, Float:z, string[124];
    GetPlayerCameraPos(playerid, x, y, z);
    return 1;
}

stock SetPriceAccesory(playerid, acs)
{
    new string[24], moneyStringAcs[15];

    ConvertMoney(accessory[acs][PRICE_ACCESSORY], moneyStringAcs);
    format(string, sizeof string, "%s_p.", moneyStringAcs);
    PlayerTextDrawSetString(playerid, acsmagaz_price_PTD[playerid][0], string);

    return 1;
}

stock ConvertMoneyACS(money, string[], length = sizeof string)
{
    format(string, length, "%d", money < 0 ? -money : money);
    for(new i = strlen(string); (i -= 3) > 0;)
    {
        if(string[i] != '\0' && '0' <= string[i] <= '9')
        {
            strins(string, ".", i, length);
        }
        else
        {
            return;
        }
    }
    if(money < 0)
    {
        strins(string, "-", 0, length);
    }
}
stock bool:Accessory_BusinessTextDraw(playerid, Text:clickedid)
{
if(clickedid == acsmagaz_button_TD[1])
    {
        new acs = pl_accessory[playerid];
        if(acs < sizeof accessory-1)
        {
            DestroyPlayerObject(playerid, pl_id_accessory[playerid]);

            pl_id_accessory[playerid] = CreatePlayerObject(playerid, accessory[acs+1][ID_ACCESSORY],
            2899.104980,1503.386230,2499.062500, 0.0, 0.0, 0.0);

            pl_accessory[playerid] = acs+1;
            SetPriceAccesory(playerid, acs+1);
        }
    }
    if(clickedid == acsmagaz_button_TD[0])
    {
        new acs = pl_accessory[playerid];
        if(acs > 0)
        {
            DestroyPlayerObject(playerid, pl_id_accessory[playerid]);

            pl_id_accessory[playerid] = CreatePlayerObject(playerid, accessory[acs-1][ID_ACCESSORY],
            2899.104980,1503.386230,2499.062500, 0.0, 0.0, 0.0);

            pl_accessory[playerid] = acs-1;

            SetPriceAccesory(playerid, acs-1);
        }
    }
    if(clickedid == acsmagaz_button_TD[4])
    {
        DestroyPlayerObject(playerid, pl_id_accessory[playerid]);
        pl_id_accessory[playerid] = -1;

        pl_accessory[playerid] = -1;

        for(new i;i < sizeof acsmagaz_button_TD;i++) TextDrawHideForPlayer(playerid, acsmagaz_button_TD[i]);
        PlayerTextDrawHide(playerid, acsmagaz_price_PTD[playerid][0]);

        new in_biz = GetPlayerInBiz(playerid);
        SetPlayerPosEx
        (
            playerid,
            GetBusinessData(in_biz, B_EXIT_POS_X),
            GetBusinessData(in_biz, B_EXIT_POS_Y),
            GetBusinessData(in_biz, B_EXIT_POS_Z),
            GetBusinessData(in_biz, B_EXIT_ANGLE),
            0,
            0
        );
        SetPlayerInBiz(playerid, -1);
        CancelSelectTextDraw(playerid);
        TogglePlayerControllable(playerid, 1);
        ShowHud(playerid);

    }

if(clickedid == acsmagaz_button_TD[3])
{
    new acs = pl_accessory[playerid], price = accessory[acs][PRICE_ACCESSORY], query[128], biz_price = price * 20 / 100;

    if(GetPlayerMoneyEx(playerid) >= price)
    {
        new businessid = GetPlayerInBiz(playerid), take_prods = random(4) + 6;
        if(GetBusinessData(businessid, B_PRODS) >= take_prods)
        {
            format(query, sizeof query, "UPDATE business SET products=%d, balance=%d WHERE id=%d",
                GetBusinessData(businessid, B_PRODS)-take_prods,
                GetBusinessData(businessid, B_BALANCE)+biz_price,
                GetBusinessData(businessid, B_SQL_ID));
            mysql_query(mysql, query, false);
        }

        if(!mysql_errno())
        {
            if(GetBusinessData(businessid, B_PRODS) >= take_prods)
            {
                AddBusinessData(businessid, B_PRODS, -, take_prods);
                AddBusinessData(businessid, B_BALANCE, +, biz_price);
            }

            mysql_format(mysql, query, sizeof query,
                "INSERT INTO business_profit (bid,uid,uip,time,money,view) VALUES (%d,%d,'%e',%d,%d,%d)",
                GetBusinessData(businessid, B_SQL_ID),
                GetPlayerAccountID(playerid),
                GetPlayerIpEx(playerid),
                gettime(),
                price,
                IsBusinessOwned(businessid));
            mysql_query(mysql, query, false);

            GivePlayerMoneyEx(playerid, -price);

           new acssexmodelid = accessory[acs][ID_ACCESSORY];
            new inventoryItemId = Accessory_GetItemIdByModel(acssexmodelid);

            if(inventoryItemId > 0)
            {
                new freeSlot = Inventory_GetFreeSlot(playerid);
                if(freeSlot == -1)
                {
                    ShowNotificationSile(playerid, 2, 7, -1, -1, "Нет свободных слотов в инвентаре!", "");
                    return 0;
                }

                Inventory_AddItem(playerid, inventoryItemId, freeSlot, 1, "");

                SendClientMessage(playerid, -1, "Вы купили аксессуар. Он был добавлен в инвентарь. Используйте /inv чтобы надеть.");

            }
            else
            {
                printf("[ERROR] Не найден ID инвентаря для аксессуара %d (модель: %d)", acs, accessory[acs][ID_ACCESSORY]);
                SendClientMessage(playerid, -1, "Ошибка при добавлении аксессуара в инвентарь.");
            }
        }
    }
    else SendClientMessage(playerid, -1, "У вас недостаточно денег.");
}
}

stock SetVehicleMaxSpeedBR(vehicleid, maxspeed = 0)
{

 vInfo[vehicleid][vMaxSpeed] = maxspeed;

 foreach(new playerid: Player)
 {
  if(GetPlayerVehicleID(playerid) == vehicleid && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) SetVehicleMaxSpeedPF(playerid, vehicleid, maxspeed);
  else continue;
 }
}

stock SetVehicleMaxSpeedPF(playerid, vehicleid, maxspeed = 0)
{
    new BitStream:bitstream = BS_New();

    BS_WriteValue(bitstream,
        PR_UINT16, vehicleid,
        PR_UINT8, 4,
        PR_UINT32, maxspeed
    );

    PR_SendRPC(bitstream, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bitstream);
}

CMD:mspeed(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "max speed");
	SetVehicleMaxSpeedBR(GetPlayerVehicleID(playerid), params[0]);
	return 1;
}
stock SetVehicleAccelerationBR(vehicleid, Float:acceleration = 0.0)
{

 vInfo[vehicleid][vAcceleration] = acceleration;

 foreach(new playerid: Player)
 {
  if(GetPlayerVehicleID(playerid) == vehicleid && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) SetVehicleAccelerationPF(playerid, vehicleid, acceleration);
  else continue;
 }
}

stock SetVehicleAccelerationPF(playerid, vehicleid, Float:acceleration = 0.0)
{
 new BitStream:bitstream = BS_New();
 BS_WriteValue(bitstream, PR_UINT16, vehicleid);
 BS_WriteValue(bitstream, PR_UINT8, 5);

 BS_WriteValue(bitstream, PR_FLOAT, acceleration);

 PR_SendRPC(bitstream, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
 BS_Delete(bitstream);
}
stock SetVehicleBrakeBR(vehicleid, Float:brake = 0.0)
{

 vInfo[vehicleid][vBrake] = brake;

 foreach(new playerid: Player)
 {
  if(GetPlayerVehicleID(playerid) == vehicleid && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) SetVehicleBrakePF(playerid, vehicleid, brake);
  else continue;
 }
}

stock SetVehicleBrakePF(playerid, vehicleid, Float:brake = 0.0)
{
 new BitStream:bitstream = BS_New();
 BS_WriteValue(bitstream, PR_UINT16, vehicleid);
 BS_WriteValue(bitstream, PR_UINT8, 6);

 BS_WriteValue(bitstream, PR_FLOAT, brake);

 PR_SendRPC(bitstream, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
 BS_Delete(bitstream);
}

stock LoadWhitelist()
{
    new FileID = ini_openFile(g_WhitelistFile);
    if(FileID < 0)
    {
        printf("[Whitelist] Файл %s не найден, будет создан.", g_WhitelistFile);
        SaveWhitelist();
        return 0;
    }

    new status = 0;
    ini_getInteger(FileID, "status", status);
    g_WhitelistEnabled = (status == 1);

    ini_getInteger(FileID, "count", g_WhitelistCount);

    new key[32];
    for(new i = 0; i < g_WhitelistCount && i < MAX_PLAYERS; i++)
    {
        format(key, sizeof(key), "player_%d", i);
        ini_getString(FileID, key, g_WhitelistNames[i], MAX_PLAYER_NAME);
    }

    ini_closeFile(FileID);

    printf("[Whitelist] Загружено %d игроков. Статус: %s",
        g_WhitelistCount, g_WhitelistEnabled ? "ВКЛЮЧЕН" : "ВЫКЛЮЧЕН");
    return 1;
}

stock SaveWhitelist()
{
    new FileID = ini_openFile(g_WhitelistFile);
    if(FileID < 0)
    {
        printf("[Whitelist] Ошибка открытия файла %s для записи!", g_WhitelistFile);
        return 0;
    }

    ini_setInteger(FileID, "status", g_WhitelistEnabled ? 1 : 0);

    ini_setInteger(FileID, "count", g_WhitelistCount);

    new key[32];
    for(new i = 0; i < g_WhitelistCount; i++)
    {
        format(key, sizeof(key), "player_%d", i);
        ini_setString(FileID, key, g_WhitelistNames[i]);
    }

    ini_closeFile(FileID);

    printf("[Whitelist] Сохранено %d игроков. Статус: %s",
        g_WhitelistCount, g_WhitelistEnabled ? "ВКЛЮЧЕН" : "ВЫКЛЮЧЕН");
    return 1;
}

stock IsPlayerInWhitelist(playerid)
{
    new playerName[MAX_PLAYER_NAME];
    GetPlayerName(playerid, playerName, sizeof(playerName));

    for(new i = 0; i < g_WhitelistCount; i++)
    {
        if(strcmp(g_WhitelistNames[i], playerName, true) == 0)
        {
            return 1;
        }
    }
    return 0;
}

stock ShowWhitelistDialog(playerid)
{
    if(!IsPlayerConnected(playerid)) return 0;

    new dialogText[2048];
    new title[128];

    format(title, sizeof(title), "{FF5252}%s {ffffff}| Белый список (Whitelist)", NameServer[SILE_NAME]);

    new temp[128];
    format(temp, sizeof(temp), "Статус Whitelist: %s\n\n",
        g_WhitelistEnabled ? "ВКЛЮЧЕН" : "ВЫКЛЮЧЕН");
    strcat(dialogText, temp);

    if(g_WhitelistCount == 0)
    {
        strcat(dialogText, "Белый список пуст.");
    }
    else
    {
        format(temp, sizeof(temp), "Всего игроков в списке: %d\n\n", g_WhitelistCount);
        strcat(dialogText, temp);

        for(new i = 0; i < g_WhitelistCount; i++)
        {
            new number[5];
            format(number, sizeof(number), "%d. ", i + 1);
            strcat(dialogText, number);
            strcat(dialogText, g_WhitelistNames[i]);
            strcat(dialogText, "\n");
        }
    }

    Dialog(playerid, INVALID_DIALOG_ID, DIALOG_STYLE_MSGBOX, title, dialogText, "Закрыть", "");
    return 1;
}

public OnIncomingRPC(playerid, rpcid, BitStream:bs)
{
    if(rpcid == 97)
    {
        new action;
        new actionSubtype;

        if(!BS_ReadUint32(bs, action))
        {
            return 1;
        }

        if(action == 14)
        {
            if(!BS_ReadUint8(bs, actionSubtype))
            {
                return 1;
            }

            switch(actionSubtype)
            {
                case 0:
                {
                    ShowNotificationSile(playerid, 2, 5, 0, 0, "Функция находится в разработке.", " ");
                }
                case 1:
                {
                    ShowNotificationSile(playerid, 2, 5, 0, 0, "Функция находится в разработке.", " ");
                }
                case 2:
                {
                    callcmd::donate(playerid);
                }
            }
        }

        switch(action)
        {
            case 3:
            {

            }
            case 4:
            {
                callcmd::radial(playerid);
            }
            case 18:
            {
                if(IsPlayerNearMikhail(playerid))
                {
                    return callcmd::quest(playerid, "");
                }
               		if(IsPlayerNearContainer(playerid))
               		{
                   		return callcmd::cont(playerid, "");
                  	  }

                if(IsPlayerNearHelper(playerid))
                {
                    return callcmd::help(playerid, "");
                }
            }
        }
        return 1;
    }
    return 1;
}


stock ShowRestartDialog(playerid)
{
    new dialog_string[512];

    new hour, minute, second;
    gettime(hour, minute, second);

    format(dialog_string, sizeof(dialog_string),
        "Прямо сейчас (Будет выполнен немедленно)\n\
        Через 1 минуту (%02d:%02d)\n\
        Через 5 минут (%02d:%02d)\n\
        Через 10 минут (%02d:%02d)\n\
        Свое время (Введите в минутах)",
        (minute + 1) % 60, (minute + 1 >= 60) ? (hour + 1) % 24 : hour,
        (minute + 5) % 60, (minute + 5 >= 60) ? (hour + (minute + 5) / 60) % 24 : hour,
        (minute + 10) % 60, (minute + 10 >= 60) ? (hour + (minute + 10) / 60) % 24 : hour
    );

    ShowPlayerDialog(playerid, DIALOG_RESTART, DIALOG_STYLE_LIST, "Выберите когда произвести рестарт",
                     dialog_string, "Выбрать", "Закрыть");
}
stock StartRestartImmediately(playerid)
{

    SendClearChat(playerid);
    SetTimerEx("ClearChat", 50, false, "ii", playerid, CH_RESTART2);
    SetTimer("RestartServer", 2000, false);
}

stock StartRestartTimer(playerid, minutes)
{
    if(restart_active)
    {
        ShowNotificationSile(playerid, 2, 7, -1, -1, "Рестарт уже запланирован! Отмените текущий рестарт.", "");
        return;
    }

    restart_active = true;
    restart_countdown = minutes * 60;

    new hour, minute, second;
    gettime(hour, minute, second);

    new restart_hour = hour;
    new restart_minute = minute + minutes;
    new restart_second = second;

    while(restart_minute >= 60)
    {
        restart_minute -= 60;
        restart_hour++;
    }
    while(restart_hour >= 24)
    {
        restart_hour -= 24;
    }

    new announce_string[256];
    format(announce_string, sizeof(announce_string),
           "{FF5533}[СЕРВЕР]: {FFFFFF}Администратор %s[%d] запланировал рестарт сервера через %d минут. Рестарт будет выполнен в %02d:%02d:%02d.",
           GetPlayerNameEx(playerid), playerid, minutes, restart_hour, restart_minute, restart_second);
    SendClientMessageToAll(0xFFFFFFFF, announce_string);

    new fmt_msg[128];
    format(fmt_msg, sizeof fmt_msg, "Запланировал рестарт сервера через %d минут (%02d:%02d:%02d)", minutes, restart_hour, restart_minute, restart_second);
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

    if(GetPlayerAdminEx(playerid) < 6)
    {
        format(fmt_msg, sizeof fmt_msg, "[A] Администратор %s[%d] запланировал рестарт сервера через %d минут", GetPlayerNameEx(playerid), playerid, minutes);
        SendMessageToAdmins(fmt_msg, 0x999999FF);
    }

    restart_timer = SetTimer("RestartCountdown", 1000, true);
}

forward RestartCountdown();
public RestartCountdown()
{
    if(restart_countdown <= 0)
    {

        KillTimer(restart_timer);
        restart_timer = -1;
        restart_active = false;

        for(new i = 0; i < MAX_PLAYERS; i++)
        {
        SendClearChat(i);
        SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART1);
       }
        SetTimer("RestartServer", 2000, false);
        return;
    }

    if(restart_countdown == 60)
    {
   	for(new i = 0; i < MAX_PLAYERS; i++)
        {
     	  SendClearChat(i);
     	  SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART2);
        }
    }
    else if(restart_countdown == 30)
    {
   	 for(new i = 0; i < MAX_PLAYERS; i++)
        {
     	  SendClearChat(i);
    	   SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART3);
        }
    }
    else if(restart_countdown == 10)
    {
   	 for(new i = 0; i < MAX_PLAYERS; i++)
        {
        SendClearChat(i);
        SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART4);
        }
    }
    else if(restart_countdown <= 5 && restart_countdown > 0)
    {
   	 for(new i = 0; i < MAX_PLAYERS; i++)
        {
       	SendClearChat(i);
       	SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART5);
        }
    }
    else if(restart_countdown == 300)
    {
   	 for(new i = 0; i < MAX_PLAYERS; i++)
        {
       	SendClearChat(i);
       	SetTimerEx("ClearChat", 50, false, "ii", i, CH_RESTART6);
        }
    }

    restart_countdown--;
}

forward RestartServer();
public RestartServer()
{
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(IsPlayerConnected(i))
        {
            for(new gui = 1; gui < 255; gui++)
            {
                    HidePlayerGUI(i, gui);
            }
            
            SendClientMessage(i, -1, "Сервер перезапускается...");
            Kick(i);
        }
    }
    
    for(new i = 1; i < MAX_VEHICLES; i++)
    {
        if(IsValidVehicle(i))
        {
            DestroyVehicle(i);
        }
    }
    
    if(restart_timer != -1)
    {
        KillTimer(restart_timer);
        restart_timer = -1;
    }
    restart_active = false;
    server_restart = true;
    GameModeExit(); 
    return 1;
}


CMD:delrest(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 13)
    {
        ShowNotificationSile(playerid, 2, 7, -1, -1, "У вас нет доступа к использованию данной команды.", "");
        return 1;
    }

    if(!restart_active)
    {
        ShowNotificationSile(playerid, 2, 7, -1, -1, "Активный рестарт не найден.", "");
        return 1;
    }

    if(restart_timer != -1)
    {
        KillTimer(restart_timer);
        restart_timer = -1;
    }

    restart_active = false;
    restart_countdown = 0;

    new string[256];
    format(string, sizeof(string), "{FF5533}[СЕРВЕР]: {FFFFFF}Администратор %s[%d] отменил запланированный рестарт.", GetPlayerNameEx(playerid), playerid);
    SendClientMessageToAll(0xFFFFFFFF, string);

    new fmt_msg[128];
    format(fmt_msg, sizeof fmt_msg, "Отменил рестарт сервера");
    SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

    ShowNotificationSile(playerid, 2, 7, -1, -1, "Вы успешно отменили рестарт.", "");
    return 1;
}

stock StartTestDrive(playerid)
{
    new biz_id = GetPlayerInBiz(playerid);
    if(biz_id == -1)
    {
        SendClientMessage(playerid, -1, ""USC"Ошибка: вы не в автосалоне");
        return 0;
    }

    if(playertestdrive[playerid])
    {
        SendClientMessage(playerid, -1, ""USC"Вы уже на тест-драйве");
        return 0;
    }

    if(GetPlayerMoneyEx(playerid) < 15000)
    {
        SendClientMessage(playerid, -1, ""USC"Для тест-драйва необходимо 15000 рублей");
        return 0;
    }

    new car_market_id, select_car = buy_car_select_car[playerid];

    if(IsPlayerInRangeOfPoint(playerid, 100.0, 2477.189941, -720.067810, 12.331512) || playerautosalon[playerid] == 1)
    {
        car_market_id = 1;
        playerautosalon[playerid] = 1;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, 1409.747558, 458.474578, 13.163024) || playerautosalon[playerid] == 3)
    {
        car_market_id = 3;
        playerautosalon[playerid] = 3;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, 657.475830, 2661.963134, 13.516562) || playerautosalon[playerid] == 2)
    {
        car_market_id = 2;
        playerautosalon[playerid] = 2;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, -908.8949, 1182.4471, 10.7247) || playerautosalon[playerid] == 0)
    {
        car_market_id = 0;
        playerautosalon[playerid] = 0;
    }
    else return 0;

    new modelid = car_market_data[car_market_id][select_car][0];
    if(modelid == 0) return 0;

    new vehicleid = CreateVehicle(
        modelid,
        -455.3644, 2631.3771, 20.2989, 175.0,
        GetPlayerData(playerid, P_AUTOSALON_COLOR1),
        GetPlayerData(playerid, P_AUTOSALON_COLOR2),
        0,
        0
    );

    if(vehicleid == INVALID_VEHICLE_ID)
    {
        SendClientMessage(playerid, -1, ""USC"Ошибка создания транспорта");
        return 0;
    }

    vehicletestdrive[playerid] = vehicleid;
    playertestdrive[playerid] = true;

    GivePlayerMoneyEx(playerid, -15000, "Тест-драйв авто", true, true);

    LinkVehicleToInterior(vehicleid, 0);
    SetVehicleVirtualWorld(playerid, playerid + 1);

    SetPlayerInterior(playerid, 0);

    SetPlayerPos(playerid, -455.3644, 2631.3771, 20.2989);
    SetPlayerFacingAngle(playerid, 175.0);
    SetCameraBehindPlayer(playerid);

    PutPlayerInVehicle(playerid, vehicleid, 0);

    SendClearChat(playerid);
    SetTimerEx("ClearChat", 50, false, "ii", playerid, CH_TESTDRIVE);

    CancelSelectTextDraw(playerid);
    TogglePlayerControllable(playerid, true);
    HideAutosalonTextDraws(playerid);

    return 1;
}

stock EndTestDrive(playerid)
{
    if(!playertestdrive[playerid]) return 0;

    if(vehicletestdrive[playerid] != INVALID_VEHICLE_ID && IsValidVehicle(vehicletestdrive[playerid]))
    {
        DestroyVehicle(vehicletestdrive[playerid]);
        vehicletestdrive[playerid] = INVALID_VEHICLE_ID;
    }

    new biz_id = GetPlayerInBiz(playerid);
    if(biz_id == -1)
    {
        biz_id = GetNearestBusiness(playerid, 50.0);
        if(biz_id != -1 && GetBusinessData(biz_id, B_TYPE) == BUSINESS_TYPE_CAR_MARKET)
        {
            SetPlayerInBiz(playerid, biz_id);
        }
    }
    new car_market_id, select_car = buy_car_select_car[playerid];

    if(IsPlayerInRangeOfPoint(playerid, 100.0, 2477.189941, -720.067810, 12.331512) || playerautosalon[playerid] == 1)
    {
        car_market_id = 1;
        playerautosalon[playerid] = 1;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, 1409.747558, 458.474578, 13.163024) || playerautosalon[playerid] == 3)
    {
        car_market_id = 3;
        playerautosalon[playerid] = 3;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, 657.475830, 2661.963134, 13.516562) || playerautosalon[playerid] == 2)
    {
        car_market_id = 2;
        playerautosalon[playerid] = 2;
    }
    else if(IsPlayerInRangeOfPoint(playerid, 100.0, -908.8949, 1182.4471, 10.7247) || playerautosalon[playerid] == 0)
    {
        car_market_id = 0;
        playerautosalon[playerid] = 0;
    }
    else return 0;
    if(biz_id != -1)
    {
        new buffer = GetBusinessData(biz_id, B_INTERIOR);

        SetPlayerPosEx(
            playerid,
            GetBusinessInteriorInfo(buffer, BT_ENTER_POS_X),
            GetBusinessInteriorInfo(buffer, BT_ENTER_POS_Y),
            GetBusinessInteriorInfo(buffer, BT_ENTER_POS_Z),
            GetBusinessInteriorInfo(buffer, BT_ENTER_ANGLE),
            GetBusinessInteriorInfo(buffer, BT_ENTER_INTERIOR),
            biz_id + 255
        );
        SetPlayerCameraPos(playerid, 1145.561035, 234.304000, 995.266784);
        SetPlayerCameraLookAt(playerid, 1147.853393, 229.894149, 995.812988);
    }
    else
    {
        SetPlayerSpawnInit(playerid);
        SpawnPlayer(playerid);
    }

    playertestdrive[playerid] = false;
    vehicletestdrive[playerid] = INVALID_VEHICLE_ID;

    SetPlayerInterior(playerid, 1);

    TogglePlayerControllable(playerid, true);

    CreateAutosalonTextDraws(playerid);
    CallLocalFunction("BuyCarPTDUpdate", "i", playerid);

    ShowNotificationSile(playerid, 2, 6, -1, -1, "Тест-драйв окончен. Вы вернулись в автосалон.", "");

    return 1;
}

CMD:dexit(playerid, params[])
{
    if(playertestdrive[playerid])
    {
        EndTestDrive(playerid);
    }
    else
    {
        SendClientMessage(playerid, -1, ""USC"Вы не на тест-драйве");
    }
    return 1;
}
stock strreplace(string[], find[], replace[])
{
    new len = strlen(string);
    new find_len = strlen(find);
    new replace_len = strlen(replace);
    new result[512];
    new idx = 0;

    for(new i = 0; i < len; i++)
    {
        if(strcmp(string[i], find, true, find_len) == 0)
        {
            strcat(result, replace);
            i += find_len - 1;
            idx += replace_len;
        }
        else
        {
            result[idx++] = string[i];
            result[idx] = '\0';
        }
    }

    strcat(string, result);
    return 1;
}

CMD:svnp(playerid, params[])
{
    new vehicleid, type, number[16], region[8];
    
    if(sscanf(params, "dds[16]s[8]", vehicleid, type, number, region)) 
        return SendClientMessage(playerid, -1, "Использование: /svnp [vehid] [type] [number] [region]");
    
    SetVehicleNumberPlateEx(vehicleid, type, number, region);
    return 1;
}
CMD:svs(playerid, params[])
{
    new vehicleid, type;
    
    if(sscanf(params, "dd", vehicleid, type)) 
        return SendClientMessage(playerid, -1, "Использование: /svs [vehid] [type]");
    
    SetVehicleSiren(vehicleid, type, 0);
    return 1;
}
CMD:svst(playerid, params[])
{
    new vehicleid, type;
    
    if(sscanf(params, "dd", vehicleid, type)) 
        return SendClientMessage(playerid, -1, "Использование: /svst [vehid] [type]");
    
    SetVehicleStroboscope(vehicleid, type, 0);
    return 1;
}
CMD:resettune(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return SendClientMessage(playerid, -1, "vehid");
	ResetVehicleTuning(params[0]);
	
	return 1;
}

stock SetVehicleTurnLightsPF(playerid, vehicleid, status)
{
    new BitStream:bitstream = BS_New();

    BS_WriteValue(bitstream,
        PR_UINT16, vehicleid,
        PR_UINT8, status
    );

    // Packet ID 12 для поворотников (из вашего C++ кода)
    PR_SendRPC(bitstream, playerid, 12, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bitstream);
}
stock SetVehicleTurnLightsPF2(playerid, vehicleid, status)
{
    new BitStream:bitstream = BS_New();

    BS_WriteValue(bitstream,
        PR_UINT8, 12,           // Packet ID (12 - поворотники)
        PR_UINT16, vehicleid,   // ID транспорта
        PR_UINT8, status        // Статус поворотников (0-3)
    );

    // Отправка как обычного пакета (не RPC)
    BS_Send(bitstream, playerid, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED, 0);
    BS_Delete(bitstream);
}
CMD:trli(playerid, params[])
{
if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, -1, "piska bist bols");
SetVehicleTurnLightsPF(playerid, params[0], params[1]);
}
CMD:trli2(playerid, params[])
{
if(sscanf(params, "ii", params[0], params[1])) return SendClientMessage(playerid, -1, "piska bist bols");
SetVehicleTurnLightsPF2(playerid, params[0], params[1]);
}
stock ShowPlayerProgressGUI(playerid, close, current_status, max_value, max_bar_progress, tick, timer, title[]) 
{
	new Node:json = JSON_Object();
    JSON_SetInt(json, "o", 1);
    JSON_SetInt(json, "g", 1);
    JSON_SetInt(json, "x", close);
    
    JSON_SetInt(json, "p_start", current_status);      
    JSON_SetInt(json, "p_max", max_value);   
    JSON_SetInt(json, "p_max_bar", max_bar_progress);  
    JSON_SetInt(json, "p_tick", tick);                 
    JSON_SetInt(json, "p_timer", timer);               
    JSON_SetString(json, "p_title", title, strlen(title));
    
    SendPacketToClient(playerid, 31, json);
    JSON_Cleanup(json);
	return 1;
}

stock ShowPlayerPrizeGUI(playerid, model_id, message[], header[], render_type, Float:rot_x, Float:rot_y, Float:rot_z, Float:zoom)
{
    new Node:json = JSON_Object();
   
    JSON_SetInt(json, "o", 1); 
    JSON_SetInt(json, "g", 0); 
    JSON_SetInt(json, "s", render_type); 
    JSON_SetInt(json, "r", model_id);
    JSON_SetFloat(json, "q1", rot_x);    
    JSON_SetFloat(json, "q2", rot_y); 
    JSON_SetFloat(json, "q3", rot_z); 
    JSON_SetFloat(json, "z", zoom);   
    JSON_SetString(json, "m", message, strlen(message));
    JSON_SetString(json, "h", header, strlen(header));
    JSON_SetString(json, "n", "");  
    
    SendPacketToClient(playerid, 31, json);
    JSON_Cleanup(json);
    return 1;
}


