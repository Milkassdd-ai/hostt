stock SetVehicleCarMod(vehicleid, operation, param, setvalue=0)
{
	if(setvalue)
    {
        vInfo[vehicleid][vCarMod] = param;
        vInfo[vehicleid][vCarModParam] = operation;
    }
    foreach(new playerid: Player)
        SendCarMod(playerid, operation, vehicleid, param);
}

stock SendCarMod(playerid, operation, vehicleid, param) {

    new BitStream:bs = BS_New();
    BS_WriteValue(bs,
        PR_UINT8, 15,
        PR_UINT8, operation,
        PR_UINT16, vehicleid,
        PR_UINT16, param
    );
    PR_SendRPC(bs, playerid, 168, PR_HIGH_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
}
CMD:carmod(playerid, params[])
{
    new operation, vehicleid, param, setvalue;
    if (sscanf(params, "iiii", operation, vehicleid, param, setvalue))
        return SendClientMessage(playerid, -1, "Использование: /carmod [op=0-3] [vehid] [param] [setvalue]");

    SetVehicleCarMod(vehicleid, operation, param, setvalue);
    return 1;
}

CMD:af(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 1)
        return SendClientMessage(playerid, 0xFFFFFFFF, "{FF0000}| {FFFFFF}Доступно только {FF5252}администрации сервера{FFFFFF}.");

    names[playerid] = params[0];

    new string[1222];
    string[0] = '\0';

    strcat(string, "{FF5252}номер\t{FF5252}описание\t{FF5252}действие\n");

    strcat(string, "{FF5252}#1\tАктивные формы\tнажмите для взаимодействия\n");
    strcat(string, "{FF5252}#2\tПодать форму\tнажмите для взаимодействия\n");

    new sile_title[128];
    format(sile_title, sizeof sile_title, "{FF5252}%s{ffffff} -> Формы администрации", NameServer[SILE_NAME]);

    SPD(playerid, DIALOG_AF, DIALOG_STYLE_TABLIST_HEADERS, sile_title, string, "Далее", "Выйти");
    return 1;
}
