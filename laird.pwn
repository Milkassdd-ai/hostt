CMD:givevb(playerid, params[])
{
 if(GetPlayerAdminEx(playerid) < 11) return 1;

    if(!strlen(params)) return SendClientMessage(playerid, 0xffffffff, "{FFFFFF}Используйте: /givevb [id игрока]");

    extract params -> new to_player;

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
    return SendClientMessage(playerid, 0xfffffffff, "{FFFFFF}Такого игрока нет");

    if(!IsPlayerInRangeOfPlayer(playerid, to_player, 4.0))
    return SendClientMessage(playerid, 0xfffffffffff, "{FFFFFF}Игрок находится слишком далеко");

    new fmt_msg[75];
    format(fmt_msg, sizeof fmt_msg, "{FFFFFF}Администратор %s[%d] выдал Вам военный билет", GetPlayerNameEx(playerid), playerid);
    SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

	new pVoenik;
    SetPlayerData(playerid, pVoenik, 1);
    UpdatePlayerDatabaseInt(playerid, "voenny_bilet", 1);
}

new pVoenik;
CMD:showvb(playerid, params[])
{
 if(GetPlayerData(playerid, pVoenik) == 0) return SendClientMessage(playerid, 0xFFFFF, "{ff0000}У Вас нету военного билета.");
 if(!strlen(params))
  return SendClientMessage(playerid, 0x999999FF, "{FF5252}| {FFFFFF}Используйте: /showvb {FF5252}[id игрока]");

 extract params -> new to_player;

 if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
  return SendClientMessage(playerid, 2, "{ff0000}| {FFFFFF}Такого игрока нет");

 if(!IsPlayerInRangeOfPlayer(playerid, to_player, 4.0))
  return SendClientMessage(playerid, 0xFFFFFF, "{ff0000}| {FFFFFF}Игрок находится слишком далеко");

 new fmt_str[300];

 format(fmt_str, sizeof fmt_str, "%s показал свой военный билет", to_player == playerid ? "просматривает" : "показал");

 Action(playerid, fmt_str, _, false);

 format(fmt_str, sizeof fmt_str,
 "Имя и Фамилия: {ffe600}%s\n"\
 "Кем был выдан: {ffe600}%s\n"\
 "Служба в армии: %s",
 GetPlayerNameEx(playerid),
 GetPlayerNameEx(playerid),
 GetPlayerData(playerid, pVoenik) >= 1 ? ("{45f235}Служил") : ("{FF0000}Не служил"));
 Dialog(playerid, 3562, DIALOG_STYLE_LIST, "{FF5252}"SERVER_NAME" {FFFFFF}| Военный билет", fmt_str, "Закрыть", "");
 return 1;
}

CMD:base(playerid, params[])
{
   if(!IsPlayerInPoliceTeam(playerid)) return SendClientMessage(playerid, 0x999999FF, "Вы не работник правоохранительных органов");

	new fmt_text[125], list[sizeof(fmt_text)*10];

	for(new i = 0; i < MAX_PLAYERS; i++)
	{
		if(!IsPlayerConnected(i)) continue;
		else if(!IsPlayerLogged(i)) continue;
		else if(!GetPlayerSuspect(i)) continue;

		format(fmt_text, sizeof fmt_text, "{FFFFFF}#%d. {FF5252}%s[%d]{FFFFFF} - уровень розыска: {FF5252}%d\n", i+1, GetPlayerNameEx(i), i, GetPlayerSuspect(i));
		strcat(list, fmt_text);
		SetPlayerListitemValue(playerid, i, i);
	}

	Dialog(playerid, DIALOG_PBASE, DIALOG_STYLE_LIST, "{FF5252}"SERVER_NAME"{ffffff} | Список преступников", list, "Поиск", "Закрыть");

	return 1;
}

CMD:med(playerid, params[])
{
	if(g_player[playerid][P_MEDKA] == 0) return SCM(playerid, COLOR_WHITE, "У вас нет мед-карты!");
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "Введите: /med [id]");
	if(!IsPlayerConnected(params[0])) return SendClientMessage(playerid, 0x999999FF, "Такого игрока нет");
	new Float:px, Float:py, Float:pz;
	GetPlayerPos(params[0], px, py, pz);
	if(!IsPlayerInRangeOfPoint(params[0], 5.0, px, py, pz)) return SendClientMessage(playerid, 0x999999FF, "Игрок находится слишком далеко!");
	new string[128];
	format(string, sizeof(string), "Никнейм игрока:{FF5252} %s\n {ffffff}Состояние игрока:{FF5252}В норме\n {ffffff}Кем выдано: {FF5252}Городская больница\n {ffffff}Дата выдачи: {FF5252} август", GetPlayerNameEx(playerid));
	SPD(params[0], 99999, DIALOG_STYLE_MSGBOX, "{FF5252}"SERVER_NAME"{ffffff} | Медицинская карта", string, "Закрыть", "");
	return 1;
}

CMD:cheat(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 6) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /cheat [id игрока]");

	extract params -> new to_player;

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
	return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new ban_time = 9999;

    new reason[999];

	new fmt_msg[999];

	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid))
	return SendClientMessage(playerid, 0xCECECEFF, ""SC"Нельзя забанить администратора выше по рангу");
	if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Нельзя забанить самого себя");

	if(AntiSliv(playerid, "/cheat")) return true;

	format(fmt_msg, sizeof fmt_msg, "Администратор %s навсегда забанил игрока %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

	format(fmt_msg, sizeof fmt_msg, "%s. Причина: Постороннее ПО", fmt_msg);

	if(strlen(reason) > 0)
		format(fmt_msg, sizeof fmt_msg, "%s. Причина: %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

    InfoAstats[1] += 1;

	format(fmt_msg, sizeof fmt_msg, "Забанил %s[acc:%d] навсегда. Причина: Постороннее ПО", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

	AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, GetPlayerNameEx(playerid));
	BanEx(to_player);
	return 1;
}

