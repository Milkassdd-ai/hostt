public SV_VOID:OnPlayerActivationKeyPress(SV_UINT:playerid, SV_UINT:keyid)
{
    if (keyid == 0x42 && lstream[playerid]) SvAttachSpeakerToStream(lstream[playerid], playerid);
    if (keyid == 0x5A && gstream) SvAttachSpeakerToStream(gstream, playerid);
}

public SV_VOID:OnPlayerActivationKeyRelease(SV_UINT:playerid, SV_UINT:keyid)
{
    if (keyid == 0x42 && lstream[playerid]) SvDetachSpeakerFromStream(lstream[playerid], playerid);
    if (keyid == 0x5A && gstream) SvDetachSpeakerFromStream(gstream, playerid);
}

stock ApplyOrgVinylToVehicle(vehicleid, org_index, slot) 
{
    new vinyl_name[32] = "";
    switch(slot) 
	{
        case 0: format(vinyl_name, 32, "%s", g_org_car[org_index][O_VINYL1]);
        case 1: format(vinyl_name, 32, "%s", g_org_car[org_index][O_VINYL2]);
        case 2: format(vinyl_name, 32, "%s", g_org_car[org_index][O_VINYL3]);
        case 3: format(vinyl_name, 32, "%s", g_org_car[org_index][O_VINYL4]);
    }
    
    if(strlen(vinyl_name) > 0) 
	{
        for(new i = 0; i < MAX_PLAYERS; i++) 
		{
            if(IsPlayerConnected(i) && IsPlayerLogged(i)) 
			{
                SetVehicleVinylForPlayer(i, vehicleid, vinyl_name);
            }
        }
        format(vInfo[vehicleid][viVinylTexture], 16, vinyl_name);
        vInfo[vehicleid][viVinyl] = 1;
    }
}

forward CrashHP_Update();
public CrashHP_Update()
{
    foreach(new playerid : Player) {
        if(IsPlayerConnected(playerid) && IsPlayerLogged(playerid)) {
            CrashHP_Process(playerid);
        }
    }
}
public CrashHP_Process(playerid)
{
    if(!IsPlayerInAnyVehicle(playerid)) return 1;

    new vehicleid = GetPlayerVehicleID(playerid);
    if(vehicleid == INVALID_VEHICLE_ID || !IsValidVehicleID(vehicleid)) return 1;

    new Float:vx, Float:vy, Float:vz;
    GetVehicleVelocity(vehicleid, vx, vy, vz);
    new Float:speed = floatsqroot(vx*vx + vy*vy + vz*vz);
    new Float:last_speed = floatsqroot(last_vx[playerid]*last_vx[playerid] +
                                        last_vy[playerid]*last_vy[playerid] +
                                        last_vz[playerid]*last_vz[playerid]);

    if (last_speed < 0.01)
    {
        last_vx[playerid] = vx;
        last_vy[playerid] = vy;
        last_vz[playerid] = vz;
        return 1;
    }

    new Float:diff = last_speed - speed;

    if(diff > 0.12)
    {
        new Float:hp = GetVehicleData(vehicleid, V_HEALTH);
        new Float:damage;

        new Float:impact_force = diff * 100.0;

        if(impact_force < 10.0)      damage = 2.0;
        else if(impact_force < 20.0) damage = 5.0;
        else if(impact_force < 35.0) damage = 10.0;
        else if(impact_force < 55.0) damage = 20.0;
        else                          damage = 35.0;

        hp -= damage;

        if(hp < 250.0) hp = 250.0;
        if(hp > 1000.0) hp = 1000.0;

        SetVehicleData(vehicleid, V_HEALTH, hp);
        SetVehicleHealth(vehicleid, hp);

        if(hp <= 280.0 && GetVehicleParam(vehicleid, V_ENGINE) == 1)
        {
            SetVehicleParam(vehicleid, V_ENGINE, 0);
            ShowNotificationSile(playerid, 2, 5, 0, 0, "Двигатель заглох от повреждений!", " ");
        }
    }

    last_vx[playerid] = vx;
    last_vy[playerid] = vy;
    last_vz[playerid] = vz;

    return 1;
}

stock strcpy(dest[], const source[], len = sizeof(dest))
{
    dest[0] = 0;
    strcat(dest, source, len);
}
