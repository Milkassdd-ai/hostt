new RPtest[8][tRPinfo] = {
    {"Что обозначает термин RolePlay ? ","(1) Убийство без причины\n(2) Ролевая Игра\n(3) Использование реальной информации в игровой чат",2},
    {"Что обозначает термин MetaGaming ? ","(1) Убийство с Т/С\n(2) Воображение из себя супер героя\n(3) Убийство своих членов организации\n(4) Использование реальной информации в игровой чат",4},
    {"Что обозначает термин SpawnKill ? ","(1) Убийство на месте появления (Spawn)\n(2) Убийство с Т/С\n(3) Гуд мод - т.е. бессмертие.\n(4) Уголовный Кодекс",1},
    {"Что обозначает термин RepeatKill ? ","(1) Намеренное, повторное возвращение на место смерти.\n(2) NonRP бег с прыжками ( shift+space )\n(3) Академический Кодекс\n(4) Убийство без причины.",1},
    {"Что обозначает термин DeathMatch ? ","(1) Убийство с Транспортного средства\n(2) Убийство своих членов организации\n(3) Убийство без причины",3},
    {"Что обозначает термин DriveBy ? ","(1) Убийство своих членов организации\n(2) Убийство с Транспортного средства\n(3) Убийство без причины",2},
    {"Что обозначает термин PowerGaming ? ","(1) NonRP бег с прыжками ( shift+space )\n(2) Академический Кодекс\n(3) Использование реальной информации и игровой чат\n(4) Изображение из себя супер героя",4},
    {"Чего НЕ стоит делать на посту администратора? ","(1) Отвечать на вопросы\n(2) Проводить МП\n(3) Участвовать в РП процессе\n(4) Помогать игрокам",3}
};

