            UpdateColumnFamilyInt(family_sql, "owner", GetPlayerAccountID(to_player));
            SetFamily(f, family_owner, GetPlayerAccountID(to_player));

            LoadPlayerFamily(playerid);
            LoadPlayerFamily(to_player);

            format(f_string144, sizeof f_string144, "%s передал полномочия лидера семьи %s",
                GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));
