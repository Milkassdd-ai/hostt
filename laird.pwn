stock ExitPlayerClothingShopPanel(playerid)
{
	new in_biz = GetPlayerInBiz(playerid);
	if(in_biz != -1)
	{
		HidePlayerSelectPanel(playerid);

		SetPlayerSkinInit(playerid);
