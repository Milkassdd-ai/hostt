stock SpawnCont(contid)
{
    if(contid < 1 || contid > MAX_CONT) return printf("ERROR: Invalid container ID in SpawnCont: %d", contid);
    new prize_region, prize_id, prize_price;
    new prize_name[64];
    new random_prize_index;

    new random_prize_type = random(2) + 1;
    if (random_prize_type == 1)
    {
        random_prize_index = random(sizeof(cSkin_Info));
        prize_region = cSkin_Info[random_prize_index][PRIZE_REGION];
        prize_id = cSkin_Info[random_prize_index][PRIZE_ID];
        format(prize_name, sizeof(prize_name), "%s", cSkin_Info[random_prize_index][PRIZE_NAME]);
        prize_price = cSkin_Info[random_prize_index][PRIZE_PRICE];
    }
    else
    {
        random_prize_index = random(sizeof(cCar_Info));
        prize_region = cCar_Info[random_prize_index][PRIZE_REGION];
        prize_id = cCar_Info[random_prize_index][PRIZE_ID];
        format(prize_name, sizeof(prize_name), "%s", cCar_Info[random_prize_index][PRIZE_NAME]);
        prize_price = cCar_Info[random_prize_index][PRIZE_PRICE];
    }

    cInfo[contid][ContRegion] = prize_region;
    cInfo[contid][ItemType] = random_prize_type;
    cInfo[contid][Item] = prize_id;
    cInfo[contid][ItemPrice] = prize_price;

    new initial_price = 0;
    if (cInfo[contid][ItemType] == 1)
    {
        initial_price = g_RegionData[cInfo[contid][ContRegion]][ClothesPrice];
    }
    else
    {
        initial_price = g_RegionData[cInfo[contid][ContRegion]][VehiclePrice];
    }

    cInfo[contid][ContPrice] = initial_price;
    cInfo[contid][BetPrice] = initial_price;

    new Float:x, Float:y, Float:z, Float:rot;
    new Float:door1X, Float:door1Y, Float:door1Z, Float:door1A;
    new Float:door2X, Float:door2Y, Float:door2Z, Float:door2A;

    x = cContsPos[contid-1][0];
    y = cContsPos[contid-1][1];
    z = cContsPos[contid-1][2];
    rot = cContsPos[contid-1][3];

    door1X = cContsPos[contid-1][4];
    door1Y = cContsPos[contid-1][5];
    door1Z = cContsPos[contid-1][6];
    door1A = cContsPos[contid-1][7];

    door2X = cContsPos[contid-1][8];
    door2Y = cContsPos[contid-1][9];
    door2Z = cContsPos[contid-1][10];
    door2A = cContsPos[contid-1][11];

    new object_model = g_RegionData[cInfo[contid][ContRegion]][ContModelId];
    new vorota_model = g_RegionData[cInfo[contid][ContRegion]][VorotaModelId];

    cInfo[contid][ContObjectId] = CreateObject(object_model, x, y, z, 0.0, 0.0, rot);
    cInfo[contid][ContObjectDoorLId] = CreateObject(vorota_model, door1X, door1Y, door1Z, 0.0, 0.0, door1A);
    cInfo[contid][ContObjectDoorRId] = CreateObject(vorota_model, door2X, door2Y, door2Z, 0.0, 0.0, door2A);

    new moneystr[15];
    ConvertMoney(cInfo[contid][ContPrice], moneystr);

    TextDrawSetString(cont_name[contid], prize_name);

    cInfo[contid][Saled] = true;
    cInfo[contid][BetedId] = INVALID_PLAYER_ID;

    new strwerton[256];
    format(strwerton, sizeof strwerton, "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n{993333}Статус: {FFFFFF}торги за контейнер открыты\n{993333}Начальная ставка: {FFFFFF}%s рублей", contid, g_RegionData[cInfo[contid][ContRegion]][RegionName], (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"), moneystr);

    if (ContsText[contid] == Dynamic3DTextLabel:INVALID_3DTEXT_ID)
    {
        ContsText[contid] = CreateDynamic3DTextLabel(strwerton, -1, x, y, z+1.0, 10.0, INVALID_PLAYER_ID, INVALID_VEHICLE_ID, false, contid);
    }
    else
    {
        UpdateDynamic3DTextLabelText(ContsText[contid], CLR_RED, strwerton);
    }

	if(ContArea[contid] != 0)
	{
		DestroyDynamicArea(ContArea[contid]);
	}
	ContArea[contid] = CreateDynamicSphere(ContBuyTextPos[contid-1][0], ContBuyTextPos[contid-1][1], ContBuyTextPos[contid-1][2], 3.5);

    printf("Создан контейнер %d ||| тип %d ||| регион %d", contid, cInfo[contid][ItemType], cInfo[contid][ContRegion]);

    return 1;
}

public TimerSecondUpdateCont(contid, moneystart[])
{
    if(cInfo[contid][SaleTime] > 0)
    {
        cInfo[contid][SaleTime]--;

        cInfo[contid][Saled] = true;

        new moneystr[15], betstr[15];
        ConvertMoney(cInfo[contid][ContPrice], moneystr);
        ConvertMoney(cInfo[contid][BetPrice], betstr);

    new strwerton[650];
    if (cInfo[contid][BetedId] != INVALID_PLAYER_ID)
    {
        format(strwerton, sizeof strwerton,
            "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n\
{993333}Статус: {FFFFFF}идут активные торги\n{993333}Последняя ставка: {FFFFFF}%s рублей\n\
{993333}Начальная ставка: {FFFFFF}%s рублей\n{993333}Ставка сделана от: {FFFFFF}%s\n\
{993333}До конца торгов осталось: {FFFFFF}%d секунд",
            contid,
            g_RegionData[cInfo[contid][ContRegion]][RegionName],
            (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"),
            betstr, moneystr, cInfo[contid][BetedName], cInfo[contid][SaleTime]);
    }
    else
    {
        format(strwerton, sizeof strwerton,
            "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n\
{993333}Статус: {FFFFFF}торги за контейнер открыты\n{993333}Начальная ставка: {FFFFFF}%s рублей",
            contid,
            g_RegionData[cInfo[contid][ContRegion]][RegionName],
            (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"),
            moneystr);
    }

        UpdateDynamic3DTextLabelText(ContsText[contid], CLR_RED, strwerton);
    }
    else
    {
        KillTimer(ContsTimer[contid]);
        ContsTimer[contid] = 0;
        cInfo[contid][Saled] = false;

        if (cInfo[contid][BetedId] != INVALID_PLAYER_ID)
        {
            new winnerid = cInfo[contid][BetedId];
            new winner_name[MAX_PLAYER_NAME];
            GetPlayerName(winnerid, winner_name, sizeof(winner_name));

            new Float:door1X = cContsPos[contid-1][4];
            new Float:door1Y = cContsPos[contid-1][5];
            new Float:door1Z = cContsPos[contid-1][6];
            new Float:door1A = cContsPos[contid-1][7];

            new Float:door2X = cContsPos[contid-1][8];
            new Float:door2Y = cContsPos[contid-1][9];
            new Float:door2Z = cContsPos[contid-1][10];
            new Float:door2A = cContsPos[contid-1][11];

            new money_str[64];
			ConvertMoney(cInfo[contid][BetPrice], money_str);

			GivePlayerMoneyEx(winnerid, -cInfo[contid][BetPrice]);

            if(cInfo[contid][ItemType] == 2)
            {
                new colors[] = {1, 10, 22, 53, 50};
                cInfo[contid][ContVehicleColor] = colors[random(sizeof(colors))];
                TextDrawSetPreviewVehCol(cont_model[contid], cInfo[contid][ContVehicleColor], 1);
                switch(contid)
                {
				case 1: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[0][0], cContsPos[0][1], cContsPos[0][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 2: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[1][0], cContsPos[1][1], cContsPos[1][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 3: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[2][0], cContsPos[2][1], cContsPos[2][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 4: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[3][0], cContsPos[3][1], cContsPos[3][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 5: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[4][0], cContsPos[4][1], cContsPos[4][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 6: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[5][0], cContsPos[5][1], cContsPos[5][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 7: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[6][0], cContsPos[6][1], cContsPos[6][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 8: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[7][0], cContsPos[7][1], cContsPos[7][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 9: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[8][0], cContsPos[8][1], cContsPos[8][2], 90.0, cInfo[contid][ContVehicleColor], 1, 0);
case 10: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[9][0], cContsPos[9][1], cContsPos[9][2], 270.0, cInfo[contid][ContVehicleColor], 1, 0);
case 11: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[10][0], cContsPos[10][1], cContsPos[10][2], 270.0, cInfo[contid][ContVehicleColor], 1, 0);
case 12: cInfo[contid][ContVehicleId] = CreateVehicle(cInfo[contid][Item], cContsPos[11][0], cContsPos[11][1], cContsPos[11][2], 270.0, cInfo[contid][ContVehicleColor], 1, 0);
                }
                SetVehicleParamsEx(cInfo[contid][ContVehicleId], false, false, false, true, false, false, false);
                ChangeVehicleColor(cInfo[contid][ContVehicleId], cInfo[contid][ContVehicleColor], 0);
            }
            else
            {
                new Float:contX = cContsPos[contid-1][0];
                new Float:contY = cContsPos[contid-1][1];
                new Float:contZ = cContsPos[contid-1][2];
                new Float:contRot = cContsPos[contid-1][3];
                cInfo[contid][ContObjectOdejdaId] = CreateObject(959, contX, contY, contZ, 0.0, 0.0, contRot);
            }

            new str_win[270];
            new balansestr[15];
            ConvertMoney(cInfo[contid][BetPrice], balansestr);
            format(str_win, sizeof(str_win), " {ffffff}Вы успешно выиграли контейнер{FF5252} #%d{ffffff}! С вашего счета списано {FF5252}%s {ffffff}рублей.", contid, balansestr);
            SendClientMessage(winnerid, CLR_YELLOW, str_win);

            new moneystr[15];
            ConvertMoney(cInfo[contid][BetPrice], moneystr);
            new strwerton[300];
            format(strwerton, sizeof(strwerton), "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n{993333}Статус: {FFFFFF}торги окончены\n{993333}Последняя попедная ставка: {FFFFFF}%s рублей\n{993333}Победитель торгов: {FFFFFF}%s\n{993333}Введите: {FFFFFF}/cont", contid, g_RegionData[cInfo[contid][ContRegion]][RegionName], (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"), moneystr, winner_name);
            UpdateDynamic3DTextLabelText(ContsText[contid], CLR_GREEN, strwerton);

            MoveObject(cInfo[contid][ContObjectDoorLId], door1X, door1Y, door1Z, 8.5, 0, 0, door1A + 128.0);
            MoveObject(cInfo[contid][ContObjectDoorRId], door2X, door2Y, door2Z, 8.5, 0, 0, door2A - 128.0);
            ContsTimer[contid] = SetTimerEx("AutoDeleteOpenedCont", 60000, false, "i", contid);
        }
        else
        {
            new moneystr[15];
            ConvertMoney(cInfo[contid][ContPrice], moneystr);
            new strwerton[256];
            format(strwerton, sizeof strwerton, "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n{993333}Статус: {FFFFFF}торги не состоялись\n{993333}Начальная ставка: {FFFFFF}%s рублей", contid, g_RegionData[cInfo[contid][ContRegion]][RegionName], (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"), moneystr);
            UpdateDynamic3DTextLabelText(ContsText[contid], CLR_YELLOW, strwerton);

            DestroyObject(cInfo[contid][ContObjectId]);
            DestroyObject(cInfo[contid][ContObjectDoorLId]);
            DestroyObject(cInfo[contid][ContObjectDoorRId]);
            DestroyObject(cInfo[contid][ContObjectOdejdaId]);
            DestroyVehicle(cInfo[contid][ContVehicleId]);

            SpawnCont(contid);
        }
    }
    return 1;
}

stock ResetContInfo(contid)
{
    DestroyObject(cInfo[contid][ContObjectId]);
    DestroyObject(cInfo[contid][ContObjectDoorLId]);
    DestroyObject(cInfo[contid][ContObjectDoorRId]);
    DestroyObject(cInfo[contid][ContObjectOdejdaId]);
    DestroyObject(cInfo[contid][ContObjectDoorLId]);
    DestroyObject(cInfo[contid][ContObjectDoorRId]);
    DestroyObject(cInfo[contid][ContObjectOdejdaId]);
    DestroyVehicle(cInfo[contid][ContVehicleId]);
    KillTimer(ContsTimer[contid]);
    ContsTimer[contid] = 0;
    UpdateDynamic3DTextLabelText(ContsText[contid], CLR_RED, "");

    for(new i = 0; i < sizeof(cInfo[]); i++)
    {
        cInfo[contid][i] = 0;
    }
    cInfo[contid][BetedId] = INVALID_PLAYER_ID;
    cInfo[contid][Saled] = false;
    return 1;
}

public AutoDeleteOpenedCont(contid)
{
    if(contid < 1 || contid > MAX_CONT) return 1;

    ContsTimer[contid] = 0;

    if(cInfo[contid][Saled] == false && cInfo[contid][BetedId] != INVALID_PLAYER_ID)
    {
        for(new player = 0; player < MAX_PLAYERS; player++)
        {
            if(!IsPlayerConnected(player)) continue;

            if(pInfo[player][BuyUseCont] == contid || pInfo[player][BetUseCont] == contid)
            {
                pInfo[player][BuyUseCont] = 0;
                pInfo[player][BetUseCont] = 0;

                TogglePlayerHudElement(player, HUD_ELEMENT_CHAT, HUD_ELEMENT_SHOW);
                TextDrawHideForPlayer(player, cont_fon);
                TextDrawHideForPlayer(player, cont_take);
                TextDrawHideForPlayer(player, cont_sell);
                TextDrawHideForPlayer(player, cont_close);
                TextDrawHideForPlayer(player, cont_name[contid]);
                TextDrawHideForPlayer(player, cont_price[contid]);
                TextDrawHideForPlayer(player, cont_model[contid]);
                CancelSelectTextDraw(player);
            }
        }

        ResetContInfo(contid);
        SetTimerEx("SpawnNewCont", 5000, false, "i", contid);
    }
    return 1;
}
public CorrectTimerMinute()
{
    new hour, minute, second;
    gettime(hour, minute, second);
    if(hour >= 8 && hour < 23 && minute == 20)
    {
        SendClientMessageToAll(0xFF5533FF, "{FF5252}[Контейнера] {ffffff}Через {FF5252}10{ffffff} минут начнутся торги за контейнеры!");
        SendClientMessageToAll(0xFF5533FF, "{FF5252}[Контейнера] {ffffff}Местоположение: {FF5252}/gps - Развлечения > Битва за контейнеры");
        return 1;
    }
    else if(hour >= 8 && hour < 23 && minute == 30)
    {
        for(new cont = 1; cont <= MAX_CONT; cont++)
        {
            if(cInfo[cont][Saled] == false && cInfo[cont][BetedId] == INVALID_PLAYER_ID)
            {
                SpawnCont(cont);
            }
        }
    }
    else if(hour >= 8 && hour < 23 && minute == 40)
    {
        SendClientMessageToAll(0xFF5533FF, "{FF5252}[Контейнера] {ffffff}Торги за контейнеры закончились");
        StopCont();
    }
    return 1;
}

CMD:cont(playerid)
{
    new bool:sell_limit;
    for(new cont=1; cont < MAX_CONT+1; cont++)
    {
        if(sell_limit == true) continue;
        if(IsPlayerInRangeOfPoint(playerid, 3.0, ContBuyTextPos[cont-1][0], ContBuyTextPos[cont-1][1], ContBuyTextPos[cont-1][2]))
        {
            sell_limit = true;

            if(cInfo[cont][Saled] == true)
            {
                if(cInfo[cont][BetedId] == playerid) return SendClientMessage(playerid, CLR_RED, "| {ffffff}Ставка на контейнер уже ваша, вы не можете перебить свою ставку");

                pInfo[playerid][BetUseCont] = cont;

                new strwerton[140], betstr[15];
                ConvertMoney(cInfo[cont][BetPrice], betstr);
                format(strwerton, sizeof strwerton, "Последняя сделанная ставка: %s рублей\n\nДля того, чтобы сделать свою ставку Вам необходимо\nбудет ввести ее в диалоговом поле ниже:", betstr);
                SPD(playerid, DIALOG_CONT_BET, DIALOG_STYLE_INPUT, "{FF6347}"SERVER_NAME" {ffffff}| Битва за контейнер", strwerton, "Готово", "Отмена");
            }

            else
            {
                if(cInfo[cont][BetedId] == playerid)
                {
                    pInfo[playerid][BuyUseCont] = cont;

                    new prize_name[64];
                    new prize_price_string[32];
                    new prize_modelid = cInfo[cont][Item];

                    if (cInfo[cont][ItemType] == 1)
                    {
                        for(new i = 0; i < sizeof(cSkin_Info); i++)
                        {
                            if (cSkin_Info[i][PRIZE_ID] == prize_modelid)
                            {
                                format(prize_name, sizeof(prize_name), "%s", cSkin_Info[i][PRIZE_NAME]);
                                break;
                            }
                        }
                        TextDrawSetPreviewModel(cont_model[cont], prize_modelid);
                    }
                    else if (cInfo[cont][ItemType] == 2)
                    {
                        for(new i = 0; i < sizeof(cCar_Info); i++)
                        {
                            if (cCar_Info[i][PRIZE_ID] == prize_modelid)
                            {
                                format(prize_name, sizeof(prize_name), "%s", cCar_Info[i][PRIZE_NAME]);
                                break;
                            }
                        }
                        TextDrawSetPreviewModel(cont_model[cont], prize_modelid, cInfo[cont][ContVehicleColor], 1);
                    }

                    ConvertMoney(cInfo[cont][ItemPrice], prize_price_string);
                    format(prize_price_string, sizeof(prize_price_string), "%s РУБ", prize_price_string);

                    TextDrawSetString(cont_name[cont], prize_name);
                    TextDrawSetString(cont_price[cont], prize_price_string);

                    TogglePlayerHudElement(playerid, HUD_ELEMENT_CHAT, HUD_ELEMENT_HIDE);
                    TextDrawShowForPlayer(playerid, cont_fon);
                    TextDrawShowForPlayer(playerid, cont_take);
                    TextDrawShowForPlayer(playerid, cont_sell);
                    TextDrawShowForPlayer(playerid, cont_close);
                    TextDrawShowForPlayer(playerid, cont_name[cont]);
                    TextDrawShowForPlayer(playerid, cont_price[cont]);
                    TextDrawShowForPlayer(playerid, cont_model[cont]);

                    for(new a;a < 12;a++)  SendClientMessage(playerid, 0xFFFFFFFF, "");

                    SelectTextDraw(playerid, CLR_WHITE);
                }
            }
        }
    }
    return 1;
}

stock StartCont()
{
    print("=== Доставка контейнеров в порт | Lonexs Test ===");
    StopCont();
    for(new cont=1; cont <= MAX_CONT; cont++)
    {
        SpawnCont(cont);
    }
    contstartact = 1;
}

stock StopCont()
{
    for(new cont=1; cont <= MAX_CONT; cont++)
    {
        DestroyObject(cInfo[cont][ContObjectId]);
        DestroyObject(cInfo[cont][ContObjectDoorLId]);
        DestroyObject(cInfo[cont][ContObjectDoorRId]);
        DestroyObject(cInfo[cont][ContObjectOdejdaId]);
        DestroyVehicle(cInfo[cont][ContVehicleId]);
        KillTimer(ContsTimer[cont]);
        ResetContInfo(cont);

        TextDrawHideForAll(cont_name[cont]);
        TextDrawHideForAll(cont_price[cont]);
        TextDrawHideForAll(cont_model[cont]);
    }
    TextDrawHideForAll(cont_fon);
    TextDrawHideForAll(cont_take);
    TextDrawHideForAll(cont_sell);
    TextDrawHideForAll(cont_close);
    contstartact = 0;
}

stock StartContBidding(contid)
{
    cInfo[contid][SaleTime] = 30;
    KillTimer(ContsTimer[contid]);

    new moneystr[32], betstr[32];
    ConvertMoney(cInfo[contid][ContPrice], moneystr);
    ConvertMoney(cInfo[contid][BetPrice], betstr);

    new strwerton[650];
    if (cInfo[contid][BetedId] != INVALID_PLAYER_ID)
    {
        format(strwerton, sizeof strwerton,
            "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n\
{993333}Статус: {FFFFFF}идут активные торги\n{993333}Последняя ставка: {FFFFFF}%s рублей\n\
{993333}Начальная ставка: {FFFFFF}%s рублей\n{993333}Ставка сделана от: {FFFFFF}%s\n\
{993333}До конца торгов осталось: {FFFFFF}%d секунд",
            contid,
            g_RegionData[cInfo[contid][ContRegion]][RegionName],
            (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"),
            betstr, moneystr, cInfo[contid][BetedName], cInfo[contid][SaleTime]);
    }
    else
    {
        format(strwerton, sizeof strwerton,
            "{993333}Контейнер #%d\n\nСтрана отправитель: {FFFFFF}%s\n{993333}Содержимое контейнера: {FFFFFF}%s\n\
{993333}Статус: {FFFFFF}торги за контейнер открыты\n{993333}Начальная ставка: {FFFFFF}%s рублей",
            contid,
            g_RegionData[cInfo[contid][ContRegion]][RegionName],
            (cInfo[contid][ItemType] == 1) ? ("Одежда") : ("Транспортное средство"),
            moneystr);
    }

    UpdateDynamic3DTextLabelText(ContsText[contid], CLR_RED, strwerton);

    ContsTimer[contid] = SetTimerEx("TimerSecondUpdateCont", 1000, true, "ds", contid, moneystr);
    return 1;
}
public SpawnNewCont(contid)
{
    SpawnCont(contid);
}

CMD:startcont(playerid)
{
    if(GetPlayerAdminEx(playerid) < 13) return 1;
    StartCont();

    ShowNotificationSile(playerid, 4, 6, OFFER_ENGINE, 0, "Успешно 3апущены kонтейнера", ">>");
    return 1;
}

CMD:stopcont(playerid)
{
    if(GetPlayerAdminEx(playerid) < 13) return 1;
    StopCont();

    ShowNotificationSile(playerid, 4, 6, OFFER_ENGINE, 0, "Успешно oстановлены kонтейнера", "");
    return 1;
}
stock IsPlayerNearContainer(playerid)
{
    for(new cont = 1; cont <= MAX_CONT; cont++)
    {
   	if(cInfo[cont][Saled] == true)
	   {
       	if(IsPlayerInDynamicArea(playerid, ContArea[cont]))
           	return 1;
   	}
 	}
    return 0;
}

stock ShowSpectateGUI(playerid, to_player)
{
	if(GetPlayerAdminEx(playerid) < 1) return ShowNotificationSile(playerid, 2, 7, -1, -1, "У Вас нет доступа к использованию этой команды", "");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationSile(playerid, 2, 7, -1, -1, "Такого игрока нет", "");

	if(GetPlayerSecretEx(to_player) >= 1)
		return ShowNotificationSile(playerid, 2, 7, -1, -1, "У игрока есть привелегия скрытность", "");

	if(playerid == to_player)
		return SendClientMessage(playerid, -1, "Вы не можете следить за самим собой.");

    new target_name[MAX_PLAYER_NAME];
    new Float:hp, Float:armor, Float:speed, ping, money, vehicleid, level;

    GetPlayerName(to_player, target_name, sizeof(target_name));
    GetPlayerHealth(to_player, hp);
    GetPlayerArmour(to_player, armor);
    ping = GetPlayerPing(to_player);
    money = GetPlayerMoney(to_player);
    vehicleid = GetPlayerVehicleID(to_player);
    speed = GetPlayerSpeed(to_player);
    level = GetPlayerLevel(to_player);

    new Node:info1 = JSON_Object(
        "p", JSON_Int(5),
        "n", JSON_String("Пинг"),
        "v", JSON_Int(ping)
    );
    new Node:info2 = JSON_Object(
        "p", JSON_Int(4),
        "n", JSON_String("Скорость"),
        "v", JSON_Int(floatround(speed))
    );
    new Node:info3 = JSON_Object(
        "p", JSON_Int(2),
        "n", JSON_String("Здоровье"),
        "v", JSON_Int(floatround(hp))
    );
    new Node:info4 = JSON_Object(
        "p", JSON_Int(3),
        "n", JSON_String("Броня"),
        "v", JSON_Int(floatround(armor))
    );
    new Node:info5 = JSON_Object(
        "p", JSON_Int(6),
        "n", JSON_String("Деньги"),
        "v", JSON_Int(money)
    );
    new Node:info6 = JSON_Object(
        "p", JSON_Int(1),
        "n", JSON_String("Уровень"),
        "v", JSON_Int(level)
    );
    new Node:info7 = JSON_Object(
        "p", JSON_Int(7),
        "n", JSON_String("Транспорт"),
        "v", JSON_Int(vehicleid)
    );

    new Node:pi_array = JSON_Array(info1, info2, info3, info4, info5, info6, info7);

    new Node:json = JSON_Object();

    JSON_SetInt(json, "t", 1);
    JSON_SetInt(json, "id", to_player);
    JSON_SetString(json, "pn", target_name);

    JSON_SetArray(json, "pi", pi_array);

    if(GetPlayerSpectateData(playerid, S_PLAYER) == -1)
	{
		new Float: x,
			Float: y,
			Float: z,
			Float: a,
			skin = GetPlayerSkin(playerid);

		GetPlayerPos(playerid, x, y, z);
		GetPlayerFacingAngle(playerid, a);

		SetPlayerSpectateData(playerid, S_START_POS_X, x);
		SetPlayerSpectateData(playerid, S_START_POS_Y, y);
		SetPlayerSpectateData(playerid, S_START_POS_Z, z);
		SetPlayerSpectateData(playerid, S_START_ANGLE, a);

		SetPlayerSpectateData(playerid, S_START_INTERIOR, GetPlayerInterior(playerid));
		SetPlayerSpectateData(playerid, S_START_VIRTUAL_WORLD, GetPlayerVirtualWorld(playerid));

		SetSpawnInfo(playerid, 0, skin, x, y, z, a, 0, 0, 0, 0, 0, 0);
	}

	StartSpectate(playerid, to_player);

    ShowPlayerGUI(playerid, 66, json);

    JSON_Cleanup(json);

    return 1;
}

stock UpdateSpectateGUI(playerid, to_player)
{

    new target_name[MAX_PLAYER_NAME];
    new Float:hp, Float:armor, Float:speed, ping, money, vehicleid, level;

    GetPlayerName(to_player, target_name, sizeof(target_name));
    GetPlayerHealth(to_player, hp);
    GetPlayerArmour(to_player, armor);
    ping = GetPlayerPing(to_player);
    money = GetPlayerMoney(to_player);
    vehicleid = GetPlayerVehicleID(to_player);
    speed = GetPlayerSpeed(to_player);
    level = GetPlayerLevel(to_player);

    new Node:info1 = JSON_Object(
        "p", JSON_Int(5),
        "n", JSON_String("Пинг"),
        "v", JSON_Int(ping)
    );
    new Node:info2 = JSON_Object(
        "p", JSON_Int(4),
        "n", JSON_String("Скорость"),
        "v", JSON_Int(floatround(speed))
    );
    new Node:info3 = JSON_Object(
        "p", JSON_Int(2),
        "n", JSON_String("Здоровье"),
        "v", JSON_Int(floatround(hp))
    );
    new Node:info4 = JSON_Object(
        "p", JSON_Int(3),
        "n", JSON_String("Броня"),
        "v", JSON_Int(floatround(armor))
    );
    new Node:info5 = JSON_Object(
        "p", JSON_Int(6),
        "n", JSON_String("Деньги"),
        "v", JSON_Int(money)
    );
    new Node:info6 = JSON_Object(
        "p", JSON_Int(1),
        "n", JSON_String("Уровень"),
        "v", JSON_Int(level)
    );
    new Node:info7 = JSON_Object(
        "p", JSON_Int(7),
        "n", JSON_String("Транспорт"),
        "v", JSON_Int(vehicleid)
    );

    new Node:pi_array = JSON_Array(info1, info2, info3, info4, info5, info6, info7);

    new Node:json = JSON_Object();

    JSON_SetInt(json, "t", 1);
    JSON_SetInt(json, "id", to_player);
    JSON_SetString(json, "pn", target_name);

    JSON_SetArray(json, "pi", pi_array);

    SendPacketToClient(playerid, 66, json);

    JSON_Cleanup(json);

    return 1;
}

CMD:sp(playerid, params[])
{
if(sscanf(params, "i", params[0])) return ShowNotificationSile(playerid, 2, 7, -1, -1, "Введите /sp [айди игрока]", "");
ShowSpectateGUI(playerid, params[0]);
}
stock FindPreviousPlayer(currentSpectatePlayer)
{
    for(new i = currentSpectatePlayer - 1; i >= 0; i--)
    {
        if(i == currentSpectatePlayer) continue;
        if(!IsPlayerConnected(i) || !IsPlayerLogged(i) || GetPlayerSecretEx(i) >= 1)
            continue;

        return i;
    }
    for(new i = MAX_PLAYERS - 1; i > currentSpectatePlayer; i--)
    {
        if(i == currentSpectatePlayer) continue;
        if(!IsPlayerConnected(i) || !IsPlayerLogged(i) || GetPlayerSecretEx(i) >= 1)
            continue;

        return i;
    }

    return -1;
}

stock FindNextPlayer(currentSpectatePlayer)
{
    for(new i = currentSpectatePlayer + 1; i < MAX_PLAYERS; i++)
    {
        if(i == currentSpectatePlayer) continue;
        if(!IsPlayerConnected(i) || !IsPlayerLogged(i) || GetPlayerSecretEx(i) >= 1)
            continue;

        return i;
    }

    for(new i = 0; i < currentSpectatePlayer; i++)
    {
        if(i == currentSpectatePlayer) continue;
        if(!IsPlayerConnected(i) || !IsPlayerLogged(i) || GetPlayerSecretEx(i) >= 1)
            continue;

        return i;
    }

    return -1;
}

CMD:setvin(playerid, params[])
