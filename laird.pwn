				new car_market_id = biz_id - 34;
				if(GetBusinessData(biz_id, B_TYPE) != BUSINESS_TYPE_CAR_MARKET) return 1;

				BuyOwnableCar(playerid, car_market_id, buy_car_select_car[playerid]);

				return 1;
