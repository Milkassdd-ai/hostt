							SendClientMessage(playerid, 0xFF5252FF, ""SC"Поздравляем! Вы устроились на работу автомеханика");
							SendClientMessage(playerid, 0xFFFFFFFF, ""SC"Чтобы начать работу найдите служебный транспорт в Вашем городе. Используйте {FF9900}/gps {FFFFFF}при необходимости");
							SendClientMessage(playerid, 0xFFFFFFFF, ""SC"Команды: /getfuel - закупить топливо; /fill - заправить транспорт; /repair - починить транспорт");
						}
						case JOB_INK:
						{
							if(GetPlayerLevel(playerid) < 10)
								return SendClientMessage(playerid, 0xCECECEFF, ""USC"Чтобы устроиться на работу инкассатора необходим 10 уровень");

							SendClientMessage(playerid, 0xFF5252FF, ""SC"Поздравляем! Вы устроились на работу инкассатора");
							SendClientMessage(playerid, 0xFFFFFFFF, ""SC"Используйте {FF5252}/gps - По работе {FFFFFF}чтобы начать работу");
							SendClientMessage(playerid, 0xFFFFFFFF, ""SC"Дополнительные инструкции и указания Вы будете получать в процессе работы");
						}

						default:
							return 1;
					}
					new query[64];

					format(query, sizeof query, "UPDATE accounts SET job=%d WHERE id=%d LIMIT 1", listitem + 1, GetPlayerAccountID(playerid));
					mysql_query(mysql, query, false);

					if(!mysql_errno())
					{
						SetPlayerData(playerid, P_JOB, listitem + 1);
					}
					else SendClientMessage(playerid, 0xFF6600FF, "Ошибка сохранения, повторите попытку {FF0000}(equ-code 14)");
				}
