{
    new title[128];
    format(title, sizeof(title), "{FF5252}%s{FFFFFF} | Подготовка к продаже транспорта", NameServer[SILE_NAME]);

    ShowPlayerDialog(playerid, 8968, DIALOG_STYLE_INPUT, title, "Вам необходимо ввести цену, за которую Вы хотите\nпродать свой транспорт в диалоговое поле ниже:", "Готово", "Отмена");
}

CMD:unsellmycar(playerid)
{
    if(player_sell_ownable_car[playerid] == true)
    {
        new title[128];
        format(title, sizeof(title), "{FF5252}%s{FFFFFF} | Снятие с продажи транспорта", NameServer[SILE_NAME]);

        ShowPlayerDialog(playerid, 8977, DIALOG_STYLE_MSGBOX, title, "Вы уверены что хотите снять свой транспорт с продажи", "Да", "Нет");
    }
    else
        SendClientMessage(playerid, 0xCECECEFF, "Вы не выставили свой транспорт на продажу");
}
public tp_buy(playerid)
{
SetPlayerPos(playerid, 447.955505,985.479675,1001.039978);
		SetPlayerFacingAngle(playerid, 272.468505);
		SetCameraBehindPlayer(playerid);
		SetPlayerVirtualWorld(playerid, 101);
          SetPlayerInterior(playerid, 1);
}

CMD:buycar(playerid)
{
if(player_sell_ownable_car[playerid] == true)
                         	{
                         SendClientMessage(playerid, 0xCECECEFF, "Сначала продайте или уберите свой транспорт с продажи");
                         return 1;
                         }
                         else {
new vehicleid = GetNearestVehicleID(playerid, 5.0);

if(vehicleid != -1)
{
	     if(ownable_car_sell_status[vehicleid] == true)
                         	{
	        new model_id = GetVehicleData(vehicleid, V_MODELID);
            new to_player = GetOwnableCarData(vehicleid, OC_LAST_OWNER_GAME_ID);
            new price = GetOwnableCarData(vehicleid, OC_LAST_PRICE);

			if((GetPlayerOwnableCars(playerid) + 1) > GetPlayerCarSlots(playerid))
				return SendClientMessage(playerid, 0xCECECEFF, "У вас нет свободных слотов для транспорта");

			if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
				return SendClientMessage(playerid, 0xCECECEFF, "Вы должны выгрузить свой личный транспорт с сервера {888888}(/car > 7)");

			if(GetPlayerMoneyEx(playerid) < GetOwnableCarData(vehicleid, OC_LAST_PRICE))
				return SendClientMessage(playerid, 0xCECECEFF, "У вас нет денег чтобы купить этот транспорт");

                SendPlayerOffer(playerid, to_player, OFFER_TYPE_SELL_OWNABLE_CAR2, price, vehicleid);
            }
            else  SendClientMessage(playerid, 0xCECECEFF, "Эта машина не продается");
    }
    else SendClientMessage(playerid, 0xCECECEFF, "Вы должны находится рядом с транспортом который хотите купить");
}
}

stock SafeGetPlayerData(playerid, field)
{
    if (field >= sizeof(g_player[]))
    {

        return 0;
    }
    if (playerid < 0 || playerid >= MAX_PLAYERS) return 0;
    return g_player[playerid][field];
}

stock SafeSetPlayerData(playerid, field, value)
{
    if (playerid < 0 || playerid >= MAX_PLAYERS) return;
    g_player[playerid][field] = value;
}
forward UpdateOnlineTimers();
public UpdateOnlineTimers()
{
    foreach (new i : Player)
    {
        if (!IsPlayerConnected(i) || !IsPlayerLogged(i)) continue;

        new before = SafeGetPlayerData(i, P_ONLINE_TODAY);
        SafeSetPlayerData(i, P_ONLINE_TODAY, before + 1);
    }
}

forward AutoRewardTopOnline();
public AutoRewardTopOnline()
{
    new hour, minute, second;
    gettime(hour, minute, second);
    if (hour != 23 || minute != 59) return;

    new top_players[3] = {-1, -1, -1};
    new top_minutes[3] = {0, 0, 0};

    foreach (new i : Player)
    {
        if (!IsPlayerConnected(i) || !IsPlayerLogged(i)) continue;
        new minutes = SafeGetPlayerData(i, P_ONLINE_TODAY);

        if (minutes > top_minutes[0])
        {
            top_minutes[2] = top_minutes[1]; top_players[2] = top_players[1];
            top_minutes[1] = top_minutes[0]; top_players[1] = top_players[0];
            top_minutes[0] = minutes;        top_players[0] = i;
        }
        else if (minutes > top_minutes[1])
        {
            top_minutes[2] = top_minutes[1]; top_players[2] = top_players[1];
            top_minutes[1] = minutes;        top_players[1] = i;
        }
        else if (minutes > top_minutes[2])
        {
            top_minutes[2] = minutes;        top_players[2] = i;
        }
    }

	if (IsPlayerConnected(top_players[0]))
	{
		new p = top_players[0];
		GivePlayerDonateRub(p, 300, "Награда за 1 место по онлайну");
		GivePlayerMoneyEx(p, 50000000, "Награда за 1 место по онлайну");
		SendClientMessage(p, 0x00FF00FF, "[ТОП ОНЛАЙН] Вы заняли 1 место и получили 300 доната + 50.000.000$");
	}

    if (IsPlayerConnected(top_players[1]))
    {
        GivePlayerDonateRub(top_players[1], 200, "Награда за 2 место по онлайну");
        GivePlayerMoneyEx(top_players[1], 35000000, "Награда за 2 место по онлайну");
        SendClientMessage(top_players[1], -1, "[ТОП ОНЛАЙН] Вы заняли 2 место и получили 200 доната + 35.000.000$");
    }

    if (IsPlayerConnected(top_players[2]))
    {
        GivePlayerDonateRub(top_players[2], 150, "Награда за 3 место по онлайну");
        GivePlayerMoneyEx(top_players[2], 20000000, "Награда за 3 место по онлайну");
        SendClientMessage(top_players[2], -1, "[ТОП ОНЛАЙН] Вы заняли 100 доната + 20.000.000$");
    }

    SendClientMessageToAll(-1, "{FF5252}[ТОП ОНЛАЙН]{FFFFFF} Награды за дневной онлайн выданы! Система сброшена.");

    foreach (new i : Player)
    {
        if (!IsPlayerConnected(i) || !IsPlayerLogged(i)) continue;

        SafeSetPlayerData(i, P_ONLINE_TODAY, 0);
        UpdatePlayerDatabaseInt(i, "online_today", 0);
    }
}

CMD:toponline(playerid, params[])
{
    new query[256];
    format(query, sizeof(query), "SELECT `name`, `online_today` FROM `accounts` ORDER BY `online_today` DESC LIMIT 10");

    new Cache:cache = mysql_query(mysql, query);

    if(cache_num_rows() == 0)
    {
        SendClientMessage(playerid, -1, "Нет данных для отображения.");
        cache_delete(cache);
        return 1;
    }

    new str[512], pname[MAX_PLAYER_NAME];
    format(str, sizeof(str), "{00FF00}[ТОП ОНЛАЙН за сутки]\n");
    strcat(str, "{FFFFFF}-----------------------------\n");
    strcat(str, "{FF5252}#\tИгрок\t\tМинуты{FFFFFF}\n");
    strcat(str, "-----------------------------\n");

    for(new i = 0; i < cache_num_rows(); i++)
    {
        cache_get_field_content(i, "name", pname, sizeof(pname));
        new minutes = cache_get_field_content_int(i, "online_today");

        new tab[8] = "\t";
        if(strlen(pname) <= 10) format(tab, sizeof(tab), "\t\t");

        format(str, sizeof(str), "%s{FF5252}%d.{FFFFFF}\t%s%s%d\n", str, i + 1, pname, tab, minutes);
    }

    ShowPlayerDialog(playerid, 1500, DIALOG_STYLE_MSGBOX, "ТОП ОНЛАЙН", str, "Ок", "");
    cache_delete(cache);
    return 1;
}

forward SaveOnlineTimers();
public SaveOnlineTimers()
{
    foreach (new i : Player)
    {
        if (!IsPlayerConnected(i) || !IsPlayerLogged(i)) continue;

        new minutes = SafeGetPlayerData(i, P_ONLINE_TODAY);
        UpdatePlayerDatabaseInt(i, "online_today", minutes);
    }
}

stock GetPlayerDatabaseInt(playerid, const field[])
{
    new query[196], Cache: result, value = 0;

    format(query, sizeof(query), "SELECT `%s` FROM `accounts` WHERE `id` = %d LIMIT 1",
        field, GetPlayerAccountID(playerid));

    result = mysql_query(mysql, query, true);

    if (cache_num_rows())
    {
        value = cache_get_field_content_int(0, field);
    }

    cache_delete(result);
    return value;
}

forward UpdateAdminTime();
public UpdateAdminTime()
{
    new hour, minute, second;
    new year, month, day;
    gettime(hour, minute, second);
    getdate(year, month, day);

    new str[64];
    format(str, sizeof str, "%02d:%02d:%02d-%02d.%02d.%04d",
        hour, minute, second, day, month, year);

    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;

        if (GetPlayerAdminEx(i) >= 1)
        {
            PlayerTextDrawSetString(i, AdminTime[i], str);
            PlayerTextDrawShow(i, AdminTime[i]);
        }
        else
        {
            PlayerTextDrawHide(i, AdminTime[i]);
        }
    }
    return 1;
}
HandleTuningEntrance(playerid)
{
    for(new i = 0; i < 3; i++)
    {
        if(IsPlayerInRangeOfPoint(playerid, 3.0, g_TuningEnter[i][0], g_TuningEnter[i][1], g_TuningEnter[i][2]))
        {
            if(!IsPlayerInAnyVehicle(playerid))
                return SendClientMessage(playerid, -1, "Вы должны быть в автомобиле!");

            new vehicleid = GetPlayerVehicleID(playerid);
            if(vehicleid != GetPlayerOwnableCar(playerid))
                return SendClientMessage(playerid, -1, "Вы должны быть за рулем своего автомобиля!");

            MovePlayersAndVehicle(playerid, vehicleid, 1);
            return 1;
        }
    }
    return 0;
}

HandleTuningExit(playerid)
{
    if(GetPlayerVirtualWorld(playerid) != TUNING_WORLD || GetPlayerInterior(playerid) != TUNING_INTERIOR)
        return 0;

    for(new i = 0; i < 3; i++)
    {
        if(IsPlayerInRangeOfPoint(playerid, 3.0, g_TuningExit[i][0], g_TuningExit[i][1], g_TuningExit[i][2]))
        {
            if(!IsPlayerInAnyVehicle(playerid))
                return SendClientMessage(playerid, -1, "Вы должны быть в автомобиле!");

            new vehicleid = GetPlayerVehicleID(playerid);
            MovePlayersAndVehicle(playerid, vehicleid, 0);
            return 1;
        }
    }
    return 0;
}
MovePlayersAndVehicle(playerid, vehicleid, type)
{
    if(type == 1)
    {
        for(new i = 0; i < MAX_PLAYERS; i++)
        {
            if(IsPlayerConnected(i) && IsPlayerInVehicle(i, vehicleid))
            {
                SetPlayerVirtualWorld(i, TUNING_WORLD);
                SetPlayerInterior(i, TUNING_INTERIOR);
                SetCameraBehindPlayer(i);
            }
        }

        SetVehiclePos(vehicleid, 996.368164, 999.465759, 1001.141540);
        SetVehicleZAngle(vehicleid, 273.919586);
        SetVehicleVirtualWorld(vehicleid, TUNING_WORLD);
        LinkVehicleToInterior(vehicleid, TUNING_INTERIOR);

        SetPlayerCameraPos(playerid, 1001.483154, 1002.271240, 1000.906738);
        SetPlayerCameraLookAt(playerid, 997.090454, 999.934204, 1001.398864);

        HideHud(playerid);
        SetTimerEx("tpplayertex", 700, false, "d", playerid);
    }
    else
    {
        for(new i = 0; i < MAX_PLAYERS; i++)
        {
            if(IsPlayerConnected(i) && IsPlayerInVehicle(i, vehicleid))
            {
                SetPlayerVirtualWorld(i, 0);
                SetPlayerInterior(i, 0);
                SetCameraBehindPlayer(i);
            }
        }

        new random_exit = random(3);
        SetVehiclePos(vehicleid, g_TuningExit[random_exit][0], g_TuningExit[random_exit][1], g_TuningExit[random_exit][2]);
        SetVehicleZAngle(vehicleid, g_TuningExit[random_exit][3]);
        SetVehicleVirtualWorld(vehicleid, 0);
        LinkVehicleToInterior(vehicleid, 0);

        SetCameraBehindPlayer(playerid);
        ShowHud(playerid);
    }
}
stock GetNearestGateByPlayer(playerid)
{
    new Float:targetX, Float:targetY, Float:targetZ;

    if(IsPlayerInAnyVehicle(playerid))
    {
        new vehicleid = GetPlayerVehicleID(playerid);
        GetVehiclePos(vehicleid, targetX, targetY, targetZ);
    }
    else GetPlayerPos(playerid, targetX, targetY, targetZ);

    new Float:minDistance = 5.0;
    new nearestGateID = INVALID_GATE_ID;

    for (new i = 0; i < g_gates_count; i++)
    {
        new Float:gateZoneX = GetGateData(i, GateZone_X);
        new Float:gateZoneY = GetGateData(i, GateZone_Y);
        new Float:gateZoneZ = GetGateData(i, GateZone_Z);

        new Float:distance = floatsqroot(floatpower(targetX - gateZoneX, 2.0) + floatpower(targetY - gateZoneY, 2.0) + floatpower(targetZ - gateZoneZ, 2.0));

        if(distance < minDistance)
        {
            minDistance = distance;
            nearestGateID = i;
        }
    }
    return nearestGateID;
}

CMD:checkgate(playerid, params[])
{
    new nearestGateID = GetNearestGateByPlayer(playerid);

    if(nearestGateID != INVALID_GATE_ID)
    {
        new sqlID = GetGateData(nearestGateID, GateSQL_ID);
        new message[128];

        format(message, sizeof(message), "Вы находитесь рядом с воротами. Серверный ID: %d, SQL ID: %d.", nearestGateID, sqlID);
        SendClientMessage(playerid, 0xFFFFFFFF, message);
    }
    else
    {
        SendClientMessage(playerid, 0xFFFFFFFF, "Рядом с вами нет ворот либо Вы далеко.");
    }
    return 1;
}

public CloseGateTimer(playerid, gateid, Float:gateVor1X, Float:gateVor1Y, Float:gateVor1Z, Float:gateVor1Angel, Float:gateVor2X, Float:gateVor2Y, Float:gateVor2Z, Float:gateVor2Angel)
{
    MoveDynamicObject(GetGateData(gateid, GateObj1_ID), gateVor1X, gateVor1Y, gateVor1Z, 7.0, 0, 0, gateVor1Angel);
    MoveDynamicObject(GetGateData(gateid, GateObj2_ID), gateVor2X, gateVor2Y, gateVor2Z, 7.0, 0, 0, gateVor2Angel);

    DeletePVar(playerid, "GateOpening");

    return 1;
}

CMD:opengate(playerid)
{
    new gateid = GetNearestGateByPlayer(playerid);

    printf("Полученный айди в GetNearestGateByPlayer = %d", gateid);
    printf("Айди ворот при открытии %d", GetGateData(gateid, GateObj1_ID));

    if(gateid != INVALID_GATE_ID)
    {
        new Float:gateVor1X = GetGateData(gateid, Gate1_X);
        new Float:gateVor1Y = GetGateData(gateid, Gate1_Y);
        new Float:gateVor1Z = GetGateData(gateid, Gate1_Z);
        new Float:gateVor1Angel = GetGateData(gateid, Gate1_Angle);

        new Float:gateVor2X = GetGateData(gateid, Gate2_X);
        new Float:gateVor2Y = GetGateData(gateid, Gate2_Y);
        new Float:gateVor2Z = GetGateData(gateid, Gate2_Z);
        new Float:gateVor2Angel = GetGateData(gateid, Gate2_Angle);

        MoveDynamicObject(GetGateData(gateid, GateObj1_ID), gateVor1X, gateVor1Y, gateVor1Z, 7.0, 0, 0, gateVor1Angel - 90);
        MoveDynamicObject(GetGateData(gateid, GateObj2_ID), gateVor2X, gateVor2Y, gateVor2Z, 7.0, 0, 0, gateVor2Angel + 90);

        SetTimerEx("CloseGateTimer", 5000, false, "iiffffffff", playerid, gateid, gateVor1X, gateVor1Y, gateVor1Z, gateVor1Angel, gateVor2X, gateVor2Y, gateVor2Z, gateVor2Angel);
    }
    else print("Ошибка в открытии ворот INVALID_GATE_ID");
}
forward LoadGates();
public LoadGates()
{
    new Cache:cache = mysql_query(mysql, "SELECT * FROM `gates`", true);
    g_gates_count = cache_num_rows(cache);

    new GATES_VOR1, GATES_VOR2;

    if(g_gates_count > 0)
    {
        for (new i = 0; i < g_gates_count; i++)
        {
            SetGateData(i, GateSQL_ID, cache_get_field_content_int(i, "id"));
            SetGateData(i, Gate_type, cache_get_field_content_float(i, "gate_type"));
            SetGateData(i, Gate1_X, cache_get_field_content_float(i, "gate1_x"));
            SetGateData(i, Gate1_Y, cache_get_field_content_float(i, "gate1_y"));
            SetGateData(i, Gate1_Z, cache_get_field_content_float(i, "gate1_z"));
            SetGateData(i, Gate1_Angle, cache_get_field_content_float(i, "gate1_angle"));
            SetGateData(i, Gate2_X, cache_get_field_content_float(i, "gate2_x"));
            SetGateData(i, Gate2_Y, cache_get_field_content_float(i, "gate2_y"));
            SetGateData(i, Gate2_Z, cache_get_field_content_float(i, "gate2_z"));
            SetGateData(i, Gate2_Angle, cache_get_field_content_float(i, "gate2_angle"));
            SetGateData(i, GateZone_X, cache_get_field_content_float(i, "gatezone_x"));
            SetGateData(i, GateZone_Y, cache_get_field_content_float(i, "gatezone_y"));
            SetGateData(i, GateZone_Z, cache_get_field_content_float(i, "gatezone_z"));

            SetGateData(i, GateIsOpened, 0);
            SetGateData(i, GateNearestHouseID, -1);

            if(GetGateData(i, Gate_type) <= 0)
            {
                GATES_VOR1 = CreateDynamicObject(7241, GetGateData(i, Gate1_X), GetGateData(i, Gate1_Y), GetGateData(i, Gate1_Z), 0.0, 0.0, GetGateData(i, Gate1_Angle));
                GATES_VOR2 = CreateDynamicObject(7241, GetGateData(i, Gate2_X), GetGateData(i, Gate2_Y), GetGateData(i, Gate2_Z), 0.0, 0.0, GetGateData(i, Gate2_Angle));
            }
            else
            {
                GATES_VOR1 = CreateDynamicObject(7242, GetGateData(i, Gate1_X), GetGateData(i, Gate1_Y), GetGateData(i, Gate1_Z), 0.0, 0.0, GetGateData(i, Gate1_Angle));
                GATES_VOR2 = INVALID_GATE_ID;
            }

            SetGateData(i, GateObj1_ID, GATES_VOR1);
            SetGateData(i, GateObj2_ID, GATES_VOR2);
            SetGateData(i, GateArea_ID, CreateDynamicSphere(GetGateData(i, GateZone_X), GetGateData(i, GateZone_Y), GetGateData(i, GateZone_Z), 5.0));

            new Float:gateZoneX = GetGateData(i, GateZone_X);
            new Float:gateZoneY = GetGateData(i, GateZone_Y);
            new Float:gateZoneZ = GetGateData(i, GateZone_Z);

            new nearestHouseID_temp = -1;
            new Float:minDistance_temp = 100.0;
            new totalHouses = MAX_HOUSES;

            for (new h = 0; h < totalHouses; h++)
            {
                new Float:houseX = GetHouseData(h, H_POS_X);
                new Float:houseY = GetHouseData(h, H_POS_Y);
                new Float:houseZ = GetHouseData(h, H_POS_Z);

                if(houseX != 0.0 || houseY != 0.0 || houseZ != 0.0)
                {
                    new Float:distance = floatsqroot(floatpower(gateZoneX - houseX, 2.0) + floatpower(gateZoneY - houseY, 2.0) + floatpower(gateZoneZ - houseZ, 2.0));

                    if(distance < minDistance_temp)
                    {
                        minDistance_temp = distance;
                        nearestHouseID_temp = h;
                    }
                }
            }
            SetGateData(i, GateNearestHouseID, nearestHouseID_temp);
        }
    }
    cache_delete(cache);
}
forward CheckAndLoadGates();
public CheckAndLoadGates()
{
    new Cache:cache;
    new query[512];

    mysql_format(mysql, query, sizeof(query), "SELECT 1 FROM `gates` LIMIT 1");
    cache = mysql_query(mysql, query, true);

    if(mysql_errno() != 0)
    {
        printf("[GATES] Таблица 'gates' не найдена. Создаем новую структуру...");
        mysql_format(mysql, query, sizeof(query), "CREATE TABLE `gates` (" \
            "`id` INT(11) NOT NULL AUTO_INCREMENT PRIMARY KEY," \
            "`gate_type` INT NOT NULL," \
            "`gate1_x` FLOAT NOT NULL," \
            "`gate1_y` FLOAT NOT NULL," \
            "`gate1_z` FLOAT NOT NULL," \
            "`gate1_angle` FLOAT NOT NULL," \
            "`gate2_x` FLOAT NOT NULL," \
            "`gate2_y` FLOAT NOT NULL," \
            "`gate2_z` FLOAT NOT NULL," \
            "`gate2_angle` FLOAT NOT NULL," \
            "`gatezone_x` FLOAT NOT NULL," \
            "`gatezone_y` FLOAT NOT NULL," \
            "`gatezone_z` FLOAT NOT NULL" \
            ") ENGINE = InnoDB");

        mysql_query(mysql, query, false);

        if(mysql_errno() != 0)
        {
            printf("[GATES] Ошибка при создании таблицы 'gates': %d", mysql_errno());
            return 0;
        }
        else
        {
            printf("[GATES] Таблица 'gates' успешно создана.");
        }

        printf("[GATES] Вставляем начальные данные в новую таблицу...");
        for(new i = 0; i < sizeof(InitialGateCoords); i++)
        {
            mysql_format(mysql, query, sizeof(query), "INSERT INTO `gates` (" \
                "gate_type, gate1_x, gate1_y, gate1_z, gate1_angle, gate2_x, gate2_y, gate2_z, gate2_angle, gatezone_x, gatezone_y, gatezone_z" \
                ") VALUES (" \
                "'%d','%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f', '%f'" \
                ")",
                InitialGateCoords[i][0], InitialGateCoords[i][1], InitialGateCoords[i][2], InitialGateCoords[i][3], InitialGateCoords[i][4],
                InitialGateCoords[i][5], InitialGateCoords[i][6], InitialGateCoords[i][7], InitialGateCoords[i][8],
                InitialGateCoords[i][9], InitialGateCoords[i][10], InitialGateCoords[i][11]
            );
            mysql_query(mysql, query, false);
        }
        printf("[GATES] Начальные данные успешно вставлены.");
    }
    cache_delete(cache);
}
stock GetNearestGate(playerid)
{
    new Float:playerX, Float:playerY, Float:playerZ;
    GetPlayerPos(playerid, playerX, playerY, playerZ);

    new Float:minDistance = 100.0;
    new nearestGateID = INVALID_GATE_ID;

    for (new i = 0; i < g_gates_count; i++)
    {
        new Float:gateZoneX = GetGateData(i, GateZone_X);
        new Float:gateZoneY = GetGateData(i, GateZone_Y);
        new Float:gateZoneZ = GetGateData(i, GateZone_Z);

        new Float:distance = floatsqroot(floatpower(playerX - gateZoneX, 2.0) + floatpower(playerY - gateZoneY, 2.0) + floatpower(playerZ - gateZoneZ, 2.0));

        if(distance < minDistance)
        {
            minDistance = distance;
            nearestGateID = i;
        }
    }
    return nearestGateID;
}
stock SetVehicleNeon(vehicleid, color1, color2, color3, setvalue=0)
{
	if(setvalue)
	{
		vInfo[vehicleid][vNeon1] = color1;
		vInfo[vehicleid][vNeon2] = color2;
		vInfo[vehicleid][vNeon3] = color3;
	}
	foreach(new playerid: Player) SetVehicleNeonForPlayer(playerid, vehicleid, color1, color2, color3);
}

stock SetVehicleNeonForPlayer(playerid, vehicleid, color1, color2, color3)
{
	new BitStream:bs = BS_New();
	BS_WriteValue(bs, PR_UINT16, vehicleid);
	BS_WriteValue(bs, PR_UINT8, 9);

	BS_WriteValue(bs, PR_UINT32, color1);
	BS_WriteValue(bs, PR_UINT32, color2);
	BS_WriteValue(bs, PR_UINT32, color3);

	PR_SendRPC(bs, playerid, 167, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
	BS_Delete(bs);
}

