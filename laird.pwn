case PICKUP_ACTION_RENT_BIKE:
{
    SetPVarInt(playerid, "rent_zone_id", action_id);

    new fmt_text[4096], Cache:result;

    mysql_format(mysql, fmt_text, sizeof fmt_text,
        "SELECT id, model_id, number FROM ownable_cars WHERE owner_id = %d LIMIT 10",
        GetPlayerAccountID(playerid)
    );
    result = mysql_query(mysql, fmt_text, true);

    new rows = cache_num_rows();
    format(fmt_text, sizeof fmt_text, "");

    strcat(fmt_text, "{FF5252}##\t{FF5252}Название\t{FF5252}Номер\t{FF5252}Действие\n");
    strcat(fmt_text, "{FF5252}0.\t{FFFFFF}Скутер\t{888888}[------]\t{FF5252}Арендовать\n");
    SetPlayerListitemValue(playerid, 0, -1);

    new model_id, car_number[8], model_name[64], query[196];

    for (new row = 0; row < rows; row++)
    {
        new vehicle_id = cache_get_row_int(row, 0);
        model_id = cache_get_row_int(row, 1);
        cache_get_row(row, 2, car_number);

        GetVehicleModelName(model_id, model_name, sizeof(model_name));

        format(query, sizeof query, "{FF5252}%d.\t{FFFFFF}%s\t{888888}[%s]\t{FF5252}Загрузить\n", row + 1, model_name, car_number);

        if((row + 1) >= sizeof(g_player_listitem[]))
            break;

        if(strlen(fmt_text) + strlen(query) >= sizeof(fmt_text) - 1)
            break;

        strcat(fmt_text, query);

        SetPlayerListitemValue(playerid, row + 1, vehicle_id);
    }

    new title[128];
    format(title, sizeof(title), "{FF5252}%s | {FFFFFF}Управление транспортом", NameServer[SILE_NAME]);

    Dialog(playerid, DIALOG_RENT_BIKE, DIALOG_STYLE_TABLIST_HEADERS, title, fmt_text, "Выбрать", "Закрыть");

    cache_delete(result);
    return 1;
}

