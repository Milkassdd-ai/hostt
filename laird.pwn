	if(!(0 <= amount <= 10000))
		return SendClientMessage(playerid, 0x999999FF, "Количество от 0 до 10000");

	new value[12];
	valstr(value, amount);
	callcmd::fullprods(playerid, value);
	callcmd::fullfuels(playerid, value);

	return 1;
}
