			case DIALOG_PROMO_CREATE:
			{
				if(response)
				{
					new code[32], money, donate, paydays, usings;

					if(sscanf(inputtext, "P<,>s[32]dddd", code, money, donate, paydays, usings))
					{
						ShowNotificationSile(playerid, 2, 6, 0, 0, "Некорректный ввод!", "");
						callcmd::createpromo(playerid);

						return 1;
					}
					else
					{
						if(!(1 <= money <= 30_000_000))
						{
							ShowNotificationSile(playerid, 2, 6, 0, 0, "Кол-во рублей от 1 до 30 млн", "");
							callcmd::createpromo(playerid);

							return 1;
						}
						if(!(1 <= donate <= 250))
						{
							ShowNotificationSile(playerid, 2, 6, 0, 0, "Количество доната от 1 до 250", "");
							callcmd::createpromo(playerid);

							return 1;
						}

						if(!(1 <= usings <= 1_000_000))
						{
							ShowNotificationSile(playerid, 2, 6, 0, 0, "Кол-во использований от 1 до 1 млн", "");
							callcmd::createpromo(playerid);

							return 1;
						}

						if(!(0 <= paydays <= 10))
						{
							ShowNotificationSile(playerid, 2, 6, 0, 0, "Кол-во PayDay's от 0 до 10", "");
							callcmd::createpromo(playerid);

							return 1;
						}

						new query[196],
							Cache: result,
							rows;

						mysql_format(mysql, query, sizeof query, "SELECT * FROM promocode WHERE code='%s'", code);
						result = mysql_query(mysql, query, true);

						rows = cache_num_rows();

						cache_delete(result);

						if(rows)
						{
							ShowNotificationSile(playerid, 2, 6, 0, 0, "Данный промокод уже создан", "");
							callcmd::createpromo(playerid);

							return 1;
						}

						mysql_format(mysql, query, sizeof query, "INSERT INTO promocode (code, money, donate, paydays, usings) VALUES ('%s', %d, %d, %d, %d)",
						code, money, donate, paydays, usings);

						mysql_query(mysql, query);

						format(query, sizeof query, "Промокод \"%s\" создан: ДЕНЬГИ: %d | BC: %d | ЧАСЫ: %d | ИСП: %d)", code, money, donate, paydays, usings);
						SendClientMessage(playerid, 0x66CC33FF, query);
					}
				}
			}

