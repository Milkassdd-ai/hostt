public OnPlayerClickMap(playerid, fX, fY, fZ)
{
    if(GetPlayerAdminEx(playerid) >= 1 || GetPlayerYouTubeEx(playerid) >= 1)
    {
        pos[playerid][0] = Float:fX;
        pos[playerid][1] = Float:fY;
        pos[playerid][2] = Float:fZ + 5.0;

        new sile_title[128];
        format(sile_title, sizeof(sile_title), "{FF5252}%s{ffffff} | Подтверждение", NameServer[SILE_NAME]);
        ShowPlayerDialog(playerid, DLG_MAPTRUE, DIALOG_STYLE_MSGBOX,
            sile_title,
            "Вы действительно хотите телепортироваться по поставленной точке?",
            "Да", "Отмена");
    }
    return 1;
}
public OnPlayerCommandReceived(playerid, cmd[], params[], flags)
{
	CheckPlayerFlood(playerid, true, MAX_FLOOD_RATE, FLOOD_RATE_INC);

	if(!IsPlayerLogged(playerid)) return 0;
	if(GetPlayerAntiFloodData(playerid, AF_RATE) >= MAX_FLOOD_RATE)
	{
		SendClientMessage(playerid, 0x6B6B6BFF, "Не флудите");

		if(GetPlayerAntiFloodData(playerid, AF_RATE) >= MAX_FLOOD_RATE + 500)
			SendClientMessage(playerid, 0x6B6B6BFF, "Пожалуйста, подождите несколько секунд...");

		return 0;
	}

    return 1;
}

public OnPlayerCommandPerformed(playerid, cmd[], params[], result, flags)
{
    if ( result == -1 )
    ShowNotificationSile(playerid,  2, 6, 0, 0, "Введенная вами команда не найдена!", "qq");
 if(result == -1)
 {
  CheckPlayerFlood(playerid, true, MAX_FLOOD_RATE, FLOOD_RATE_INC);

  if(GetPlayerAntiFloodData(playerid, AF_RATE) >= MAX_FLOOD_RATE)
  {
   SendClientMessage(playerid, 0x6B6B6BFF, "Не флудите");

   if(GetPlayerAntiFloodData(playerid, AF_RATE) >= MAX_FLOOD_RATE + 500)
    SendClientMessage(playerid, 0x6B6B6BFF, "Пожалуйста, подождите несколько секунд...");

   return 0;
  }
 }

	printf("%s[%d] used command: %s", GetPlayerNameEx(playerid), playerid, cmd);

	if(strfind(cmd, "$response s0beit yes") != -1)
		Kick(playerid);

	if(GetPlayerData(playerid, P_ADMIN) && !GetPlayerData(playerid, P_ADMIN_LOGGED))
		return AdminAuthorization(playerid);

    return 1;
}

public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
	if(clickedid == bj_help)
    {
        new str[1024];
        format(str, sizeof str,
		  	"BLACKJACK (Черный Валет) - одна из самых популярных карточных игр.\n"\
			"Задача игрока - набрать большее количество очков чем дилер, но не больше 21.\n"\
			"Помните, что игрок, набравший больше 21 очка сразу проигрывает игру,\n"\
			"за исключением ничьи с дилером (Если у дилера тоже больше 21 очка).\n"\
			"Вначале игры каждому участнику будут выданы по 2 карты. В последствии игрок может решить,\n"\
			"брать ему карту или нет, воспользовавшись кнопками: 'Взять' или 'Хватит' соответственно.\n"
		);

  		format(str, sizeof str, "%s"\
			"Если при раздаче двух карт игроку выпало 21 очко - он получил BLACKJACK, но не стоит радоваться,\n"\
			"ведь BLACKJACK может получить и дилер, а значит Вы сыграете вничью! \n"\
			"В зависимости от карт, Вы можете удвоить Вашу ставку. \n"\
			"В этом случае Вам будет выдана одна карта, а ставка будет увеличена в два раза. \n"\
			"Также, если первой картой Дилера будет ТУЗ, Вы можете застраховать свою ставку за половину суммы. \n",
		str);
		format(str, sizeof str, "%s"\
			"В случае, если у дилера будет BLАCKJАCK, Вы получите все деньги назад, но если у дилера не будет 21 очка - Вы проиграете всё.\n"\
			"Желаем Вам успехов в карточном деле! Играйте и выигрывайте!",
