CMD:imgui(playerid, params[])
{
    new image_name[64];
    
    if(sscanf(params, "s[64]", image_name))
    {
        SendClientMessage(playerid, -1, "Использование: /image [имя_файла]");
        SendClientMessage(playerid, -1, "Пример: /image halloween_bg.png");
        return 1;
    }
    
    ShowPlayerImageGUI(playerid, 0, image_name);
    return 1;
}
CMD:figui(playerid, params[])
{
    new image_name;
    
    if(sscanf(params, "d", image_name))
    {
        SendClientMessage(playerid, -1, "Использование: /figui [close]");
        return 1;
    }
    
    ShowPlayerFingerGUI(playerid, image_name);
    return 1;
}

CMD:prgui(playerid, params[])
{
    new close, model_id, render_type, message[128], header[128];
    new Float:rot_x, Float:rot_y, Float:rot_z, Float:zoom;
    
    if(sscanf(params, "is[128]s[128]iffff", model_id, message, header, render_type, rot_x, rot_y, rot_z, zoom))
    {
        SendClientMessage(playerid, -1, "Использование: /prize [model_id] [message] [header] [render_type] [rot_x] [rot_y] [rot_z] [zoom]");
        return 1;
    }
    
    ShowPlayerPrizeGUI(playerid, model_id, message, header, render_type, rot_x, rot_y, rot_z, zoom);
    return 1;
}

stock CreatePlayerTextDrawsZp(playerid) 
{
	money_PTD[playerid][0] = CreatePlayerTextDraw(playerid, 523.3333, 95.6814, "main:moneytd");
	PlayerTextDrawTextSize(playerid, money_PTD[playerid][0], 115.0000, 61.0000);
	PlayerTextDrawAlignment(playerid, money_PTD[playerid][0], 1);
	PlayerTextDrawColor(playerid, money_PTD[playerid][0], -1);
	PlayerTextDrawBackgroundColor(playerid, money_PTD[playerid][0], 255);
	PlayerTextDrawFont(playerid, money_PTD[playerid][0], 4);
	PlayerTextDrawSetProportional(playerid, money_PTD[playerid][0], 0);
	PlayerTextDrawSetShadow(playerid, money_PTD[playerid][0], 0);

	money_PTD[playerid][1] = CreatePlayerTextDraw(playerid, 571.9998, 119.8962, "0");
	PlayerTextDrawLetterSize(playerid, money_PTD[playerid][1], 0.3380, 1.1229);
	PlayerTextDrawAlignment(playerid, money_PTD[playerid][1], 1);
	PlayerTextDrawColor(playerid, money_PTD[playerid][1], -1);
	PlayerTextDrawBackgroundColor(playerid, money_PTD[playerid][1], 255);
	PlayerTextDrawFont(playerid, money_PTD[playerid][1], 1);
	PlayerTextDrawSetProportional(playerid, money_PTD[playerid][1], 1);
	PlayerTextDrawSetShadow(playerid, money_PTD[playerid][1], 0);
	return 1;
}

stock ShowZP(playerid) 
{
	CreatePlayerTextDrawsZp(playerid);
	for(new i = 0; i < 2; i++) 
		PlayerTextDrawShow(playerid, money_PTD[playerid][i]);
	
	if(UpdateZp[playerid] != -1) KillTimer(UpdateZp[playerid]);
	UpdateZp[playerid] = SetTimerEx("UpdateTextDrawsZP", 1000, true, "i", playerid);
	ChekUpdateddd[playerid] = 1;
	return 1;	
}


stock HideZP(playerid) 
{
	PlayerZP[playerid] = 0;
	for(new i = 0; i < 2; i++)
		PlayerTextDrawHide(playerid, money_PTD[playerid][i]);
	return 1;
}


stock AddZP(playerid, sum) 
{
	PlayerZP[playerid] += sum;
	return PlayerZP[playerid];
}

stock SetZP(playerid, sum) 
{
	PlayerZP[playerid] = sum;
	return PlayerZP[playerid];
}


stock GetZP(playerid)
{
	return PlayerZP[playerid];
}

forward UpdateTextDrawsZP(playerid);
public UpdateTextDrawsZP(playerid)
{
	new str[32];
	format(str, sizeof(str), "%d", PlayerZP[playerid]);
	PlayerTextDrawSetString(playerid, money_PTD[playerid][1], str);
	return 1;
}

