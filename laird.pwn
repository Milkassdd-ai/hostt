CMD:bot(playerid, params[])

{

	if(GetPlayerAdminEx(playerid) < 6) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /bot [ID игрока]");

	extract params -> new to_player, string:reason[30];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))

	return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new ban_time = 9999;

	new fmt_msg[999];

	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid))

	return SendClientMessage(playerid, 0xCECECEFF, ""SC"Нельзя забанить администратора выше по рангу");

	if(AntiSliv(playerid, "/bot")) return true;

	format(fmt_msg, sizeof fmt_msg, "Администратор %s забанил игрока %s навсегда", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

	format(fmt_msg, sizeof fmt_msg, "%s. Причина: БОТ", fmt_msg);

	if(strlen(reason) > 0)
		format(fmt_msg, sizeof fmt_msg, "%s. Причина: %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "Забанил %s[acc:%d] навсегда. Причина %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

    InfoAstats[1] += 1;
	AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, GetPlayerIpEx(to_player), reason, GetPlayerNameEx(playerid));

	Kick(to_player);

	return 1;

}

CMD:permban(playerid, params[])

{

	if(GetPlayerAdminEx(playerid) < 6) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /permban [ID игрока] [причина]");

	extract params -> new to_player, string:reason[30];

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))

	return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new ban_time = 9999;

	new fmt_msg[999];

	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid))

	return SendClientMessage(playerid, 0xCECECEFF, ""SC"Нельзя забанить администратора выше по рангу");

	if(AntiSliv(playerid, "/permban")) return true;

	format(fmt_msg, sizeof fmt_msg, "Администратор %s навсегда заблокировал игрока %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

	if(strlen(reason) > 0)

	format(fmt_msg, sizeof fmt_msg, "%s. Причина: %s", fmt_msg, reason);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	if(!strlen(reason)) reason = "None";

	format(fmt_msg, sizeof fmt_msg, "Забанил %s[acc:%d] навсегда. Причина %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), reason);

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

    InfoAstats[1] += 1;

	AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, GetPlayerIpEx(to_player), reason, GetPlayerNameEx(playerid));

	Kick(to_player);

	return 1;

}

CMD:ppv(playerid, params[])
{
 if(GetPlayerAdminEx(playerid) < 6) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

 if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /ppv [ID игрока]");

 extract params -> new to_player;

 if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
 return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

 new ban_time = 9999;

 new fmt_msg[999];

 if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid))
 return SendClientMessage(playerid, 0xCECECEFF, "Нельзя забанить администратора выше по рангу");
 if(to_player == playerid) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя забанить самого себя");

 if(AntiSliv(playerid, "/ppv")) return true;

 format(fmt_msg, sizeof fmt_msg, "Администратор %s забанил игрока навсегда %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player));

 format(fmt_msg, sizeof fmt_msg, "%s. Причина: ППВ", fmt_msg);

 SendClientMessageToAll(0xFF5533FF, fmt_msg);

 format(fmt_msg, sizeof fmt_msg, "Забанил %s[acc:%d] навсегда. Причина: ППВ", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));

 SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

 AddBan(GetPlayerAccountID(to_player), gettime(), ban_time, GetPlayerIpEx(to_player), GetPlayerNameEx(playerid));
 BanEx(to_player);
 return 1;
}

CMD:flood(playerid, params[])
{

	if(GetPlayerAdminEx(playerid) < 3) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");
	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /flood [id игрока]");
	extract params -> new to_player;
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
	return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");
	new mute_time = 30;

	if(GetPlayerData(to_player, P_MUTE) > 0) return SendClientMessage(playerid, 0xCECECEFF, "У этого игрока уже есть мут");
	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя поставить заблокировать чат администратору выше по рангу");

	if(AntiSliv(playerid, "/flood")) return true;
	new fmt_msg[999];
	format(fmt_msg, sizeof fmt_msg, "Администратор %s выдал блокировку чата игроку %s на %d мин", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), mute_time);
	format(fmt_msg, sizeof fmt_msg, "%s. Причина: Флуд", fmt_msg);
	SendClientMessageToAll(0xFF5533FF, fmt_msg);
	SetPlayerData(to_player, P_MUTE, mute_time * 60);
	UpdatePlayerDatabaseInt(to_player, "mute", mute_time * 60);
	SendClientMessage(to_player, 0xCECECEFF, ""SC"Время до окончания бана чата: {CCCC00}/time");
	SendClientMessage(to_player, 0xCECECEFF, ""SC"Советуем ознакомится с правилами сервера, чтобы не получать подобных наказаний.");
	ShowNotificationSile(to_player, 2, 5, 0, 0, "{FFFFFF}У вас имеется активный мут. Время до\n{FFFFFF}разблокировки: {CCCC00}/time", " ");
	format(fmt_msg, sizeof fmt_msg, "Выдал %s[acc:%d] блокировку чата на %d мин. Причина: Флуд",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), mute_time);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);
	return 1;
}

CMD:mat(playerid, params[])
{

	if(GetPlayerAdminEx(playerid) < 4) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	if(!strlen(params)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Используйте: /mat [ID игрока]");

	extract params -> new to_player;

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
	return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new mute_time = 30;
	if(GetPlayerData(to_player, P_MUTE) > 0) return SendClientMessage(playerid, 0xCECECEFF, ""SC"У этого игрока уже есть мут");
	if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, ""SC"Нельзя выдать мут администратору выше вашего ранга");

	if(AntiSliv(playerid, "/mat")) return true;

	new fmt_msg[999];
	format(fmt_msg, sizeof fmt_msg, "Администратор %s выдал блокировку чата игроку %s на %d минут", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), mute_time);

	format(fmt_msg, sizeof fmt_msg, "%s. Причина: Мат в вип чат", fmt_msg);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	SetPlayerData(to_player, P_MUTE, mute_time * 60);
	UpdatePlayerDatabaseInt(to_player, "mute", mute_time * 60);

	SendClientMessage(to_player, 0xCECECEFF, ""SC"Время до окончания бана чата: {CCCC00}/time");
	SendClientMessage(to_player, 0xCECECEFF, ""SC"Советуем ознакомится с правилами сервера, чтобы не получать подобных наказаний.");
	ShowNotificationSile(to_player, 2, 5, 0, 0, "{FFFFFF}У вас имеется активный мут. Время до\n{FFFFFF}разблокировки: {CCCC00}/time", " ");

	format(fmt_msg, sizeof fmt_msg, "Выдал %s[acc:%d] блокировку чата на %d минут. Причина: Мат в вип чат",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), mute_time);

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	return 1;
}
CMD:delveh(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 4) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");
    if(!IsPlayerInAnyVehicle(playerid)) return SendClientMessage(playerid, -1, ""USC"Вы должны быть за рулем автомобиля");
    if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return true;
    if(GetVehicleData(GetPlayerVehicleID(playerid), V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_ADMIN_CAR)
    {
	    RemovePlayerFromVehicle(playerid);
	    n_veh_DestroyVehicle(GetPlayerVehicleID(playerid));
	    SendClientMessage(playerid, 0xCECECEFF, ""SC"Вы удалили созданный транспорт");

	    new fmt_msg[999];

    	format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] удалил созданный транспорт", GetPlayerNameEx(playerid), playerid);
    	SendMessageToAdmins(fmt_msg, 0x999999FF);
	}
	return true;
}

CMD:reset_cash(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 13) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	extract params -> new to_player, cash; else return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /reset_cash [ID игрока] [cумма]");
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new reason[999];
	new fmt_msg[999];
	format(reason, sizeof reason, "{1E90FF}Администратор %s[%d] обнулил вам деньги", GetPlayerNameEx(playerid), playerid);
	GivePlayerMoneyEx(to_player, -cash, reason, true, true);
	SendClientMessage(to_player, 0x66CC00FF, reason);

    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] обнулил деньги игроку %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);

	format(reason, sizeof reason, "{1E90FF}Вы обнулили %s %d рублей", GetPlayerNameEx(to_player), cash);
	SendClientMessage(playerid, 0x66CC00FF, reason);

	format(reason, sizeof reason, "Обнулил %s[%d] %d руб", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), cash);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, reason);
	return 1;
}

CMD:reset_donate(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 13) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");

	extract params -> new to_player, donate; else return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /reset_donate [ID игрока] [cумма]");
	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	new reason[999];
	new fmt_msg[999];
	format(reason, sizeof reason, "{1E90FF}Администратор %s[%d] обнулил вам донат", GetPlayerNameEx(playerid), playerid);
	GivePlayerDonateRub(to_player, -donate, reason, true, true);
	SendClientMessage(to_player, 0x66CC00FF, reason);

    format(fmt_msg, sizeof fmt_msg, "[A] %s[%d] обнулил донат игроку %s[%d]", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player);
    SendMessageToAdmins(fmt_msg, 0x999999FF);

	format(reason, sizeof reason, "{1E90FF}Вы обнулили %s %d доната", GetPlayerNameEx(to_player), donate);
	SendClientMessage(playerid, 0x66CC00FF, reason);

	format(reason, sizeof reason, "Обнулил %s[%d] %d доната", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), donate);
	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, reason);
	return 1;
}

CMD:givevip(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 13) return ShowNotificationSile(playerid, 2, 3, 0, 0, "У вас нет доступа к использованию данной команде", " ");
	extract params -> new to_player, premium, days; else return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /givevip [ID игрока] [уровень премиум-аккаунта] [время (в днях)]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return ShowNotificationSile(playerid, 2, 4, 0, 0, "Такого игрока нет", " ");

	if(!(1 <= premium <= 3)) return SendClientMessage(playerid, 0x999999FF, "Уровень премиум-аккаунта от 1 до 3 (чтобы отобрать, используйте кол-во дней: 0)");

	if(!(0 <= days <= 30)) return SendClientMessage(playerid, 0x999999FF, "Количество дней от 0 до 30");

	new fmt_msg[999];

	new premium_rank[3][17] =
	{
		"{C0C0C0}Silver",
		"{FF5252}Gold",
		"{E5E4E2}Platinum"
	};

	SetPlayerData(to_player, P_PREMIUM, premium);
	SetPlayerData(to_player, P_PREMIUM_TIME, gettime() + days * 86400);

	UpdatePlayerDatabaseInt(to_player, "premium", premium);
	UpdatePlayerDatabaseInt(to_player, "premium_time", gettime() + days * 86400);

	format(fmt_msg, sizeof fmt_msg, "%s выдал Вам %s {3399FF}премиум-аккаунт на %d дн.", GetPlayerNameEx(playerid), premium_rank[premium - 1], days);
	SendClientMessage(to_player, 0x3399FFFF, fmt_msg);

	format(fmt_msg, sizeof fmt_msg, "Вы выдали %s %s {3399FF}премиум-аккаунт на %d дн.", GetPlayerNameEx(to_player), premium_rank[premium - 1], days);
	SendClientMessage(playerid, 0x3399FFFF, fmt_msg);

	return 1;
}

CMD:epoints(playerid)
{
	if(GetPlayerAdminEx(playerid) < 1) return 0;

	new fmt_str[300];

	format(str, sizeof str, "{FF5252}"SERVER_NAME"{ffffff} | Баллов: {FF5252}%d", GetPlayerData(playerid, P_ACOINS));

	Dialog
		(
			playerid, DIALOG_ADMSHOP, DIALOG_STYLE_LIST,
			str,
			"{FF5252} #1 {FFFFFF}Виртуальная Валюта\t\t\t\t\t {888888} нажмите для взаимодействия\n"\
			"{FF5252} #2 {FFFFFF}Донатная Валюта\t\t\t\t\t {888888} нажмите для взаимодействия\n"\
			"{FF5252} #3 {FFFFFF}Вип статусы\t\t\t\t\t {888888} нажмите для взаимодействия\n"\
			"{FF5252} #4 {FFFFFF}Кейсы\t\t\t\t\t {888888} нажмите для взаимодействия\n"\
			"{FF5252} #5 {FFFFFF}Уникальные аксессуары\t\t\t\t\t {888888} нажмите для взаимодействия",
			"Выбрать", "Закрыть"
		);
}
CMD:giveepoints(playerid, params[])
{
	if(GetPlayerAdminEx(playerid) < 13) return 1;

	extract params -> new to_player, acoins; else return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /giveepoints [id игрока] [cумма]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xCECECEFF, "Такого игрока нет");

	if(!(-1 <= acoins <= 100_000)) return SendClientMessage(playerid, 0xCECECEFF, "Можно выдавать от 1 до 10000 Баллов за один раз");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, -1, ""USC" Игрок не в сети!");

	new fmt_text[999];

    format(fmt_text, sizeof fmt_text, "{FFFFFF}Администратор {FF5252}%s {FFFFFF}выдал Вам {FF5252}%d {FFFFFF}балла(-ов) обмена.", GetPlayerNameEx(playerid), acoins);
	SendClientMessage(to_player, -1, fmt_text);

	format(fmt_text, sizeof fmt_text, "{FFFFFF}Чтобы потратить баллы воспользуйтесь специальной командой: {FF5252}/epoints");
	SendClientMessage(to_player, -1, fmt_text);

	format(fmt_text, sizeof fmt_text, "[A] %s[%d] выдал баллы для обмена %s[%d] кол-во %d баллов, в итоге у игрока %d баллов", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, acoins, GetPlayerMoneyEx(to_player));
	SendMessageToAdmins(fmt_text, 0xCECECEFF);

    AddPlayerData(playerid, P_ACOINS, +, acoins);
	UpdatePlayerDatabaseInt(playerid, "acoins", GetPlayerData(to_player, P_ACOINS) - 450);
	return 1;
}

stock GivePlayerCar(playerid, modelid, color_1, color_2)
{

		if((GetPlayerOwnableCars(playerid) + 1) > GetPlayerCarSlots(playerid))
		{
			SendClientMessage(playerid, 0x3399FFFF, "Все слоты для транспорта заняты. Вы можете увеличить их: {FF5252}/menu > Дополнительно");
			return -1;
		}

		if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
		{
			SendClientMessage(playerid, 0x999999FF, "Для покупки транспорта нужно выгрузить уже загруженный транспорт с сервера");
			return -1;
		}

		new buy_cars_count = cars_after_purchase_count[2]++;

		if(buy_cars_count >= 4)
			cars_after_purchase_count[2] = 0;

		new Float: pos_x = cars_pos_after_purchase[2][buy_cars_count][0];
		new Float: pos_y = cars_pos_after_purchase[2][buy_cars_count][1];
		new Float: pos_z = cars_pos_after_purchase[2][buy_cars_count][2];
		new Float: angle = cars_pos_after_purchase[2][buy_cars_count][3];

		new query[220],
			Cache: result,
			idx;

		idx = GetFreeOwnableCarID();

		SetOwnableCarData(idx, OC_OWNER_ID, 	GetPlayerAccountID(playerid));

		SetOwnableCarData(idx, OC_MODEL_ID, 	modelid);
		SetOwnableCarData(idx, OC_COLOR_1, 		color_1);
		SetOwnableCarData(idx, OC_COLOR_2, 		color_2);

		SetOwnableCarData(idx, OC_POS_X, 		pos_x);
		SetOwnableCarData(idx, OC_POS_Y, 		pos_y);
		SetOwnableCarData(idx, OC_POS_Z, 		pos_z);
		SetOwnableCarData(idx, OC_ANGLE, 		angle);

		strmid(g_ownable_car[idx][OC_NUMBER], "", 0, 8, 8);

		SetOwnableCarData(idx, OC_ALARM, 		false);
		SetOwnableCarData(idx, OC_KEY_IN, 		false);

		SetOwnableCarData(idx, OC_CREATE, 		gettime());

		format(g_ownable_car[idx][OC_OWNER_NAME], 21, GetPlayerNameEx(playerid));

		new vehicleid = CreateVehicle
		(
			GetOwnableCarData(idx, OC_MODEL_ID),
			GetOwnableCarData(idx, OC_POS_X),
			GetOwnableCarData(idx, OC_POS_Y),
			GetOwnableCarData(idx, OC_POS_Z),
			GetOwnableCarData(idx, OC_ANGLE),
			GetOwnableCarData(idx, OC_COLOR_1),
			GetOwnableCarData(idx, OC_COLOR_2),
			-1,
			0,
			VEHICLE_ACTION_TYPE_OWNABLE_CAR,
			idx
		);
		if(vehicleid != INVALID_VEHICLE_ID)
		{

			format(g_ownable_car[idx][OC_NUMBER], 12, g_ownable_car[idx][OC_NUMBER]);
			SetVehicleNumberPlateEx(vehicleid, g_ownable_car[idx][OC_NUMBER_TYPE], g_ownable_car[idx][OC_NUMBER], g_ownable_car[idx][OC_REGION]);
			SetVehicleParam(vehicleid, V_LOCK, false);

			SetVehicleData(vehicleid, V_MILEAGE, 0.0);
		}

		SetPlayerData(playerid, P_OWNABLE_CAR, vehicleid);

		format
		(
			query, sizeof query,
			"INSERT INTO ownable_cars \
			(owner_id,model_id,color_1,color_2,pos_x,pos_y,pos_z,angle,create_time) \
			VALUES \
			('%d','%d','%d','%d','%f','%f','%f','%f','%d')",
			GetPlayerAccountID(playerid),
			modelid,
			color_1,
			color_2,
			pos_x,
			pos_y,
			pos_z,
			angle,
			gettime()
		);
		result = mysql_query(mysql, query, true);

		SetOwnableCarData(idx, OC_SQL_ID, cache_insert_id());

		cache_delete(result);

		SendClientMessage(playerid, 0x66CC00FF, "{FFFFFF}Для загрузки транспорта воспользуйтесь{FF5252} Меню - Транспорт.");
	    SendClientMessage(playerid, 0x66CC00FF, "{FFFFFF}Или воспользуйтесь{FF5252} парковкой.");
		UnloadPlayerOwnableCar(playerid);

		return 1;
}

stock GetPromoPriz(playerid, code[])
{
    new query[144], Cache:result;

    mysql_format(mysql, query, sizeof query, "SELECT * FROM promocode WHERE code = '%s'", code);

    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows(result);

    if (rows > 0)
    {
        new amount[32], paydays[32];
        new amountValue;
        new paydaysValue;

        amountValue = cache_get_field_content_int(0, "amount");
        paydaysValue = cache_get_field_content_int(0, "paydays");

        new fmt_e[210];
format(fmt_e, sizeof fmt_e, "{FF5252}%s\n \n {FFFFFF}Вы получили награды:\n{FF5252}1. {FFFFFF}Игровая валюта {FF5252}%d\n \n{FFFFFF}Забрать приз после отыгрыша-/promo-Забрать призы!\n \nПриятной Игры на {FF5252}BLACK RUSSIA", code, amountValue, paydaysValue);

cache_delete(result);

        return fmt_e;
    }

}

CMD:bankomat(playerid, params[])
{
    if(!IsPlayerAtATM(playerid))
        return SendClientMessage(playerid, -1, "Вы не рядом с банкоматом!");

    Dialog(playerid, DIALOG_ATM, DIALOG_STYLE_LIST,
        "{FFCD00}Банкомат",
        "1. Снять с банковского счета\n"\
        "2. Положить на банковский счет\n"\
        "3. Баланс банковского счета\n"\
        "4. Снять со счета предприятия\n"\
        "5. Положить на счет предприятия\n"\
        "6. Пополнить мобильный телефон\n"\
        "7. Безналичный перевод\n"\
        "8. Оплата штрафа\n"\
        "9. Благотворительность",
        "Выбрать", "Выйти"
    );
    return 1;
}

CMD:starthalloween(playerid)
{
    if(g_HalloweenQuestActive == 0)
    {
        g_HalloweenQuestActive = 1;
        g_PlayerQuestStatus[playerid] = 0;

        new message[128];
        format(message, sizeof(message), "Вы успешно начали Halloween квест");
        SendClientMessage(playerid, COLOR_WHITE, message);
        CreateVehicle(466, -707.802062,101.233436,16.304492, 0.0);
        SetPlayerCheckpoint(playerid, -707.802062,101.233436,16.304492);
        if(!IsPlayerPassenger(playerid))
        {
        SetPlayerCheckpoint(playerid, -226.964385,452.922241,12.885372);
        Dialog
        (
        playerid, 12459, DIALOG_STYLE_MSGBOX, "Старик",
        "Здравствуй %s! Садись в машину и отправляй на метку!",
        "Выбрать", "Закрыть" );

       }

    }
    else
    {
        new message[128];
        format(message, sizeof(message), "Вы уже начали квест");
        SendClientMessage(playerid, COLOR_RED, message);
    }
}

CMD:startquest(playerid)
{
if (g_PlayerQuestState[playerid] == QUEST_NOT_STARTED)
{
            g_PlayerQuestState[playerid] = QUEST_IN_PROGRESS;
            ShowPlayerDialog(playerid, DIALOG_START_QUEST, DIALOG_STYLE_MSGBOX,
                             "Старик: Привет! Мне нужны бумаги. Отвези их Злой Зине.",
                             "Понял", "Отмена");
        } else
 {
            SendClientMessage(playerid, COLOR_RED, "Вы уже начали квест!");
        }
        return 1;
    }

 public: timerinko(playerid)
{
	new fmt_str[100];
	if(inko[playerid] >= 3 || inko[napinko[playerid]] >= 3)
	{
		if(GetPlayerVehicleID(playerid) != vehidinko[playerid])
		{
			secinko[playerid] -= 1;
			format(fmt_str, sizeof fmt_str, "~y~%d", secinko[playerid]);
			GameTextForPlayer(playerid, fmt_str, 1000, 3);
			if(secinko[playerid] < 1)
			{
				DestroyVehicle(vehidinko[playerid]);
				SendClientMessage(playerid, 0xFF5252, "Вы не успели вернуться в авто. Рабочий день окончен.");
				inko[playerid] = 0;
				napinko[playerid] = -1;
				inko[napinko[playerid]] = 0;
				napinko[napinko[playerid]] = -1;
			}
		}
		else return secinko[playerid] = 90;
	}

}
public: inkozakaz()
{
	 new rows, query[256], money;

	 mysql_query(mysql, "SELECT * FROM inkozakaz", true);
	 rows = cache_num_rows();

	 if(rows >= 10) return 1;

	 new rand = random(sizeof(coordraz));
	 new randrang = RandomEx(1, 4);
	 switch(randrang)
	 {
	  case 1: money = 16000;
	 case 2: money = 24000;
	 case 3: money = 32000;
	}

	 mysql_format(mysql, query, sizeof query, "INSERT INTO inkozakaz(x, y, z, money, rang) VALUES(%f, %f, %f, %d, %d)", coordraz[rand][0],coordraz[rand][1],coordraz[rand][2], money, randrang);
	 mysql_query(mysql, query, true);

	 return 1;
}

stock GetPlayerRang(playerid)
{
	new query[196], rang;

	mysql_format(mysql, query, sizeof query, "SELECT rang FROM inko WHERE id=%d", GetPlayerAccountID(playerid));
	mysql_query(mysql, query, true);

	if(!cache_num_rows()) rang = 0;
	else rang = cache_get_row_int(0, 0);

	return rang;
}
stock SetPlayerRang(playerid, rang)
{
	new query[196], work;
	mysql_format(mysql, query, sizeof query, "SELECT * FROM inko WHERE id=%d", GetPlayerAccountID(playerid));
	mysql_query(mysql, query, true);

	if(cache_num_rows())
	{

		mysql_format(mysql, query, sizeof query, "UPDATE inko SET rang=%d WHERE id=%d", rang, GetPlayerAccountID(playerid));
		mysql_query(mysql, query, true);
	}
	return 1;
}
stock GetPlayerInko(playerid)
{
	new query[196], work;

	mysql_format(mysql, query, sizeof query, "SELECT work FROM inko WHERE id=%d", GetPlayerAccountID(playerid));
	mysql_query(mysql, query, true);

	if(!cache_num_rows()) work = 0;
	else work = cache_get_row_int(0, 0);

	return work;
}
stock SetPlayerInko(playerid, inko)
{
	new query[128];

	mysql_format(mysql, query, sizeof query, "SELECT * FROM inko WHERE id=%d", GetPlayerAccountID(playerid));
	mysql_query(mysql, query, true);

	if(cache_num_rows())
	{
		mysql_format(mysql, query, sizeof query, "UPDATE inko SET work=%d WHERE id=%d", inko, GetPlayerAccountID(playerid));
		mysql_query(mysql, query, true);
	}
	return 1;
}
stock SetPlayerZakazInko(playerid, zakaz)
{
