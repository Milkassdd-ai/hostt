		            strcat(helpadmcmd, "{FF5252}№1 {ffffff}/sliv  навсегда заблокировать за слив\n{FF5252}№2 {ffffff}/cheat  навсегда заблокировать за посторонее ПО\n{FF5252}№3 {ffffff}/sk  посадить в деморган за SpawnKill\n{FF5252}№4 {ffffff}/caps  выдать мут за CapsLook\n{FF5252}№5 {ffffff}/osk  выдать мут за оскорбление\n{FF5252}№6 {ffffff}/oskadm  выдать мут за оскорбление администрации\n{FF5252}№7 {ffffff}/goss  выдать мут за торговлю на территории государства\n{FF5252}№8 {ffffff}/flood  выдать мут за флуд\n{FF5252}№9 {ffffff}/fdrive  посадить в деморган за NonRp фуру\n{FF5252}№10 {ffffff}/ndrive  посадить в деморган за NonRp вождение\n{FF5252}№11 {ffffff}/mg  выдать мут за MetaGaming (MG)\n{FF5252}№12 {ffffff}/pg  посадить в деморган за PowerGaming (PG)\n{FF5252}№13 {ffffff}/db  посадить в деморган за Drive By\n{FF5252}№14 {ffffff}/dm  посадить в деморган за DeathMach (DM)\n{FF5252}№15 {ffffff}/ppv  заблокировать за Продан/Передан/Взломан\n{FF5252}№16 {ffffff}/bot  навсегда заблокировать за БОТ");
