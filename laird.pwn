stock SetVehicleSpeedometerInfo(vehicleid, Float:fuel = 0.0, Float:mileage = 0.0)
{
    vSpeedometerFuel[vehicleid] = fuel;
    vSpeedometerMileage[vehicleid] = mileage;

    foreach(new playerid: Player)
    {
        if(GetPlayerVehicleID(playerid) == vehicleid && GetPlayerState(playerid) == PLAYER_STATE_DRIVER) SetVehicleSpeedometerInfoFP(playerid, vehicleid, fuel, mileage);
    }
}

stock GetVehicleDataName(modelid, name[], size)
{
    if(GetVehicleJsonNameByModelId(modelid, name, size))
    {
        return 1;
    }

    new index = modelid - 400;
    if(index >= 0 && index < 3000)
    {

        if(g_vehicle_info[index][VI_PRICE] > 0)
        {
            format(name, size, "%s", g_vehicle_info[index][VI_NAME]);
            return 1;
        }
    }

    #if defined g_high_end_vehicles
    new he_index = FindHighEndVehicle(modelid);
    if(he_index != -1)
    {
        format(name, size, "%s", g_high_end_vehicles[he_index][HEVI_NAME]);
        return 1;
    }
    #endif

    format(name, size, "Model_%d", modelid);
    return 0;
}


stock HexToInt(const hex_string[])
{
    new len = strlen(hex_string);
    if(len == 0) return 0;

    new result = 0;
    for(new i = 0; i < len; i++)
    {
        new c = hex_string[i];
        result <<= 4;

        if('0' <= c <= '9')
            result |= (c - '0');
        else if('A' <= c <= 'F')
            result |= (c - 'A' + 10);
        else if('a' <= c <= 'f')
            result |= (c - 'a' + 10);
        else
            return 0;
    }
    return result;
}

forward SyncAllVehiclesForPlayer(playerid);
public SyncAllVehiclesForPlayer(playerid)
{
    for(new v = 1; v < MAX_VEHICLES; v++)
    {
        if(IsValidVehicle(v) && IsVehicleStreamedIn(v, playerid))
        {
            SyncVehicleTuningForPlayer(playerid, v);
        }
    }
}
stock SaveVehicleTuning(vehicleid)
{
    if(!IsValidVehicle(vehicleid)) return 0;

    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index == INVALID_VEHICLE_ID) return 0;

    new sql_id = GetOwnableCarData(index, OC_SQL_ID);
    if(sql_id <= 0) return 0;

    new query[512];
    mysql_format(mysql, query, sizeof(query),
        "UPDATE `ownable_cars` SET \
        `tuning_neon1` = %d, \
        `tuning_neon2` = %d, \
        `tuning_neon3` = %d, \
        `tuning_tint` = %d, \
        `tuning_vinyl` = %d, \
        `tuning_toner_front` = %d, \
        `tuning_toner_rear` = %d, \
        `tuning_toner_front_side` = %d, \
        `tuning_toner_rear_side` = %d, \
        `tuning_suspension_force` = %f, \
        `tuning_suspension_bias` = %f, \
        `tuning_wheel_size` = %f, \
        `tuning_wheel_add_front` = %f, \
        `tuning_wheel_add_rear` = %f, \
        `tuning_hydraulics` = %d, \
        `tuning_launch_control` = %d, \
        `tuning_stroboscope` = %d, \
        `tuning_siren` = %d, \
        `tuning_plate_type` = %d, \
        `tuning_plate_number` = '%e', \
        `tuning_plate_region` = '%e' \
        WHERE `id` = %d LIMIT 1",

        vInfo[vehicleid][vNeon1],
        vInfo[vehicleid][vNeon2],
        vInfo[vehicleid][vNeon3],
        vInfo[vehicleid][vTint],
        vInfo[vehicleid][vVinyl],
        vInfo[vehicleid][viTonerFront],
        vInfo[vehicleid][viTonerRear],
        vInfo[vehicleid][viTonerFrontSide],
        vInfo[vehicleid][viTonerRearSide],
        vInfo[vehicleid][vSuspensionForce],
        vInfo[vehicleid][vSuspensionBias],
        vInfo[vehicleid][vWheelSize],
        vInfo[vehicleid][vWheelAddFront],
        vInfo[vehicleid][vWheelAddRear],
        vInfo[vehicleid][viHydraulics],
        vInfo[vehicleid][viLaunchControl],
        vInfo[vehicleid][viStrob],
        vInfo[vehicleid][viSiren],
        vNumber[vehicleid][npType],
        vNumber[vehicleid][npNumber],
        vNumber[vehicleid][npRegion],
        sql_id
    );

    mysql_tquery(mysql, query);

    return 1;
}

stock LoadVehicleTuningFromCache(vehicleid, row, Cache:result)
{
    if(!IsValidVehicle(vehicleid)) return 0;

    ResetVehicleTuning(vehicleid);

    
    return 1;
}
forward OnVehicleTuningLoad(vehicleid, index);
public OnVehicleTuningLoad(vehicleid, index)
{
    if(!IsValidVehicle(vehicleid)) return 0;
    ResetVehicleTuning(vehicleid);

    if(cache_num_rows() > 0)
    {
        LoadVehicleTuningFromCache(vehicleid, 0, cache_save());

        foreach(new playerid: Player)
        {
            if(IsVehicleStreamedIn(vehicleid, playerid))
            {
                SyncVehicleTuningForPlayer(playerid, vehicleid);
            }
        }
    }

    return 1;
}

forward DelayedPutPlayerInVehicle(playerid, vehicleid);
public DelayedPutPlayerInVehicle(playerid, vehicleid)
{
    if(IsPlayerConnected(playerid) && GetVehicleModel(vehicleid) != 0)
    {
        PutPlayerInVehicle(playerid, vehicleid, 0);
    }
}
stock UnloadOwnableCar(vehicleid)
{
    new idx = GetOwnableCarIDByVehicleID(vehicleid);
    if(idx != -1)
    {

        SetOwnableCarData(idx, OC_SQL_ID, 0);
        SetOwnableCarData(idx, OC_OWNER_ID, 0);
        SetOwnableCarData(idx, OC_MODEL_ID, 0);
        SetOwnableCarData(idx, OC_CREATE, 0);

        if(g_ownable_car_loaded > 0)
        {
            g_ownable_car_loaded--;

        }

        UnloadOwnableCarTrunk(vehicleid);
    }

    DestroyVehicle(vehicleid);
    return 1;
}

stock SetGreenZone(value)
{
    foreach (new i : Player)
    {
        SetGreenZoneForPlayer(i, value);
    }
}

stock SetGreenZoneForPlayer(playerid, value)
{
    if (!IsPlayerConnected(playerid)) return 0;

    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT8, 6);
    BS_WriteValue(bs, PR_UINT16, playerid);
    BS_WriteValue(bs, PR_UINT8, value);
    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
    return 1;
}

stock CreateRentZone(Float:pickup_x, Float:pickup_y, Float:pickup_z, Float:park_coords[][4], park_count)
{
    if(TotalRentZones >= MAX_RENT_ZONES) return -1;

    new zone_id = TotalRentZones;

    RentZones[zone_id][RENT_PICKUP_X] = pickup_x;
    RentZones[zone_id][RENT_PICKUP_Y] = pickup_y;
    RentZones[zone_id][RENT_PICKUP_Z] = pickup_z;
    RentZones[zone_id][RENT_PARKING_COUNT] = park_count;

	CreatePickup(19131, 23, pickup_x, pickup_y, pickup_z, -1, PICKUP_ACTION_RENT_BIKE, zone_id);
	CreateDynamic3DTextLabel(
		"{FF5252}Управление транспортом\n"\
		"{DCDCDC}[ Подойдите для взаимодействия ]",
		-1, pickup_x, pickup_y, pickup_z + 0.7, 10.0
	);

    for(new i = 0; i < park_count; i++)
    {
        ParkingSlots[zone_id][i][PARKING_X] = park_coords[i][0];
        ParkingSlots[zone_id][i][PARKING_Y] = park_coords[i][1];
        ParkingSlots[zone_id][i][PARKING_Z] = park_coords[i][2];
        ParkingSlots[zone_id][i][PARKING_A] = park_coords[i][3];
        ParkingSlots[zone_id][i][PARKING_BUSY] = false;
        ParkingSlots[zone_id][i][PARKING_VEHICLE] = INVALID_VEHICLE_ID;
    }

    TotalRentZones++;

    return zone_id;
}
