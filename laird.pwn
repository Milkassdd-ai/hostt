                JSON_SetString(JSONObject, "n", "Пополните счет чтобы купить!");

				SendPacketToClient(playerid, 22, JSONObject);
                return 1;
            }

            GivePlayerDonateRub(playerid, -price, "Покупка 4-значной SIM-карты", true, true);

            Inventory_AddSIM(playerid, freeSlot, number);

            format(query, sizeof query, "Вы успешно приобрели SIM-карту с номером {0099FF}%d", number);
            new Node:JSONObject = JSON_Object();

			JSON_SetInt(JSONObject, "t", 0);
			JSON_SetInt(JSONObject, "y", 1);

			JSON_SetString(JSONObject, "m", query);
