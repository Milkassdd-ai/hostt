            new query[256];
            new rows;
            new Cache: result;

            mysql_format(mysql, query, sizeof query, "SELECT id FROM accounts WHERE phone=%d", number);
            result = mysql_query(mysql, query, true);
            rows = cache_num_rows();
            cache_delete(result);

            if(rows)
            {
                new Node:JSONObject = JSON_Object();

				JSON_SetInt(JSONObject, "t", 0);
