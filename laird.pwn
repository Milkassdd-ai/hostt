                return 1;
            }

            mysql_format(mysql, query, sizeof query,
                "SELECT id FROM `player_inventory` WHERE `item_id` = 58 AND `item_count` = %d AND `is_active` = 0 LIMIT 1",
                number);
            result = mysql_query(mysql, query, true);
            rows = cache_num_rows();
            cache_delete(result);

            if(rows)
            {
                new Node:JSONObject = JSON_Object();

				JSON_SetInt(JSONObject, "t", 0);
