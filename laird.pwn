case DIALOG_RENT_BIKE:
{
    if(response)
    {
        switch(listitem)
        {
case 0:
{
    if(GetPlayerData(playerid, P_RENT_BIKE) != INVALID_VEHICLE_ID)
    {
        if(IsValidVehicle(GetPlayerData(playerid, P_RENT_BIKE)))
            return ShowNotificationSile(playerid, 2, 4, 0, 0, "Вы уже арендовали скутер!", " ");

        RemoveRentBike(playerid);
    }

    new zone_id = GetPVarInt(playerid, "rent_zone_id");
    if(zone_id < 0 || zone_id >= TotalRentZones)
        return ShowNotificationSile(playerid, 2, 4, 0, 0, "Подойдите к парковке для аренды транспорта!", " ");

    new slot_id = GetFreeParkingSlot(zone_id);
    new bool:use_parking_slot = (slot_id != -1);
    new Float:spawn_x, Float:spawn_y, Float:spawn_z, Float:spawn_a;

    if(use_parking_slot)
    {
        spawn_x = ParkingSlots[zone_id][slot_id][PARKING_X];
        spawn_y = ParkingSlots[zone_id][slot_id][PARKING_Y];
        spawn_z = ParkingSlots[zone_id][slot_id][PARKING_Z];
        spawn_a = ParkingSlots[zone_id][slot_id][PARKING_A];
    }
    else
    {
        GetPlayerPos(playerid, spawn_x, spawn_y, spawn_z);
        GetPlayerFacingAngle(playerid, spawn_a);
        spawn_x += 4.0 * floatsin(-spawn_a, degrees);
        spawn_y += 4.0 * floatcos(-spawn_a, degrees);
    }

    if(GetPlayerMoneyEx(playerid) < 50)
        return ShowNotificationSile(playerid, 2, 4, 0, 0, "У вас недостаточно средств для аренды!", " ");

    GivePlayerMoneyEx(playerid, -50, "Аренда скутера", true);

    new vehicleid = CreateVehicle(
        462,
        spawn_x,
        spawn_y,
        spawn_z,
        spawn_a,
        0, 0, 300, 0,
        VEHICLE_ACTION_TYPE_RENT_BIKE
    );

    if(vehicleid == INVALID_VEHICLE_ID)
    {
        GivePlayerMoneyEx(playerid, 50, "Возврат за ошибку", true);
        return ShowNotificationSile(playerid, 2, 4, 0, 0, "Ошибка создания транспорта!", " ");
    }

    if(use_parking_slot)
    {
        OccupyParking(zone_id, slot_id, vehicleid);
        SetPVarInt(playerid, "scooter_zone", zone_id);
        SetPVarInt(playerid, "scooter_slot", slot_id);
    }
    else
    {
        DeletePVar(playerid, "scooter_zone");
        DeletePVar(playerid, "scooter_slot");
    }

    SetPlayerData(playerid, P_RENT_BIKE, vehicleid);
    SetTimerEx("DelayedSpawnAndEngine", 200, false, "ii", playerid, vehicleid);
    return 1;
}

            default:
            {
                if(GetPlayerOwnableCar(playerid) != INVALID_VEHICLE_ID)
                    return SendClientMessage(playerid, -1, ""USC" У вас уже загружено личное авто!");

                new zone_id = GetPVarInt(playerid, "rent_zone_id");
                if(zone_id < 0 || zone_id >= TotalRentZones)
                    return ShowNotificationSile(playerid, 2, 4, 0, 0, "Подойдите к парковке для аренды транспорта!", " ");

                new idx = GetPlayerListitemValue(playerid, listitem);

                SetPVarInt(playerid, "car_zone", zone_id);
                DeletePVar(playerid, "car_slot");

                ShowOwnableCarLoadDialog(playerid, idx, false, true);
            }
        }
    }
    return 1;
}
case DIALOG_ORG_CAR_GET:
{
    if(!response) return 1;
    new action_id = GetPlayerListitemValue(playerid, 0);
    new vehicle_index = listitem;

    new modelid = g_org_car[action_id][O_MODEL][vehicle_index];
    new color1 = g_org_car[action_id][O_COLOR][vehicle_index];
    new color2 = 0;
    new numt = g_org_car[action_id][O_NUMTYPE];
    new migal = g_org_car[action_id][O_MIGAL][vehicle_index];
    new siren = g_org_car[action_id][O_SIREN][vehicle_index];

    new buy_cars_count = g_org_car[action_id][O_COUNT]++;
    if(buy_cars_count >= 4) g_org_car[action_id][O_COUNT] = 0;

    new Float: pos_x = org_car_pos_spawn[action_id][buy_cars_count][0];
    new Float: pos_y = org_car_pos_spawn[action_id][buy_cars_count][1];
    new Float: pos_z = org_car_pos_spawn[action_id][buy_cars_count][2];
    new Float: angle = org_car_pos_spawn[action_id][buy_cars_count][3];

    new vehicleid = CreateVehicle(
        modelid, pos_x, pos_y, pos_z, angle,
        color1, color2, 120, 0,
        VEHICLE_ACTION_ORG_CAR,
        g_org_car[action_id][O_FRAC_ID]
    );

    if(vehicleid == INVALID_VEHICLE_ID)
    {
        SendClientMessage(playerid, -1, ""SC"Ошибка создания транспорта!");
        return 1;
    }
    new plate[32];
	RandomNumberPlate(numt, plate, sizeof(plate));
	SetVehicleNumberPlateEx(vehicleid, numt, plate, "52");
    ApplyOrgVinylToVehicle(vehicleid, action_id, vehicle_index);
    if(migal != 0)
    {
   	SetVehicleCarMod(vehicleid, 0, migal, 1);
    }
    SetVehicleSiren(vehicleid, siren, 1);
    
    SetVehicleData(vehicleid, V_ACTION_OWNER, playerid);
    SetPlayerData(playerid, P_FRACTION_CAR, vehicleid);
    PutPlayerInVehicle(playerid, vehicleid, 0);

    new model_name[64];
    GetVehicleModelName(modelid, model_name, sizeof(model_name));
    new fmt_text[128];
    format(fmt_text, sizeof(fmt_text), ""SC"Вы взяли транспорт: %s", model_name);
    SendClientMessage(playerid, -1, fmt_text);

    return 1;
}
