        if(IsPlayerInRangeOfPoint(playerid, 4.0, ContBuyTextPos[cont-1][0], ContBuyTextPos[cont-1][1], ContBuyTextPos[cont-1][2]) && cInfo[cont][Saled] == false)
        {
