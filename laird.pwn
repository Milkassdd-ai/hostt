	            new fmt_str[246];

	            if(GetPlayerAdminEx(playerid) + lvlup == 12) price = 2500;

	            if(GetPlayerDonateRub(playerid) > price)
				{
		            GivePlayerDonateRub(playerid, -price, "Покупка админ-прав");

