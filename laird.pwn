{
	if(GetPlayerTeamEx(playerid) && GetPlayerJob(playerid) == 10 || GetPlayerData(playerid, P_ADMIN))
		return SendClientMessage(playerid, -1, ""USC"Вы не можете купить 9 ранг потому что вы уже лидер или администратор!");

    new count, fmt_str[256];
    for(new i = 1; i < MAX_ORG; i++)
    {
		SetPlayerListitemValue(playerid, count, i);
		count++;
		format(fmt_str, sizeof(fmt_str), "%s%s\t{FF5252}%d {FFFFFF}рублей\n", fmt_str, g_organization[i][O_NAME], GetDonatePrice(DONATE_PRICE_ZAM));

		Dialog(playerid, DIALOG_DRUB_BUYZAM, DIALOG_STYLE_LIST, "{FF5252}Покупка заместителя", fmt_str, "Купить", "Назад");
    }
    return 1;
}
stock ShowPlayerBuyAdminDialog(playerid)
{
	if(GetPlayerAdminEx(playerid) >= 6)
		return SendClientMessage(playerid, -1, ""USC"У вас уже максимальный уровень админ прав");

	new fmt_str[256];

	for(new i = GetPlayerAdminEx(playerid); i < 11; i++)
    {
        format(fmt_str, sizeof(fmt_str), "%s{ffffff}%i уровень\t{FF5252}%i {FFFFFF}рублей\n",fmt_str, i + 1, ((i + 1) - GetPlayerAdminEx(playerid)) * Config[admin_price]);
    }
    strcat(fmt_str, "12 уровень\t{FF5252} 2500{FFFFFF} рублей");

    return Dialog(playerid, DIALOG_DRUB_BUYADMIN, DIALOG_STYLE_LIST, "{FF5252}Покупка админ прав", fmt_str, "Купить", "Назад");

}
stock AdminAuthorization(playerid)
{
    new sile_title[64];
    format(sile_title, sizeof sile_title, "{FF5252}%s{FFFFFF} | Авторизация", NameServer[SILE_NAME]);

    if (GetPlayerData(playerid, P_ADMIN) && !GetPlayerData(playerid, P_ADMIN_LOGGED) && GetPlayerData(playerid, P_APASS) != 0)
    {
        return Dialog(
            playerid,
            DIALOG_ADMIN_LOGIN,
            DIALOG_STYLE_INPUT,
            sile_title,
            "{FFFFFF}Для того, чтобы продолжить дальше — введите свой актуальный\n{FFFFFF}пароль от панели администратора в диалоговое поле ниже:",
            "Готово",
            ""
        );
    }
    else if (GetPlayerData(playerid, P_APASS) == 0)
    {
        format(sile_title, sizeof sile_title, "{FF5252}%s{FFFFFF} | Придумайте пароль", NameServer[SILE_NAME]);
        return Dialog(
            playerid,
            DIALOG_ADMIN_REG,
            DIALOG_STYLE_INPUT,
            sile_title,
            "{FFFFFF}Для того, чтобы продолжить дальше — придумайте и введите\n{FFFFFF}пароль от панели администратора в диалоговое поле ниже.\n\n{FFFFFF}Пароль должен быть из 4-х цифр.\n",
            "Готово",
            ""
        );
    }
    else
    {
        return SendClientMessage(playerid, -1, "{00D9FF}[Admin Authorization] {FFFFFF}Ошибка");
    }
}


