            JSON_SetString(response, "n", "Недостаточно средств.");
            SendPacketToClient(playerid, 22, response);
            JSON_Cleanup(response);
        }
    }
}
	if(dialogid == 9500)
	{
     	if(!response) return 1;

	     switch(listitem)
         {
         case 0:
