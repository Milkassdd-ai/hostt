stock GetFreeParkingSlot(zone_id)
{
    if(zone_id < 0 || zone_id >= TotalRentZones) return -1;

    for(new i = 0; i < RentZones[zone_id][RENT_PARKING_COUNT]; i++)
    {
        if(!ParkingSlots[zone_id][i][PARKING_BUSY])
            return i;
    }
    return -1;
}

stock OccupyParking(zone_id, slot_id, vehicleid)
{
    if(zone_id < 0 || zone_id >= TotalRentZones) return 0;
    if(slot_id < 0 || slot_id >= MAX_PARKING_PER_ZONE) return 0;

    ParkingSlots[zone_id][slot_id][PARKING_BUSY] = true;
    ParkingSlots[zone_id][slot_id][PARKING_VEHICLE] = vehicleid;
    return 1;
}

stock FreeParking(zone_id, slot_id)
{
    if(zone_id < 0 || zone_id >= TotalRentZones) return 0;
    if(slot_id < 0 || slot_id >= MAX_PARKING_PER_ZONE) return 0;

    ParkingSlots[zone_id][slot_id][PARKING_BUSY] = false;
    ParkingSlots[zone_id][slot_id][PARKING_VEHICLE] = INVALID_VEHICLE_ID;
    return 1;
}

stock FindParkingByVehicle(vehicleid, &zone_id, &slot_id)
{
    for(new z = 0; z < TotalRentZones; z++)
    {
        for(new s = 0; s < RentZones[z][RENT_PARKING_COUNT]; s++)
        {
            if(ParkingSlots[z][s][PARKING_VEHICLE] == vehicleid)
            {
                zone_id = z;
                slot_id = s;
                return 1;
            }
        }
    }
    return 0;
}
CMD:parkinfo(playerid, params[])
{
    new info[128];
    format(info, sizeof(info), "Всего зон: %d", TotalRentZones);
    SendClientMessage(playerid, -1, info);

    for(new z = 0; z < TotalRentZones; z++)
    {
        new occupied = 0;
        for(new s = 0; s < RentZones[z][RENT_PARKING_COUNT]; s++)
        {
            if(ParkingSlots[z][s][PARKING_BUSY]) occupied++;
        }

        format(info, sizeof(info), "Зона %d: Мест: %d | Занято: %d | Свободно: %d",
            z, RentZones[z][RENT_PARKING_COUNT], occupied, RentZones[z][RENT_PARKING_COUNT] - occupied);
        SendClientMessage(playerid, -1, info);
    }
    return 1;
}

stock RemoveRentBike(playerid)
{
    new vehicleid = GetPlayerData(playerid, P_RENT_BIKE);

    if(vehicleid != INVALID_VEHICLE_ID)
    {

        new zone_id = GetPVarInt(playerid, "scooter_zone");
        new slot_id = GetPVarInt(playerid, "scooter_slot");

        if(zone_id >= 0 && slot_id >= 0)
        {
            FreeParking(zone_id, slot_id);
            DeletePVar(playerid, "scooter_zone");
            DeletePVar(playerid, "scooter_slot");
        }
        else
        {
            if(FindParkingByVehicle(vehicleid, zone_id, slot_id))
            {
                FreeParking(zone_id, slot_id);
            }

            DeletePVar(playerid, "scooter_zone");
            DeletePVar(playerid, "scooter_slot");
        }

        DestroyVehicle(vehicleid);
        SetPlayerData(playerid, P_RENT_BIKE, INVALID_VEHICLE_ID);
    }
    return 1;
}

stock ShowDialogGZ(playerid)
{
    Dialog
    (
        playerid, -1, DIALOG_STYLE_MSGBOX,
        ""c_green"Зелёная зона",
        "{FFFFFF}Вы находитесь в зелёной зоне!\n"\
        "{FFFFFF}Нанесение урона в зелёной зоне запрещено.",
        "Ок", ""
    );
    ClearAnimations(playerid);
}
stock SetPlayerGPSWithoutLine(playerid, markertype, Float: x, Float: y, Float: z, message[] = "Метка отмечена на мини карте")
{
    SetPlayerGPSInfo(playerid, G_POS_X, x);
    SetPlayerGPSInfo(playerid, G_POS_Y, y);
    SetPlayerGPSInfo(playerid, G_POS_Z, z);

    SetPlayerCheckpoint(playerid, x, y, z, 3.0, CP_ACTION_TYPE_GPS);
    ShowGPS(playerid);

    if(strlen(message))
        SendClientMessage(playerid, 0xFF5252FF, message);

    SetPlayerGPSInfo(playerid, G_ENABLED, GPS_STATUS_ON);

    return 1;
}

stock DrawGPSLineForPlayer(playerid, Float:x1, Float:y1, Float:z1, Float:x2, Float:y2, Float:z2)
{
    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT8, 26);
    BS_WriteValue(bs, PR_FLOAT, x1);
    BS_WriteValue(bs, PR_FLOAT, y1);
    BS_WriteValue(bs, PR_FLOAT, z1);
    BS_WriteValue(bs, PR_FLOAT, x2);
    BS_WriteValue(bs, PR_FLOAT, y2);
    BS_WriteValue(bs, PR_FLOAT, z2);
    BS_WriteValue(bs, PR_UINT32, 0xFFFF5252FF);
    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);

    SetPlayerGPSWithoutLine(playerid, 55, x1, y1, z1, "");
}
stock PlayerToPoint(Float:radi, playerid, Float:x, Float:y, Float:z)
{
    if(IsPlayerConnected(playerid))
        {
                new Float:oldposx;
                new Float:oldposy;
                new Float:oldposz;
                new Float:tempposx;
                new Float:tempposy;
                new Float:tempposz;
                GetPlayerPos(playerid, oldposx, oldposy, oldposz);
                tempposx = (oldposx -x);
                tempposy = (oldposy -y);
                tempposz = (oldposz -z);
                if(((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi))) return true;
        }
        return false;
}
