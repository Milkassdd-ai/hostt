stock ShowLarekGUI(playerid)
{
    new Node:json = JSON_Object();
    JSON_SetInt(json, "o", 1);
    JSON_SetInt(json, "m", GetPlayerMoneyEx(playerid));
    JSON_SetInt(json, "satiety", player_satiety[playerid]);
    ShowPlayerGUI(playerid, 3, json);
    JSON_Cleanup(json);
    return 1;
}
stock bool:ProcessLarekPurchase(playerid, order_mask, bool:reopen_gui = false)
{
    new eats_price[6] = {120, 230, 320, 580, 80, 30};
    new eats_satiety[6] = {5, 10, 15, 20, 3, 2};
    new eats_products[6] = {1, 1, 1, 1, 1, 1};

    new total_cost, total_satiety, total_products;

    for(new i = 0; i < 6; i++)
    {
        if(order_mask & (1 << i))
        {
            total_cost += eats_price[i];
            total_satiety += eats_satiety[i];
            total_products += eats_products[i];
        }
    }

    if(total_cost <= 0)
    {
        return false;
    }

    if(GetPlayerMoneyEx(playerid) < total_cost)
    {
        ShowNotificationSile(playerid, 2, 7, -1, -1, "Недостаточно средств!", "");
        return false;
    }

    new businessid = GetPlayerInBiz(playerid);
    new query[512];
	if(GetBusinessData(businessid, B_PRODS) >= total_products)
    {
        format(query, sizeof(query),
            "UPDATE accounts a, business b SET a.money=%d, b.products=%d, b.balance=%d WHERE a.id=%d AND b.id=%d",
            GetPlayerMoneyEx(playerid) - total_cost,
            GetBusinessData(businessid, B_PRODS) - total_products,
            GetBusinessData(businessid, B_BALANCE) + total_cost,
            GetPlayerAccountID(playerid),
            GetBusinessData(businessid, B_SQL_ID)
        );
    }
    else
    {
        format(query, sizeof(query),
            "UPDATE accounts SET money=%d WHERE id=%d LIMIT 1",
            GetPlayerMoneyEx(playerid) - total_cost,
            GetPlayerAccountID(playerid)
        );
    }
    mysql_query(mysql, query, false);

    if(!mysql_errno())
    {
        if(GetBusinessData(businessid, B_PRODS) >= total_products)
        {
            AddBusinessData(businessid, B_PRODS, -, total_products);
            AddBusinessData(businessid, B_BALANCE, +, total_cost);

            mysql_format(mysql, query, sizeof(query),
                "INSERT INTO business_profit (bid,uid,uip,time,money,view) VALUES (%d,%d,'%e',%d,%d,%d)",
                GetBusinessData(businessid, B_SQL_ID),
                GetPlayerAccountID(playerid),
                GetPlayerIpEx(playerid),
                gettime(),
                total_cost,
                IsBusinessOwned(businessid)
            );
            mysql_query(mysql, query, false);
        }

        GivePlayerMoneyEx(playerid, -total_cost, "Покупка в ларьке", true, true);

        player_satiety[playerid] += total_satiety;
        if(player_satiety[playerid] > 100)
            player_satiety[playerid] = 100;

        UpdatePlayerDatabaseInt(playerid, "satiety", player_satiety[playerid]);

        new message[128];
        format(message, sizeof(message), "\xC2\xFB\x20\xEA\xF3\xEF\xE8\xEB\xE8\x20\xEF\xEE\xEA\xF3\xF8\xE0\xF2\xFC\x2E\x20\xC2\xE0\xF8\xE0\x20\xF1\xFB\xF2\xED\xEE\xF1\xF2\xFC\x20\xEF\xEE\xE2\xFB\xF8\xE5\xED\xE0");
        ShowNotificationSile(playerid, 3, 6, 0, 0, message, "");

        if(reopen_gui)
            ShowLarekGUI(playerid);

        return true;
    }
    else
    {
        SendClientMessage(playerid, 0xFF6600FF, "Ошибка сохранения, повторите попытку {FF0000}(larek-code 1)");
        return false;
    }
}

