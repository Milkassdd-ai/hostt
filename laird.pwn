			case DIALOG_GPS_MISTS:
			{
				if(response)
				{
					switch(listitem)
					{
					case 0:
					{
						new fmt_str[128];
						new station_name[64];
						new stationid;
						new Float: dist;

						stationid = GetNearestFuelStation(playerid, 0.0);
						dist = GetPlayerDistanceFromPoint(playerid, GetFuelStationData(stationid, FS_POS_X), GetFuelStationData(stationid, FS_POS_Y), GetFuelStationData(stationid, FS_POS_Z));

						format(station_name, sizeof(station_name), "%s", GetFuelStationData(stationid, FS_NAME));

						if(strlen(station_name) < 1)
							format(station_name, sizeof(station_name), "АЗС №%d", stationid);

						EnablePlayerGPS
						(
							playerid,
							47,
							GetFuelStationData(stationid, FS_POS_X),
							GetFuelStationData(stationid, FS_POS_Y),
							GetFuelStationData(stationid, FS_POS_Z),
							""
						);

						format(fmt_str, sizeof fmt_str, "Ближе всех к Вам находится {FF5252}%s {FFFFFF}(расстояние {FF5252}%.1f м{FFFFFF})", station_name, dist);
						SendClientMessage(playerid, -1, fmt_str);

						ShowNotificationSile(playerid, 3, 6, 0, 0, "Место отмечено у Вас на GPS.", " ");
					}

					case 1:
					{
						new fmt_str[128];
						new biz_name[64];
						new biz_id;
						new Float: dist;

						biz_id = GetNearestBiz(playerid, BUSINESS_TYPE_SHOP_24_7, 0.0);
						dist = GetPlayerDistanceFromPoint(playerid, GetBusinessData(biz_id, B_POS_X), GetBusinessData(biz_id, B_POS_Y), GetBusinessData(biz_id, B_POS_Z));

						format(biz_name, sizeof(biz_name), "%s", GetBusinessInteriorInfo(GetBusinessData(biz_id, B_INTERIOR), BT_NAME));

						EnablePlayerGPS
						(
							playerid,
							23,
							GetBusinessData(biz_id, B_POS_X),
							GetBusinessData(biz_id, B_POS_Y),
							GetBusinessData(biz_id, B_POS_Z),
							""
						);

						format(fmt_str, sizeof fmt_str, "Ближе всех к Вам находится {FF5252}%s {FFFFFF}(расстояние {FF5252}%.1f м{FFFFFF})", biz_name, dist);
						SendClientMessage(playerid, -1, fmt_str);

						ShowNotificationSile(playerid, 3, 6, 0, 0, "Место отмечено у Вас на GPS.", " ");
					}

					case 2:
					{
						new fmt_str[128];
						new biz_name[64];
						new biz_id;
						new Float: dist;

						biz_id = GetNearestBiz(playerid, BUSINESS_TYPE_CLOTHING_SHOP, 0.0);
						dist = GetPlayerDistanceFromPoint(playerid, GetBusinessData(biz_id, B_POS_X), GetBusinessData(biz_id, B_POS_Y), GetBusinessData(biz_id, B_POS_Z));

						format(biz_name, sizeof(biz_name), "%s", GetBusinessInteriorInfo(GetBusinessData(biz_id, B_INTERIOR), BT_NAME));

						EnablePlayerGPS
						(
							playerid,
							45,
							GetBusinessData(biz_id, B_POS_X),
							GetBusinessData(biz_id, B_POS_Y),
							GetBusinessData(biz_id, B_POS_Z),
							""
						);

						format(fmt_str, sizeof fmt_str, "Ближе всех к Вам находится {FF5252}%s {FFFFFF}(расстояние {FF5252}%.1f м{FFFFFF})", biz_name, dist);
						SendClientMessage(playerid, -1, fmt_str);

						ShowNotificationSile(playerid, 3, 6, 0, 0, "Место отмечено у Вас на GPS.", " ");
					}

					case 3:
					{
						new fmt_str[128];
						new biz_name[64];
						new biz_id;
						new Float: dist;

						biz_id = GetNearestBiz(playerid, BUSINESS_TYPE_SHOP_GUN, 0.0);
						dist = GetPlayerDistanceFromPoint(playerid, GetBusinessData(biz_id, B_POS_X), GetBusinessData(biz_id, B_POS_Y), GetBusinessData(biz_id, B_POS_Z));

						format(biz_name, sizeof(biz_name), "%s", GetBusinessInteriorInfo(GetBusinessData(biz_id, B_INTERIOR), BT_NAME));

