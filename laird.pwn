							Примеры: AFK\n\
                            {FF0000}Укажите причину (минимум 3 символа).",
						   "Далее", "Закрыть");
           }

           new fmt_msg[128];
		   format(fmt_msg, sizeof fmt_msg, "Администратор: %s кикнул игрока %s. Причина: %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), inputtext);

		   SendClientMessageToAll(0xFF5533FF, fmt_msg);

	       format(fmt_msg, sizeof fmt_msg, "Кикнул %s[acc:%d]", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player));
	       SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	      Kick(to_player);
     	HidePlayerGUI(playerid, 66);
	}
	if(dialogid == DIALOG_MUTE_SPEC)
	{
		   utf8_to_cp1251(inputtext);
	       if(!response) return 1;

	       new to_player = GetPlayerSpectateData(playerid, S_PLAYER);
	       if(to_player == -1 || !IsPlayerConnected(to_player))
	       {
	               SendClientMessage(playerid, -1,  "Игрок не найден");
	               return 1;
	       }

	       if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя выдать мут администратору выше по рангу");

			new mute_time, prichina[32];

  		 if(sscanf(inputtext, "is[32]", mute_time, prichina))
	     {
     		  ShowPlayerDialog(playerid, DIALOG_MUTE_SPEC, DIALOG_STYLE_INPUT, "{FFCC00}Lonexs Test | {FFFFFF}Мут игрока",
      	     "Введите время и причину мута\n\
          	 \n\
         	  Время указывается в минутах\n\
      	     Причина должна содержать минимум 5 символов\n\
    	       \n\
       	    Пример: 30 Оскорбление",
    	       "Выбрать", "Отмена");

 		      return 1;
	   }

    if(!(10 <= mute_time <= 360))
    {
        SendClientMessage(playerid, -1, "Время мута должно быть не менее 10 минут и не более 360 минут");
        return 1;
    }

    if(strlen(prichina) < 5)
    {
        SendClientMessage(playerid, -1, "Причина должна содержать минимум 5 символов");
        return 1;
    }

          new fmt_msg[128];
	      format(fmt_msg, sizeof fmt_msg, "Администратор: %s выдал мут игроку %s на %d мин. Причина: %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), mute_time, prichina);

           SendClientMessageToAll(0xFF5533FF, fmt_msg);

	SetPlayerData(to_player, P_MUTE, mute_time * 60);
	UpdatePlayerDatabaseInt(to_player, "mute", mute_time * 60);

	SendClientMessage(to_player, 0xCECECEFF, "Время до окончания бана чата: {CCCC00}/time");

	format(fmt_msg, sizeof fmt_msg, "Выдал %s[acc:%d] мут на %d мин. Причина: %s",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), mute_time, prichina);

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	}
	if(dialogid == DIALOG_JAIL_SPEC)
	{
		   utf8_to_cp1251(inputtext);
	       if(!response) return 1;

	       new to_player = GetPlayerSpectateData(playerid, S_PLAYER);
	       if(to_player == -1 || !IsPlayerConnected(to_player))
	       {
	               SendClientMessage(playerid, -1,  "Игрок не найден");
	               return 1;
	       }

	       if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя посадить администратора выше по рангу");

			new jail_time, prichina[32];

  		 if(sscanf(inputtext, "is[32]", jail_time, prichina))
	     {
     		  ShowPlayerDialog(playerid, DIALOG_JAIL_SPEC, DIALOG_STYLE_INPUT, "{FFCC00}Lonexs Test | {FFFFFF}Деморган игрока",
      	     "Введите время заключения и причину\n\
          	 \n\
         	  Время указывается в минутах\n\
      	     Причина должна содержать минимум 5 символов\n\
    	       \n\
       	    Пример: 60 Death-Match(DM)",
    	       "Выбрать", "Отмена");

 		      return 1;
	   }

    if(!(10 <= jail_time <= 360))
    {
        SendClientMessage(playerid, -1, "Время должно быть не менее 10 минут и не более 360 минут");
        return 1;
    }

    if(strlen(prichina) < 5)
    {
        SendClientMessage(playerid, -1, "Причина должна содержать минимум 5 символов");
        return 1;
    }

          new fmt_msg[128];
	      format(fmt_msg, sizeof fmt_msg, "Администратор: %s посадил в деморган игрока %s на %d мин. Причина: %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), jail_time, prichina);

           SendClientMessageToAll(0xFF5533FF, fmt_msg);

	JailPlayer(to_player, jail_time);

	SendClientMessage(to_player, 0xCECECEFF, "Время до конца заключения: {CCCC00}/time");

	format(fmt_msg, sizeof fmt_msg, "Посадил %s[acc:%d] в деморган на %d мин. Причина: %s",
	GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), jail_time, prichina);

	SendLog(playerid, LOG_TYPE_ADMIN_ACTION, fmt_msg);

	}
	   if(dialogid == DIALOG_WARN_SPEC)
	{
		  utf8_to_cp1251(inputtext);
	       if(!response) return 1;

	       new to_player = GetPlayerSpectateData(playerid, S_PLAYER);
	       if(to_player == -1 || !IsPlayerConnected(to_player))
	       {
	               SendClientMessage(playerid, -1,  "Игрок не найден");
	               return 1;
	       }

			if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя выдать предупреждение администратору выше по рангу");

           if(strlen(inputtext) < 3)
           {
                  ShowPlayerDialog(playerid, DIALOG_KICK_SPEC, DIALOG_STYLE_INPUT, "{ffcc00}Lonexs Test | {FFFFFF}Варн игроку",
						   "Укажите причину выдачи варна\n\
							Обязательно укажите причину (минимум 3 символа)\n\
							\n\
							Примеры: \n\
                            {FF0000}Укажите причину (минимум 3 символа).",
						   "Далее", "Закрыть");
           }

           AddPlayerData(to_player, P_WARN, +, 1);
	SetPlayerData(to_player, P_WARN_TIME, gettime() + (86400 * 10));

	new fmt_msg[128];
	format(fmt_msg, sizeof fmt_msg, "Администратор: %s выдал предупреждение игроку %s [%d|3]. Причина: %s", GetPlayerNameEx(playerid), GetPlayerNameEx(to_player), GetPlayerData(to_player, P_WARN), inputtext);

	SendClientMessageToAll(0xFF5533FF, fmt_msg);

	InvitePlayer(to_player, 0, 0, true);

	new uid = GetPlayerAccountID(to_player);
	new warns = GetPlayerData(to_player, P_WARN);
	new warns_time = GetPlayerData(to_player, P_WARN_TIME);

