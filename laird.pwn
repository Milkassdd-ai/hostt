								"Введите количество доната которое будет выдаваться при регистрации\n\
								\tПримечание: Нельзя меньше 0 и больше 20000!",
								"Далее", "Отмена"
							);
						}
						case 7:
						{
							Dialog
							(
								playerid, DIALOG_SERVER_SETTINGS_BONUSL, DIALOG_STYLE_INPUT,
								"Управление сервером",
