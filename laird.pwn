        UpdateReportText();

        new fmt_text[200];
        format(fmt_text, sizeof fmt_text, "{008000}[R] Жалоба от %s[%d]: {FF5252}%s", GetPlayerNameEx(playerid), playerid, inputtext);
        SendMessageToAdmins(fmt_text, 0xFFFFFFFF);

        SendClientMessage(playerid, -1, "{FF5252}| {FFFFFF}Ваша жалоба была отправлена администрации сервера, ожидайте ответа.");
