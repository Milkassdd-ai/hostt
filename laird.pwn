stock SyncVehicleTuningForPlayer(playerid, vehicleid)
{
    if(vInfo[vehicleid][vNeon1] || vInfo[vehicleid][vNeon2] || vInfo[vehicleid][vNeon3])
    {
        SetVehicleNeonForPlayer(playerid, vehicleid,
            vInfo[vehicleid][vNeon1],
            vInfo[vehicleid][vNeon2],
            vInfo[vehicleid][vNeon3]
        );
    }
    if(vInfo[vehicleid][vTint] > 0)
    {
        SetVehicleTintForPlayer(playerid, vehicleid, vInfo[vehicleid][vTint]);
    }
    if(strlen(vInfo[vehicleid][viVinylTexture]) > 0)
    {
        SetVehicleVinylForPlayer(playerid, vehicleid, vInfo[vehicleid][viVinylTexture]);
    }

    if(vInfo[vehicleid][viTonerFront] || vInfo[vehicleid][viTonerRear])
    {
        SetVehicleTonerForPlayer(playerid, vehicleid,
            vInfo[vehicleid][viTonerFront],
            vInfo[vehicleid][viTonerRear],
            vInfo[vehicleid][viTonerFrontSide],
            vInfo[vehicleid][viTonerRearSide]
        );
    }
    if(vInfo[vehicleid][vSuspensionForce] != 0)
    {
        SetVehicleSuspensionForceForPlayer(playerid, vehicleid, vInfo[vehicleid][vSuspensionForce]);
    }
    if(vInfo[vehicleid][vCarMod] > 0)
    {
        SendCarMod(playerid, vInfo[vehicleid][vCarModParam], vehicleid, vInfo[vehicleid][vCarMod]);
    }

    if(vInfo[vehicleid][vSuspensionBias] != 0)
    {
        SetVehicleSuspensionBiasForPlayer(playerid, vehicleid, vInfo[vehicleid][vSuspensionBias]);
    }
    if(vInfo[vehicleid][vWheelSize] != 0)
    {
        SetVehicleWheelSizeForPlayer(playerid, vehicleid, vInfo[vehicleid][vWheelSize]);
    }

    if(vInfo[vehicleid][vWheelAddFront] || vInfo[vehicleid][vWheelAddRear])
    {
        SetVehicleWheelAdditiveForPlayer(playerid, vehicleid,
            vInfo[vehicleid][vWheelAddFront],
            vInfo[vehicleid][vWheelAddRear]
        );
	}
    if(vInfo[vehicleid][viHydraulics] > 0)
    {
        SetVehicleHydraulicsForPlayer(playerid, vehicleid, vInfo[vehicleid][viHydraulics]);
    }

    if(vInfo[vehicleid][viLaunchControl] > 0)
    {
        SetVehicleLaunchControlFP(playerid, vehicleid, vInfo[vehicleid][viLaunchControl]);
    }

    if(vInfo[vehicleid][viStrob] > 0)
    {
        SetVehicleStroboscopeForPlayer(playerid, vehicleid, vInfo[vehicleid][viStrob]);
    }

    if(vInfo[vehicleid][viSiren] > 0)
    {
        SetVehicleSirenForPlayer(playerid, vehicleid, vInfo[vehicleid][viSiren]);
    }

    new index = GetVehicleData(vehicleid, V_ACTION_ID);
    if(index != -1 && GetVehicleData(vehicleid, V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_OWNABLE_CAR)
    {
        if(g_ownable_car[index][OC_NUMBER_TYPE] != 0)
        {
            SetVehicleNumberPlateForPlayer(playerid, vehicleid,
                g_ownable_car[index][OC_NUMBER_TYPE],
                g_ownable_car[index][OC_NUMBER],
                g_ownable_car[index][OC_REGION]
            );
        }
    }
    else if(index != -1 && GetVehicleData(vehicleid, V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_FAMILY_CAR)
{
    if(index >= 0 && index < MAX_OWNABLE_CARS)
    {
        if(vehicle_family[index][V_F_NUMBER_TYPE] != 0)
        {
            SetVehicleNumberPlateForPlayer(playerid, vehicleid,
                vehicle_family[index][V_F_NUMBER_TYPE],
                vehicle_family[index][V_F_NUMBER],
                vehicle_family[index][V_F_REGION]
            );
        }
    }
    else
    {
        printf("[ERROR] Невалидный индекс семейного ТС %d (max: %d)", index, MAX_OWNABLE_CARS);
    }
}
    else
    {
        if(vNumber[vehicleid][npType] > 0)
        {
            SetVehicleNumberPlateForPlayer(playerid, vehicleid,
                vNumber[vehicleid][npType],
                vNumber[vehicleid][npNumber],
                vNumber[vehicleid][npRegion]
            );
        }
    }
}
public OnVehicleStreamIn(vehicleid, forplayerid)
{
	SyncVehicleTuningForPlayer(forplayerid, vehicleid);
    Iter_Add(streamed_players_in_veh[vehicleid], forplayerid);
	Iter_Add(vehicle_in_stream[forplayerid], vehicleid);

	sc_OnVehicleStreamIn(vehicleid, forplayerid);
	return 1;
}

public OnVehicleStreamOut(vehicleid, forplayerid)
{
	sc_OnVehicleStreamIn(vehicleid, forplayerid);

	Iter_Remove(streamed_players_in_veh[vehicleid], forplayerid);
	Iter_Remove(vehicle_in_stream[forplayerid], vehicleid);
	return 1;
}

public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	if(dialogid == 19999)
	{
	    if(response)
	    {
	        if(pBJInfo[playerid][OnLobby])
	        {
 				new str[128];
				new bet;
	            if(sscanf(inputtext,"d",bet))
	            {
	                SCM(playerid, COLOR_RED, "| "c_white"Введите ставку на которую хотите сыграть!");
	                SPD(playerid, 19999, DSI, "{00FFFF}BlackJack", "Введите сумму на которую хотите сыграть: (Минимально 1000 рублей, Максимально 500000 рублей.)", "Играть", "Закрыть");
	                return 0;
	            }
	            if(!(999 < bet < 5000001))
	            {
	                SCM(playerid, COLOR_RED, "| "c_white"Минимально 1000 рублей, Максимально 500000 рублей.");
	                SPD(playerid, 19999, DSI, "{00FFFF}BlackJack", "Введите сумму на которую хотите сыграть: (Минимально 1000 рублей, Максимально 500000 рублей.)", "Играть", "Закрыть");
	                return 0;
	            }
	            if(GetPlayerMoneyEx(playerid) < bet)
	            {
	                SCM(playerid, COLOR_RED, "| "c_white"У вас недостаточно средств.");
	                SPD(playerid, 19999, DSI, "{00FFFF}BlackJack", "Введите сумму на которую хотите сыграть: (Минимально 1000 рублей, Максимально 500000 рублей.)", "Играть", "Закрыть");
	                return 0;
	            }

				format(str, sizeof str, "%d руb", bet);
				PlayerTextDrawShow(playerid, bj_bet[playerid]);
				PlayerTextDrawSetString(playerid, bj_bet[playerid], str);
				pBJInfo[playerid][pBJBet] = bet;
				//SCM(playerid, CYELLOW, "| "c_white"Вы поставили ставку.");

				new lobby = pBJInfo[playerid][pBJLobby];

				new str2[] = "READY";
				utf8_to_cp1251(str2);
				TextDrawSetString(bj_table_ready[lobby][pBJInfo[playerid][pBJTable]], str2);
				TextDrawColor(bj_table_ready[lobby][pBJInfo[playerid][pBJTable]], 0x00FF00FF);

				if(BlackJackLobby[lobby][Table1Id] < 1000) TextDrawShowForPlayer(BlackJackLobby[lobby][Table1Id], bj_table_ready[lobby][pBJInfo[playerid][pBJTable]]);
				if(BlackJackLobby[lobby][Table2Id] < 1000) TextDrawShowForPlayer(BlackJackLobby[lobby][Table2Id], bj_table_ready[lobby][pBJInfo[playerid][pBJTable]]);
				if(BlackJackLobby[lobby][Table3Id] < 1000) TextDrawShowForPlayer(BlackJackLobby[lobby][Table3Id], bj_table_ready[lobby][pBJInfo[playerid][pBJTable]]);
				if(BlackJackLobby[lobby][Table4Id] < 1000) TextDrawShowForPlayer(BlackJackLobby[lobby][Table4Id], bj_table_ready[lobby][pBJInfo[playerid][pBJTable]]);

				TextDrawShowForPlayer(playerid, bj_text_bet[0]);
				TextDrawShowForPlayer(playerid, bj_text_bet[1]);
				SetTimerEx("TimerHideBetText", 3000, false, "d", playerid);
			}
		}
	}    
	if(dialogid == DIALOG_RESTART)
    {
        if(!response) return 1;

        new minutes = 0;

        switch(listitem)
        {
            case 0:
            {
                minutes = 0;
                StartRestartImmediately(playerid);
                return 1;
            }
            case 1:
            {
                minutes = 1;
                StartRestartTimer(playerid, minutes);
            }
            case 2:
            {
                minutes = 5;
                StartRestartTimer(playerid, minutes);
            }
            case 3:
            {
                minutes = 10;
                StartRestartTimer(playerid, minutes);
            }
            case 4:
            {
                ShowPlayerDialog(playerid, DIALOG_RESTART_CUSTOM, DIALOG_STYLE_INPUT,
                                "Введите время до рестарта",
                                "Введите количество минут до рестарта (от 1 до 60):",
                                "Запустить", "Назад");
                return 1;
            }
        }
        return 1;
    }
     if(dialogid == DIALOG_RESTART_CUSTOM)
    {
        if(!response)
        {
            ShowRestartDialog(playerid);
            return 1;
        }

        new minutes = strval(inputtext);
        if(minutes < 1 || minutes > 60)
        {
            ShowNotificationSile(playerid, 2, 7, -1, -1, "Время должно быть от 1 до 60 минут.", "");
            ShowPlayerDialog(playerid, DIALOG_RESTART_CUSTOM, DIALOG_STYLE_INPUT,
                            "Введите время до рестарта",
                            "Введите количество минут до рестарта (от 1 до 60):",
                            "Запустить", "Назад");
            return 1;
        }

        StartRestartTimer(playerid, minutes);
    }
	new f = GetPlayerIdFamily(playerid);
	if(dialogid == DIALOG_SMENA_NAZVANIA_FAM)
    {
        if(response)
        {
            new fam_name[32];

            if(sscanf(inputtext, "s[32]", fam_name) || strlen(inputtext) < 3)
            {
           		new Node:response = JSON_Object();
                        JSON_SetInt(response, "t", 0);
                        JSON_SetInt(response, "y", 0);
                        JSON_SetInt(response , "k", 1);
                        JSON_SetString(response, "n", "Название семьи должно состоять от 3 до 32 символов");
                        SendPacketToClient(playerid, 22, response);
                        return 1;
            }

            for(new i; i < strlen(fam_name); i++) if(fam_name[i] == '-' && fam_name[i+7] == '}') fam_name[i] = '{';

            format(family[f][family_name], 32, fam_name);
            mysql_format(mysql, f_string144, sizeof f_string144, "UPDATE family SET name='%s' WHERE id = %d", GetFamily(f, family_name), GetFamily(f, family_database));
            mysql_query(mysql, f_string144, false);

            GivePlayerDonateRub(playerid, -100);

            FSendClientMessage(f_string144, playerid, -1, ""c_f_g"Вы изменили название вашей семьи на %s.", GetFamily(f, family_name));
            new fmtfam[512];
            format(fmtfam, sizeof(fmtfam), "Новое название вашей семьи %s", GetFamily(f, family_name));
            new Node:JSONObject = JSON_Object();

			JSON_SetInt(JSONObject, "t", 0);
        	JSON_SetInt(JSONObject, "y", 1);

			JSON_SetString(JSONObject, "m", "Вы успешно изменили имя семьи.");
