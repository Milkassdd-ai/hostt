forward UpdateGZOutVehicleRPC();
public UpdateGZOutVehicleRPC()
{
    foreach(new playerid : Player)
    {
        if(!IsPlayerConnected(playerid)) continue;

        new bool:isInGreenZone = GreenZone(playerid);

        if(isInGreenZone && PlayerInfo[playerid][P_IN_GREEN_ZONE] == 0)
        {

            PlayerInfo[playerid][P_IN_GREEN_ZONE] = 1;
            SetGreenZoneForPlayer(playerid, 1);
            PlayerInfo[playerid][P_GZ_OUT_VEH_RPC_ACTIVE] = 1;

        }
        else if(!isInGreenZone && PlayerInfo[playerid][P_IN_GREEN_ZONE] == 1)
        {

            PlayerInfo[playerid][P_IN_GREEN_ZONE] = 0;
            SetGreenZoneForPlayer(playerid, 0);
            PlayerInfo[playerid][P_GZ_OUT_VEH_RPC_ACTIVE] = 0;

        }
    }

    return 1;
}
forward UnFreezePlayerExAfterRent(playerid);
public UnFreezePlayerExAfterRent(playerid)
{
        TogglePlayerControllable(playerid, true);
}

stock IsNumeric(const string[])
{
    for(new i = 0; i < strlen(string); i++)
    {
        if(string[i] < '0' || string[i] > '9')
            return false;
    }
    return true;
}

stock HidePlayerGUI(playerid, guiid)
{
	new Node:json = JSON_Object();
	JSON_SetInt(json, "c", 1);
	SendPacketToClient(playerid, guiid, json);
}
CMD:radial(playerid)
{
    if (!IsPlayerInAnyVehicle(playerid))
        return SendClientMessage(playerid, 0xCECECE, "Вы должны находиться в транспорте");

    new vehicleid = GetPlayerVehicleID(playerid);
    new Node:JSONObject = JSON_Object();
    new Node:Info = JSON_Array();

    if (GetVehicleParam(vehicleid, V_LOCK))
        Info = JSON_Append(Info, JSON_Array(JSON_Int(3)));
    if (vInfo[vehicleid][vLaunchControl])
        Info = JSON_Append(Info, JSON_Array(JSON_Int(5)));
    if (GetVehicleParam(vehicleid, V_ENGINE))
        Info = JSON_Append(Info, JSON_Array(JSON_Int(6)));
    if (vInfo[vehicleid][vEnableNeon])
        Info = JSON_Append(Info, JSON_Array(JSON_Int(12)));
    if (vInfo[vehicleid][vEnableHighLights])
        Info = JSON_Append(Info, JSON_Array(JSON_Int(13)));
    if (GetVehicleParam(vehicleid, V_LIGHTS))
        Info = JSON_Append(Info, JSON_Array(JSON_Int(14)));
    if (vInfo[vehicleid][vEnableStrob])
        Info = JSON_Append(Info, JSON_Array(JSON_Int(15)));
    if (vInfo[vehicleid][vEnableHydraulics])
        Info = JSON_Append(Info, JSON_Array(JSON_Int(19)));

    Info = JSON_Append(Info, JSON_Array(JSON_Int(1)));
    JSON_SetArray(JSONObject, "s", Info);

    ShowPlayerGUI(playerid, 27, JSONObject);

    JSON_Cleanup(Info);
    JSON_Cleanup(JSONObject);
    return true;
}

stock ShowBuyNumberDialog(playerid)
{
    new vehicleid = GetPlayerOwnableCar(playerid);

    if(vehicleid == INVALID_VEHICLE_ID)
    {
        if(GetPlayerOwnableCars(playerid) == 0)
            return SendClientMessage(playerid, 0x999999FF, "У Вас нет личного транспорта");
	}
    Dialog
    (
        playerid, 9500, DIALOG_STYLE_TABLIST_HEADERS,
        "{FF5252}Номерные знаки",
        "{FF5252}№\t{FF5252}Тип номерных знаков\t{FF5252}Описание\n"\
        "{FF5252}1\t{FFFFFF}Рандомные номерные знаки\t{FFFFFF}Автоматическая генерация номеров",
        "Выбрать", "Закрыть"
    );

    return 1;
}

public DelayedSpawnAndEngine(playerid, vehicleid)
{
    if(!IsPlayerConnected(playerid) || !IsValidVehicle(vehicleid))
        return 0;

    PutPlayerInVehicle(playerid, vehicleid, 0);

    SetTimerEx("AutoStartEngine", 150, false, "ii", playerid, vehicleid);

    return 1;
}

public AutoStartEngine(playerid, vehicleid)
{
    if(!IsPlayerConnected(playerid) || !IsValidVehicle(vehicleid))
        return 0;

    if(GetVehicleData(vehicleid, V_FUEL) <= 0.0)
    {
        ShowNotificationSile(playerid, 2, 5, -1, -1, "Нет бензина.", "");
        return 0;
    }

    return 1;
}
stock SetPlayerGPSPoint(playerid, Float:x, Float:y, Float:z, color = 0xFF5252FF)
{
    new BitStream:bs = BS_New();

    BS_WriteValue(bs, PR_UINT8, 0x1A);

    BS_WriteValue(bs, PR_UINT32, color);

    BS_WriteValue(bs, PR_FLOAT, x);
    BS_WriteValue(bs, PR_FLOAT, y);
    BS_WriteValue(bs, PR_FLOAT, z);

    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);

    return 1;
}

stock CreateATMs()
{
    for(new i = 0; i < sizeof(ATM_Positions); i++)
    {

        ATM_Areas[i] = CreateDynamicSphere(
            ATM_Positions[i][0],
            ATM_Positions[i][1],
            ATM_Positions[i][2],
            2.0,
            .interiorid = floatround(ATM_Positions[i][3]),
            .worldid = floatround(ATM_Positions[i][4])
        );

        CreateDynamic3DTextLabel(
            "{33AAFF}Банкомат\n{FFFFFF}Нажмите {FFCD00}Y",
            -1,
            ATM_Positions[i][0],
            ATM_Positions[i][1],
            ATM_Positions[i][2] + 0.5,
            5.0,
            .interiorid = floatround(ATM_Positions[i][3]),
            .worldid = floatround(ATM_Positions[i][4])
        );
    }
    return 1;
}
stock IsPlayerAtATM(playerid)
{
    for(new i = 0; i < sizeof(ATM_Areas); i++)
    {
        if(IsPlayerInDynamicArea(playerid, ATM_Areas[i]))
            return 1;
    }
    return 0;
}
stock ToggleInteractionWindow(playerid, bool:toggle)
{
    new BitStream:bs = BS_New();
    BS_WriteValue(bs, PR_UINT8, 2);
    BS_WriteValue(bs, PR_UINT8, toggle);

    PR_SendRPC(bs, playerid, 168, PR_LOW_PRIORITY, PR_RELIABLE_ORDERED);
    BS_Delete(bs);
    return 1;
}
