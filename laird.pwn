				vehidinko[napinko[playerid]] = vehidinko[playerid];
				inkwork[playerid] = 1;
				inkwork[napinko[playerid]] = 2;
				PutPlayerInVehicle(playerid, vehidinko[playerid], 0);
				SendClientMessage(playerid, 0xFF5252, "| Вы успешно арендовали авто. Для принятия заказов введите {FF5252}/blist");
				SendClientMessage(napinko[playerid], 0xFF5252, "| Вы успешно сели в авто к напарнику. Для принятия заказов введите {FF5252}/blist");
				GivePlayerMoney(playerid, -5000);
				inko[playerid] = 2;
				inko[napinko[playerid]] = 2;
			}
			default: SendClientMessage(playerid, 0x808080, "Недоступно");
		}
	}

			if (dialogid == DIALOG_START_QUEST) {
        if (response)
{
            SendClientMessage(playerid, COLOR_WHITE, "Вы направляетесь к Злой Зине...");
            SetPlayerPos(playerid, 1051.383789,2032.698730,14.418960);
        } else
{
            SendClientMessage(playerid, COLOR_RED, "Вы отменили квест.");
            g_PlayerQuestState[playerid] = QUEST_NOT_STARTED;
        }
    } else
if (dialogid == DIALOG_END_QUEST)
 {
        if (response)
{
            GivePlayerMoney(playerid, 100000);
            SendClientMessage(playerid, COLOR_WHITE, "Вы получили 100000 денег за выполнение квеста!");
            g_PlayerQuestState[playerid] = QUEST_COMPLETED;
        }
    }

