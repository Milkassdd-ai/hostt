					{
						new order_prods = strval(inputtext);
						new prod_price = 35;
						new price = order_prods * prod_price;

						if(order_prods > 0 && IsNumeric(inputtext))
						{
							new fmt_str[256];

							new free_prods_slots = GetBusinessMaxProd(businessid) - GetBusinessData(businessid, B_PRODS);

