							if(Config[sBuyBiz] == 0)
						    {
								Dialog
								(
									playerid, DIALOG_BUYBIZ_CLOSE, DIALOG_STYLE_MSGBOX,
									"Запрет на покупку бизнеса",
									""c_b"Вы уверены, что хотите запретить покупать бизнесы на сервере?",
									"Далее", "Отмена"
								);
							}

							if(Config[sBuyBiz] == 1)
						    {
