if (dialogid == DIALOG_SETADMINS)
{

	new level = listitem + 1;

    if (level > GetPlayerAdminEx(playerid))
        return SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Вы не можете назначить уровень выше своего.");
    if (response)
    {
        new textPlayer[444], textAdmin[444], textAdmins[444];
        new id = g_player[playerid][P_TARGET_PLAYER_ID];

        static const adminRanks[][] = {
            "Младший модератор",
            "Модератор",
            "Старший модератор",
            "Администратор",
            "Старший администратор",
            "ГС/ЗГС",
            "Куратор администрации",
            "Технический специалист",
            "Зам. главного администратора",
            "Главный администратор",
            "Команда проекта",
            "Заместитель основателя",
            "Основатель"
        };

        if (listitem >= 0 && listitem < sizeof(adminRanks))
        {
            new level = listitem + 1;
            new rankName[64];
            format(rankName, sizeof(rankName), "%s", adminRanks[listitem]);

            SetPlayerData(id, P_ADMIN, level);
            UpdatePlayerDatabaseInt(id, "admin", level);
            format(GetPlayerData(id, P_PREFIX), 32, "%s", rankName);
            UpdatePlayerDatabaseString(id, "prefix", rankName);

            format(textPlayer, sizeof(textPlayer), "{FF5252}|{1E90FF} %s[%d] назначил Вас администратором \"%s\"", GetPlayerNameEx(playerid), playerid, rankName);
            format(textAdmin, sizeof(textAdmin), "{FF5252}|{ffffff} Вы поставили на пост администратора %s[%d] {FF5252} \"%s\"", GetPlayerNameEx(id), id, rankName);
            format(textAdmins, sizeof(textAdmins), "{FF5252}[ADMIN INFO]{ffffff} %s[%d] назначил %s[%d] на должность \"%s\"", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(id), id, rankName);

            SendClientMessage(playerid, -1, textAdmin);
            SendClientMessage(id, -1, textPlayer);
            SendMessageToAdmins(textAdmins, 0x999999FF);
            AdminAuthorization(id);

            new debugText[64];
            SendClientMessage(playerid, -1, debugText);
        }
        else
        {
            SendClientMessage(playerid, -1, "{FF0000}[Ошибка]{FFFFFF} Неверный уровень администратора.");
        }
    }
}

