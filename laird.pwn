                else
                {
                    if(GetPVarFloat(playerid, "num_4") <= -360.000000)
                        SetPVarFloat(playerid, "num_4", 5.000000);
                    Rx -= 5.0;
                }
                format(acs_coords, sizeof acs_coords, "%.0f", GetPVarFloat(playerid, "num_4") + Rx);
