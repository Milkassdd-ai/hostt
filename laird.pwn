	       {
	               SendClientMessage(playerid, -1,  "Игрок не найден");
	               return 1;
	       }

			if(GetPlayerAdminEx(to_player) > GetPlayerAdminEx(playerid)) return SendClientMessage(playerid, 0xCECECEFF, "Нельзя кикнуть администратора выше по рангу");

           if(strlen(inputtext) < 3)
           {
                  ShowPlayerDialog(playerid, DIALOG_KICK_SPEC, DIALOG_STYLE_INPUT, "{ffcc00}Lonexs Test | {FFFFFF}Кик игрока",
