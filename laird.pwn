							else SendClientMessage(playerid, 0x999999FF, "У Вас нет дома");
						}
						case 2:
						{
							buffer = GetPlayerBusiness(playerid);
							if(buffer != -1)
							{
								ShowPlayerBusinessPayForRent(playerid);
								return 1;
