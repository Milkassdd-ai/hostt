            if(freeSlot == -1)
            {
                new Node:JSONObject = JSON_Object();

				JSON_SetInt(JSONObject, "t", 0);
           	JSON_SetInt(JSONObject, "y", 0);
               JSON_SetInt(JSONObject, "k", -1);

