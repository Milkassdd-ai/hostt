				}
			}
			case DIALOG_JOIN_TO_JOB:
			{
				if(response)
				{
					if(GetPlayerTeamEx(playerid) != 0)
						return SendClientMessage(playerid, 0x999999FF, ""USC"Вы не можете устроиться на работу, находясь во фракции");

					switch(listitem + 1)
					{
						case JOB_BUS_DRIVER:
						{
							if(GetPlayerLevel(playerid) < 2)
								return SendClientMessage(playerid, 0xCECECEFF, ""USC"Чтобы устроиться на работу водителя автобуса необходим 2 уровень");

							SendClientMessage(playerid, 0xFF5252FF, ""SC"Поздравляем! Вы устроились на работу водителя автобуса");
							SendClientMessage(playerid, 0xFFFFFFFF, ""SC"Стоянки автобусов находятся на всех автостанциях. Используйте {0099FF}/gps {FFFFFF}чтобы найти ближайшую к вам");
						}
						case JOB_KYRER:
						{
							if(GetPlayerLevel(playerid) < 2)
								return SendClientMessage(playerid, 0xCECECEFF, ""USC"Чтобы устроиться на работу курьера, необходим 2 уровень");

							SendClientMessage(playerid, 0xFF5252FF, ""SC"Поздравляем! Вы устроились на работу курьера");
