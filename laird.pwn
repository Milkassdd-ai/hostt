	format(fmt_msg, sizeof fmt_msg, "Забанил %s[acc:%d] на %d дней. Причина %s", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), prichina);

	SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, fmt_msg);

