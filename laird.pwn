            }

            if(GetPlayerIdFamily(to_player) != -1)
            {
                new Node:response = JSON_Object();
                JSON_SetInt(response, "t", 0);
                JSON_SetInt(response, "y", 0);
                JSON_SetInt(response, "k", 1);
                JSON_SetString(response, "n", "Игрок уже состоит в семье.");
                SendPacketToClient(playerid, 22, response);
                JSON_Cleanup(response);
                return 1;
            }

            if(!IsPlayerInRangeOfPlayer(playerid, to_player, 5.0))
            {
                new Node:response = JSON_Object();
                JSON_SetInt(response, "t", 0);
                JSON_SetInt(response, "y", 0);
                JSON_SetInt(response, "k", 1);
                JSON_SetString(response, "n", "Игрок слишком далеко");
                SendPacketToClient(playerid, 22, response);
                JSON_Cleanup(response);
