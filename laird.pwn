case DIALOG_EVENT_WINNER:
{
    if(response)
    {
        new winnerid, prize_amount;
        new str_winnerid[10], str_prize[20], str_full[50];

        format(str_full, sizeof(str_full), "%s", inputtext);

        if(sscanf(str_full, "p<,>s[10]s[20]", str_winnerid, str_prize))
        {
            SendClientMessage(playerid, COLOR_RED, "Ошибка: Неверный формат. Используйте: ID, сумма");
            return 1;
        }

        winnerid = strval(str_winnerid);
        prize_amount = strval(str_prize);

        if(winnerid < 0 || winnerid > MAX_PLAYERS)
        {
            SendClientMessage(playerid, COLOR_RED, "Ошибка: Неверный ID игрока");
            return 1;
        }

        if(!IsPlayerConnected(winnerid))
        {
            SendClientMessage(playerid, COLOR_RED, "Ошибка: Игрок с таким ID не найден");
            return 1;
        }

        if(prize_amount <= 0)
        {
            SendClientMessage(playerid, COLOR_RED, "Ошибка: Сумма приза должна быть больше 0");
            return 1;
        }

        GivePlayerMoney(winnerid, prize_amount);

        new query[256];
        new winner_name[MAX_PLAYER_NAME];
        GetPlayerName(winnerid, winner_name, sizeof(winner_name));
        new admin_name[MAX_PLAYER_NAME];
        GetPlayerName(playerid, admin_name, sizeof(admin_name));

        format(query, sizeof(query), "{FFCC33}Администратор {d58300}%s {FFCC33}выдал игроку {d58300}%s[%d] {FFCC33}приз в размере {d58300}%d {FFCC33}игровых рублей!",
            admin_name, winner_name, winnerid, prize_amount);
        SendClientMessageToAll(0xFFCC33FF, query);

        format(query, sizeof(query), "{FFCC33}Поздравляем! Вы получили приз в размере {d58300}%d {FFCC33}игровых рублей!", prize_amount);
        SendClientMessage(winnerid, 0x3399FFFF, query);
    }
}
			case DIALOG_EVENT_SKIN:
			{
			    if(response)
			    {
					new skin_id;

					if(sscanf(inputtext, "d", skin_id))
					{
						SendClientMessage(playerid, 0xCECECEFF, "Некорректный ввод");
						callcmd::event(playerid, "");

						return 1;
					}
					else
					{
				        if(!(-1 <= skin_id <= 299) || skin_id == 0) return SendClientMessage(playerid, 0xCECECEFF, "ID скина от 1 до 299");

						for(new i; i < MAX_PLAYERS; i ++)
						{
							if(!IsPlayerConnected(i)) continue;
							else if(!IsPlayerLogged(i)) continue;
							else if(!GetPlayerData(i, P_LAST_MP)) continue;

							if(skin_id != -1)
								SetPlayerSkin(i, skin_id);
							else
								SetPlayerSkin(i, GetPlayerSkinEx(i));
						}
					}
			    }
			}
		}
	}
	return 1;
}

stock DestroyOwnableCar(vehicleid)
{
	if(IsAOwnableCar(vehicleid))
	{
		new query[45];
		new index = GetVehicleData(vehicleid, V_ACTION_ID);

		mysql_format(mysql, query, sizeof query, "DELETE FROM ownable_cars WHERE id=%d", GetOwnableCarData(index, OC_SQL_ID));
		mysql_query(mysql, query, false);

		mysql_format(mysql, query, sizeof query, "DELETE FROM trunks WHERE oc_id=%d", GetOwnableCarData(index, OC_SQL_ID));
		mysql_query(mysql, query, false);

		if(!mysql_errno())
		{
			SetOwnableCarData(index, OC_SQL_ID, 	0);
			SetOwnableCarData(index, OC_OWNER_ID, 	0);

			DestroyVehicleLabel(vehicleid);
			UnloadOwnableCarTrunk(vehicleid);

			SetOwnableCarData(index, OC_CREATE, 0);
			DestroyVehicle(vehicleid);
			return 1;
		}
		else printf("[Error]: [OwnableCars]: Ошибка удаления личного ТС: %d", GetOwnableCarData(index, OC_SQL_ID));
	}
	return 0;
}
stock DestroyFamilyCar(vehicleid)
{
	if(IsAFamilyCar(vehicleid))
	{
		new query[45];
		new index = GetVehicleData(vehicleid, V_ACTION_ID);

		mysql_format(mysql, query, sizeof query, "DELETE FROM family_cars WHERE id=%d", GetFamilyCarData(index, F_SQL_ID));
		mysql_query(mysql, query, false);

		if(!mysql_errno())
		{
			g_family_car[index][F_OWNER_ID] = -1;
			g_family_car[index][F_SQL_ID] = 0;

			DestroyVehicleLabel(vehicleid);
			UnloadOwnableCarTrunk(vehicleid);

			SetOwnableCarData(index, OC_CREATE, 0);
			DestroyVehicle(vehicleid);
			return 1;
		}
		else printf("[Error]: [FamilyCars]: Ошибка удаления семейного ТС: %d", GetOwnableCarData(index, OC_SQL_ID));
	}
	return 0;
}

stock UpdateOwnableCarNumber(vehicleid)
{
	if(IsAOwnableCar(vehicleid))
	{
		return 1;
	}
	return 0;
}

