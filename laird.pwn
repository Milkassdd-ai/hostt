					mysql_format(mysql, fmt_str, sizeof fmt_str, "UPDATE accounts SET admin=%d,rub=%d WHERE id=%d", GetPlayerAdminEx(playerid), GetPlayerDonateRub(playerid), GetPlayerAccountID(playerid));
					mysql_query(mysql, fmt_str, false);
