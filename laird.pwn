stock SetPlayerMinerJobLoadCP(playerid)
{
    if(GetPlayerTempJob(playerid) == TEMP_JOB_MINER)
    {
        for(new i = 0; i < sizeof miner_job_chop_cp; i++)
        {
            if(miner_job_cp[playerid][i] != -1)
            {
                DestroyDynamicCP(miner_job_cp[playerid][i]);
                miner_job_cp[playerid][i] = -1;
            }
        }
        
        for(new i = 0; i < sizeof miner_job_chop_cp; i++)
        {
            miner_job_cp[playerid][i] = CreateDynamicCP(
                miner_job_chop_cp[i][0],
                miner_job_chop_cp[i][1],
                miner_job_chop_cp[i][2],
                0.8, 0, 1, playerid
            );
        }
        
        SetPlayerTempJobState(playerid, TEMP_JOB_STATE_MINER_LOAD);
    }
}

stock SetPlayerMinerJobUnLoadCP(playerid)
{
	if(GetPlayerTempJob(playerid) == TEMP_JOB_MINER)
	{
		miner_un_job_cp[playerid] = CreateDynamicCP(557.126159,515.976318,999.714477, 0.8, 0, 1, playerid);
		 
		SetPlayerTempJobState(playerid, TEMP_JOB_STATE_MINER_UNLOAD);
	}
}

