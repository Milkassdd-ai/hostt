public LoadOwnableCarRent(playerid, oc_id)
{
    new idx = GetFreeOwnableCarID();
    if(idx == -1)
    {
        print("[OwnableCars]: Нет свободного ID транспорта");
        return INVALID_VEHICLE_ID;
    }

    new query[196], Cache:result;
    mysql_format(mysql, query, sizeof query, "SELECT * FROM ownable_cars WHERE id='%d' LIMIT 1", oc_id);
    result = mysql_query(mysql, query, true);

    if(!cache_num_rows())
    {
        cache_delete(result);
        print("[OwnableCars]: Машина не найдена в БД");
        return INVALID_VEHICLE_ID;
    }

    new zone_id = GetPVarInt(playerid, "rent_zone_id");
    if(zone_id < 0 || zone_id >= TotalRentZones)
    {
        cache_delete(result);
        SendClientMessage(playerid, 0x999999FF, "Ошибка: парковка аренды не найдена");
        return INVALID_VEHICLE_ID;
    }

    new slot_id = GetFreeParkingSlot(zone_id);
    new bool:use_parking_slot = (slot_id != -1);
    new Float:spawn_x, Float:spawn_y, Float:spawn_z, Float:spawn_a;

    if(use_parking_slot)
    {
        spawn_x = ParkingSlots[zone_id][slot_id][PARKING_X];
        spawn_y = ParkingSlots[zone_id][slot_id][PARKING_Y];
        spawn_z = ParkingSlots[zone_id][slot_id][PARKING_Z];
        spawn_a = ParkingSlots[zone_id][slot_id][PARKING_A];
    }
    else
    {
        GetPlayerPos(playerid, spawn_x, spawn_y, spawn_z);
        GetPlayerFacingAngle(playerid, spawn_a);
        spawn_x += 5.0 * floatsin(-spawn_a, degrees);
        spawn_y += 5.0 * floatcos(-spawn_a, degrees);
    }

    new model_id = cache_get_field_content_int(0, "model_id");

    SetOwnableCarData(idx, OC_SQL_ID, cache_get_field_content_int(0, "id"));
    SetOwnableCarData(idx, OC_OWNER_ID, cache_get_field_content_int(0, "owner_id"));
    SetOwnableCarData(idx, OC_MODEL_ID, model_id);
    SetOwnableCarData(idx, OC_COLOR_1, cache_get_field_content_int(0, "color_1"));
    SetOwnableCarData(idx, OC_COLOR_2, cache_get_field_content_int(0, "color_2"));

    SetOwnableCarData(idx, OC_PT_BRAKE, cache_get_field_content_int(0, "pt_brake"));
    SetOwnableCarData(idx, OC_PT_STABILITY, cache_get_field_content_int(0, "pt_stability"));
    SetOwnableCarData(idx, OC_PT_ENGINE, cache_get_field_content_int(0, "pt_engine"));
    SetOwnableCarData(idx, OC_NUMBER_TYPE, cache_get_field_content_int(0, "number_type"));

    cache_get_field_content(0, "number", g_ownable_car[idx][OC_NUMBER], mysql, 32);
    cache_get_field_content(0, "region", g_ownable_car[idx][OC_REGION], mysql, 8);

    new vehicleid = CreateVehicle(
        model_id,
        spawn_x,
        spawn_y,
        spawn_z,
        spawn_a,
        GetOwnableCarData(idx, OC_COLOR_1),
        GetOwnableCarData(idx, OC_COLOR_2),
        -1, 0,
        VEHICLE_ACTION_TYPE_OWNABLE_CAR, idx
    );

    if(vehicleid == INVALID_VEHICLE_ID)
    {

        cache_delete(result);
        return INVALID_VEHICLE_ID;
    }

    SetVehicleData(vehicleid, V_HEALTH, 1000.0);
    SetVehicleHealth(vehicleid, 1000.0);
    SetVehicleData(vehicleid, V_LAST_LOAD_TIME, gettime());
    SetVehicleData(vehicleid, V_MILEAGE, cache_get_field_content_float(0, "mileage"));
    SetVehicleParam(vehicleid, V_LOCK, bool:cache_get_field_content_int(0, "status"));

    ApplyVehicleNumberPlate(vehicleid);

    LoadVehicleTuningFromCache(vehicleid, 0, result);

    if(use_parking_slot)
    {
        OccupyParking(zone_id, slot_id, vehicleid);
        SetPVarInt(playerid, "parking_zone", zone_id);
        SetPVarInt(playerid, "parking_slot", slot_id);
    }
    else
    {
        DeletePVar(playerid, "parking_zone");
        DeletePVar(playerid, "parking_slot");
    }

    foreach(new i: Player)
    {
        if(IsPlayerConnected(i) && IsVehicleStreamedIn(vehicleid, i))
        {
            SyncVehicleTuningForPlayer(i, vehicleid);
        }
    }

    cache_delete(result);
    LoadOwnableCarTrunk(vehicleid);

    return vehicleid;
}

stock GetVehicleModelName(modelid, name[], size = 24)
{
    if(GetVehicleJsonNameByModelId(modelid, name, size))
    {
        return 1;
    }
    if (modelid >= 400 && modelid <= 30000)
    {
        format(name, size, "%s", g_vehicle_info[modelid - 400][VI_NAME]);
    }
    else
    {
        format(name, size, "Модель %d", modelid);
    }
}

stock GetVehicleMarketPriceByModel(modelid)
{
    new price;

    if(GetVehicleJsonCostByModelId(modelid, price))
    {
        return price;
    }

    if(modelid >= 400 && modelid <= 3000)
    {
        return GetVehicleInfo(modelid - 400, VI_PRICE);
    }

    return 0;
}
stock bool:IsOwnableCarLoaded(carid)
{
    for (new i = 0; i < MAX_PLAYERS; i++)
    {
        if (!IsPlayerConnected(i)) continue;

        if (GetPlayerOwnableCar(i) == carid)
            return true;
    }
    return false;
}

stock utf8_to_cp1251(string[]) {
    new len = strlen(string);
    for (new i = 0; i < len; i++) {
        if (string[i] == 0xD0 && i + 1 < len) {
            if (string[i + 1] >= 0x90 && string[i + 1] <= 0xBF) {
                string[i] = string[i + 1] + 0x30;
                strdel(string, i + 1, i + 2);
                len--;
            }
        }
        else if (string[i] == 0xD1 && i + 1 < len) {
            if (string[i + 1] >= 0x80 && string[i + 1] <= 0x8F) {
                string[i] = string[i + 1] + 0x70;
                strdel(string, i + 1, i + 2);
                len--;
            }
        }
    }
    return 1;
}

stock cp1251_to_utf8(string[]) {
    new len = strlen(string);
    new result[128];
    new i = 0, j = 0;
    while (i < len && j < sizeof(result) - 2) {
        if (string[i] >= 0xC0) {
            result[j++] = 0xD0 + (string[i] >= 0xF0);
            result[j++] = string[i++] - (string[i] >= 0xF0 ? 0x70 : 0x30);
        } else {
            result[j++] = string[i++];
        }
    }
    result[j] = 0;
    format(string, 128, "%s", result);
}

stock UTF8_tto_CP1251(const input[], output[], maxlen)
{
    new i = 0, j = 0;
    while (input[i] != '\0' && j < maxlen - 1)
    {
        new c = input[i];
        if (c < 0x80)
        {
            output[j++] = c;
            i++;
        }
        else if ((c & 0xE0) == 0xC0)
        {
            new c2 = input[i+1];
            new codepoint = ((c & 0x1F) << 6) | (c2 & 0x3F);
            if (codepoint >= 0x0410 && codepoint <= 0x044F)
                output[j++] = codepoint - 0x0410 + 0xC0;
            else if (codepoint == 0x0401) output[j++] = 0xA8;
            else if (codepoint == 0x0451) output[j++] = 0xB8;
            else output[j++] = '?';
            i += 2;
        }
        else
        {
            output[j++] = '?';
            i++;
        }
    }
    output[j] = '\0';
}

