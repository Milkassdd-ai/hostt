	if(inkwork[playerid] == 1 && inko[playerid] == 3)
	{
		new Float: x = GetPVarFloat(playerid, "inkox"), Float: y = GetPVarFloat(playerid, "inkoy"), Float: z = GetPVarFloat(playerid, "inkoz");
		if(IsPlayerInRangeOfPoint(playerid, 3.0, x,y,z))
		{
			DisablePlayerCheckpoint(playerid);
			SendClientMessage(napinko[playerid], 0xFF5252, "Заберите денежные средства у отмеченной точки");
			SendClientMessage(playerid, 0xFF5252, "Ожидайте пока ваш напарник выполнит работу");
			inko[playerid] = 5;
			inko[napinko[playerid]] = 6;
			new Float: x, Float: y, Float: z;
			GetPlayerPos(playerid, x, y, z);
			SetPlayerCheckpoint(napinko[playerid], x-3, y-3, z, 3.0);
			SetTimerEx("timerinko", 1000, true, "d", napinko[playerid]);
			SetPVarFloat(playerid, "inkox", x+3);
			SetPVarFloat(playerid, "inkoy", y+3);
			SetPVarFloat(playerid, "inkoz", z);
		}
	}
