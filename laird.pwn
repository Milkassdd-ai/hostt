stock CreateActorEx(name[],text[], skinid, Float:posx,Float:posy,Float:posz,Float:rot,virt = 0,inter = 0,inv = 1)
{
    for(new i = 0; i < MAX_ACTORS; i++)
    {
        if(IsValidActor(i)) continue;
        CreateActor(skinid,posx,posy,posz,rot);
        new string[144];
        SetActorVirtualWorld(i,virt);
        SetActorInvulnerable(i,inv);
        if(strlen(name) || strlen(text))
        {
            format(string,sizeof(string),"{FFFFFF}%s\n%s",name,text);
            CreateDynamic3DTextLabel(string,0xFF5252AA,posx,posy,posz+1.2,10.0,INVALID_PLAYER_ID, INVALID_VEHICLE_ID, 1, virt, inter);
        }
        return i;
    }
    return -1;
}

CMD:clist(playerid)
{
     if(IsPlayerConnected(playerid))
     {
            if(GetPlayerJob(playerid) != JOB_INK)
			{
   				SendClientMessage(playerid, COLOR_RED, "{ff2400}| {ffffff}Вы не работаете инкоссатором!");
                return 1;
            }
            if(PlayerIsInkasator[playerid] == 2)
            {
                SendClientMessage(playerid, COLOR_RED, "{ff2400}| {ffffff}Вы уже взяли заказ");
                return 1;
            }
            ShowPlayerDialog(playerid, 8646, DIALOG_STYLE_LIST, "Список заказов инкассатора", "Заказ 1", "Взять", "Отмена");
	}
	return 1;

}

public OnTrailerUpdate(playerid, vehicleid) {
	if(GetPVarInt(playerid, "cargovzyat")) return true;
	else
	{
	    SetPlayerCheckpoint(playerid, 2325.356933,1747.288696,0.506430, 5.0);
		SendClientMessage(playerid, -1, "{FF5252}|{ffffff} На карте отмечена точка, куда вам необходимо ехать для загрузки прицепа!");
		SetPVarInt(playerid, "cargovzyat", 1);
		PlayerIsDalnoboi[playerid] = 1;
		return true;
	}

}

CMD:cargo(playerid)
{
    if(GetPlayerJob(playerid) != 10)
    {
        SendClientMessage(playerid, -1, "{ff2400}|{ffffff} Вы не работаете в транспортной компании");
        return true;
	}
	else
	{
	    if(!GetPVarInt(playerid, "cargosp"))
	    {
		    ShowPlayerDialog(playerid, 8654, DIALOG_STYLE_LIST, "Список заказов", "Обычная руда\t49470 РУб\nОбычная руда\t47658 РУб\nОбычная руда\t44897 РУб\nОвощи\t46879 РУб\tМеталл\t47893 РУб\nОбычная руда\t45980 РУб", "Взять", "Отмена");
			return true;
	    }

		else
		{
		    return SendClientMessage(playerid, -1, "{ff2400}| {ffffff}Вы уже взяли заказ!");
		}
  }

}

